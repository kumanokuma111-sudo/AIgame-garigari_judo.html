<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ガリガリ柔道</title>
<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js"
  }
}
</script>
<script>
  window.__THREE_CDN_FALLBACKS = [
    'https://unpkg.com/three@0.160.0/build/three.module.js',
    'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js',
    'https://cdn.skypack.dev/three@0.160.0',
    'https://esm.sh/three@0.160.0',
    'https://cdn.jsdelivr.net/gh/mrdoob/three.js@r160/build/three.module.js'
  ];
  window.__threeCache = null;
  window.__threeLoading = null;
  window.loadThreeWithRetry = function(maxRetries) {
    if (window.__threeCache) return Promise.resolve(window.__threeCache);
    if (window.__threeLoading) return window.__threeLoading;
    const urls = window.__THREE_CDN_FALLBACKS.slice();
    const tries = (maxRetries == null ? 3 : maxRetries);
    const tryOnce = (urlIdx, attempt) => {
      if (urlIdx >= urls.length) return Promise.reject(new Error('All CDNs failed'));
      const url = urls[urlIdx];
      return import(/* @vite-ignore */ url).then(mod => {
        window.__threeCache = mod;
        return mod;
      }).catch(err => {
        console.warn('[three.js] load failed from', url, 'attempt', attempt, err);
        if (attempt < tries) {
          return new Promise(r => setTimeout(r, 350 * (attempt + 1)))
            .then(() => tryOnce(urlIdx, attempt + 1));
        }
        return tryOnce(urlIdx + 1, 0);
      });
    };
    window.__threeLoading = tryOnce(0, 0).then(mod => {
      window.__threeLoading = null;
      return mod;
    }).catch(err => {
      window.__threeLoading = null;
      throw err;
    });
    return window.__threeLoading;
  };
</script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; user-select: none; }
  html, body { width: 100%; height: 100%; overflow: hidden; font-family: "Hiragino Sans", "Yu Gothic", "Meiryo", sans-serif; background: #111; color: #fff; touch-action: manipulation; }
  #app { position: fixed; inset: 0; display: flex; flex-direction: column; }

  /* ====== 柔道専用 ====== */
  .judoBtn { transition: transform 0.08s, background 0.12s; cursor:pointer; }
  .judoBtn:active { transform: scale(0.95); background: rgba(255,255,255,0.25) !important; }
  .pinBtn {
    position:absolute; width:64px; height:64px; border-radius:50%;
    background: radial-gradient(circle at 30% 30%, #ffe066, #f59f00);
    border: 3px solid #fff;
    box-shadow: 0 0 14px rgba(255,224,102,0.8), 0 4px 8px rgba(0,0,0,0.5);
    display:flex; align-items:center; justify-content:center;
    font-weight:bold; font-size:26px; color:#5a2d00;
    cursor:pointer; user-select:none;
    pointer-events:auto;
    z-index: 6;
    animation: pinBtnPulse 0.5s ease-out;
  }
  .pinBtn.hit { background: radial-gradient(circle at 30% 30%, #b8ffb8, #2ecc40); transform:scale(1.2); opacity:0; transition:all 0.25s; }
  @keyframes pinBtnPulse {
    0% { transform: scale(0.3); opacity:0; }
    100% { transform: scale(1); opacity:1; }
  }

  /* ====== 共通 ====== */
  .screen { position: absolute; inset: 0; display: none; flex-direction: column; }
  .screen.active { display: flex; }
  .bg-photo {
    position: absolute; inset: 0; background-image: url('data:image/jpeg;base64,');
    background-size: cover; background-position: center; z-index: 0;
  }
  .bg-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.55) 60%, rgba(0,0,0,0.75) 100%);
    z-index: 1;
  }
  .content { position: relative; z-index: 2; display: flex; flex-direction: column; flex: 1; padding: 16px; }

  header.topbar {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; background: rgba(0,0,0,0.55); backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  header.topbar .icon { width: 40px; height: 40px; border-radius: 50%; overflow: hidden; background: #444; display: flex; align-items: center; justify-content: center; font-weight: bold; border: 2px solid #f7c948; }
  header.topbar .icon img { width: 100%; height: 100%; object-fit: cover; }
  header.topbar .nameWrap { flex: 1; display: flex; flex-direction: column; }
  header.topbar .nameWrap .nm { font-weight: bold; font-size: 15px; }
  header.topbar .nameWrap .sub { font-size: 11px; opacity: 0.7; }
  header.topbar button.iconBtn {
    background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2);
    padding: 6px 10px; border-radius: 8px; font-size: 12px; cursor: pointer;
  }

  h1.title {
    font-size: 42px; text-align: center; margin: 30px 0 6px;
    color: #f7c948; text-shadow: 3px 3px 0 #000, 0 0 20px rgba(247,201,72,0.6);
    letter-spacing: 2px; font-weight: 900;
  }
  .subtitle { text-align: center; font-size: 13px; opacity: 0.85; margin-bottom: 18px; }

  /* メニューボタン */
  .menu { display: flex; flex-direction: column; gap: 12px; padding: 8px 4px 16px; }
  .menu button {
    background: rgba(20,20,20,0.78); color: #fff; border: 2px solid #f7c948;
    padding: 16px; border-radius: 14px; font-size: 18px; font-weight: bold; cursor: pointer;
    backdrop-filter: blur(4px);
    transition: transform 0.1s, background 0.15s;
    text-align: left; display: flex; align-items: center; gap: 12px;
  }
  .menu button:active { transform: scale(0.97); background: rgba(247,201,72,0.25); }
  .menu button .emoji { font-size: 26px; }
  .menu button .desc { display: block; font-size: 11px; opacity: 0.7; font-weight: normal; margin-top: 2px; }

  /* タブバー */
  .tabbar {
    display: flex; background: rgba(0,0,0,0.7); border-top: 1px solid rgba(255,255,255,0.1);
  }
  .tabbar button {
    flex: 1; background: transparent; color: #aaa; border: none; padding: 10px 4px;
    font-size: 11px; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 2px;
  }
  .tabbar button .ic { font-size: 20px; }
  .tabbar button.active { color: #f7c948; }

  /* ゲーム画面共通 */
  .gameWrap { flex: 1; display: flex; flex-direction: column; }
  .gameHeader {
    display: flex; align-items: center; gap: 10px; padding: 10px 12px;
    background: rgba(0,0,0,0.7); border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .backBtn {
    background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.25);
    padding: 6px 12px; border-radius: 8px; font-size: 13px; cursor: pointer;
  }
  .gameTitle { font-weight: bold; flex: 1; font-size: 15px; }
  .gameInfo { font-size: 12px; opacity: 0.8; }

  canvas { display: block; background: #0a0a0a; touch-action: none; flex: 1; width: 100%; }

  /* ガリみくじ */
  .omikujiBox { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; gap: 16px; }
  .omikujiCard {
    width: 80%; max-width: 320px; aspect-ratio: 3/5; background: linear-gradient(180deg, #fff, #f4e7c1);
    border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center;
    color: #222; padding: 20px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.7);
    position: relative; overflow: hidden;
  }
  .omikujiCard::before { content: ""; position: absolute; top: 12px; left: 12px; right: 12px; bottom: 12px; border: 2px solid #c00; border-radius: 4px; }
  .omikujiCard .label { font-size: 14px; color: #c00; font-weight: bold; }
  .omikujiCard .fortune { font-size: 48px; font-weight: 900; color: #c00; margin: 12px 0; letter-spacing: 4px; }
  .omikujiCard .msg { font-size: 14px; color: #333; line-height: 1.6; padding: 0 8px; }
  .omikujiCard .date { font-size: 11px; color: #888; margin-top: 12px; }
  .omikujiBtn {
    background: #c00; color: #fff; border: none; padding: 14px 40px; border-radius: 30px;
    font-size: 18px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 0 #800;
  }
  .omikujiBtn:disabled { background: #555; box-shadow: 0 4px 0 #222; cursor: not-allowed; }

  /* 極太バスター・スコア表示 */
  .scoreBar {
    display: flex; justify-content: space-around; padding: 8px;
    background: rgba(0,0,0,0.7); font-size: 13px;
  }
  .scoreBar span { font-weight: bold; color: #f7c948; }

  .floatBars { position:absolute; inset:0; pointer-events:none; z-index:6; }
  /* HPバーを廃止して、頭の横に丸(SVG)を表示。色とひび割れで残りを示す */
  .charHpRing {
    position:absolute; width:44px; height:44px; transform:translate(-50%, -50%);
    pointer-events:none;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.55));
  }
  .charHpRing svg { width:100%; height:100%; display:block; overflow:visible; }
  .charHpRing .bg { fill: rgba(0,0,0,0.55); stroke: rgba(255,255,255,0.35); stroke-width:1.4; }
  .charHpRing .arc { fill:none; stroke:#57ef8c; stroke-width:5; stroke-linecap:round; transform: rotate(-90deg); transform-origin: 50% 50%; transition: stroke 0.18s; }
  .charHpRing.enemy .arc { stroke:#ff9764; }
  .charHpRing .lbl { font-size:9px; font-weight:bold; fill:#fff; text-anchor:middle; dominant-baseline:central; font-family: 'Hiragino Sans', sans-serif; }

  /* ニュース・ランキング・チャット */
  .listWrap { flex: 1; overflow-y: auto; padding: 12px; background: rgba(0,0,0,0.55); }
  .card {
    background: rgba(30,30,30,0.85); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px; padding: 12px; margin-bottom: 10px;
  }
  .card .ttl { font-weight: bold; font-size: 14px; margin-bottom: 4px; color: #f7c948; }
  .card .meta { font-size: 11px; opacity: 0.6; margin-bottom: 6px; }
  .card .body { font-size: 13px; line-height: 1.5; }

  .rankRow {
    display: flex; align-items: center; gap: 12px; padding: 10px 12px;
    background: rgba(30,30,30,0.85); border-radius: 10px; margin-bottom: 6px;
  }
  .rankRow .rk { font-size: 22px; font-weight: 900; min-width: 40px; text-align: center; color: #f7c948; }
  .rankRow .rk.gold { color: #ffd700; }
  .rankRow .rk.silver { color: #c0c0c0; }
  .rankRow .rk.bronze { color: #cd7f32; }
  .rankRow .ic { width: 36px; height: 36px; border-radius: 50%; background: #555; overflow: hidden; display: flex; align-items: center; justify-content: center; font-weight: bold; }
  .rankRow .ic img { width: 100%; height: 100%; object-fit: cover; }
  .rankRow .nm { flex: 1; font-weight: bold; font-size: 14px; }
  .rankRow .sc { font-weight: bold; color: #f7c948; }

  /* チャット */
  .chatWrap { flex: 1; display: flex; flex-direction: column; background: rgba(0,0,0,0.6); }
  .chatList { flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 8px; }
  .chatMsg { display: flex; gap: 8px; align-items: flex-start; max-width: 85%; }
  .chatMsg.me { align-self: flex-end; flex-direction: row-reverse; }
  .chatMsg .ic { width: 32px; height: 32px; border-radius: 50%; background: #555; flex-shrink: 0; overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; }
  .chatMsg .ic img { width: 100%; height: 100%; object-fit: cover; }
  .chatMsg .bubble { background: rgba(255,255,255,0.1); padding: 8px 12px; border-radius: 14px; font-size: 14px; word-break: break-word; }
  .chatMsg.me .bubble { background: #2a7; }
  .chatMsg .nm { font-size: 11px; opacity: 0.7; margin-bottom: 2px; }
  .chatInput {
    display: flex; gap: 8px; padding: 8px; background: rgba(0,0,0,0.8);
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .chatInput input {
    flex: 1; background: rgba(255,255,255,0.1); color: #fff;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; padding: 8px 14px; font-size: 14px; outline: none;
  }
  .chatInput button {
    background: #f7c948; color: #000; border: none; padding: 8px 16px; border-radius: 20px;
    font-weight: bold; cursor: pointer;
  }

  /* モーダル */
  .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 100; display: none; align-items: center; justify-content: center; padding: 20px; }
  .modal.active { display: flex; }
  .modalBox {
    background: #1a1a1a; border: 2px solid #f7c948; border-radius: 14px;
    padding: 20px; width: 100%; max-width: 360px; max-height: 90vh; overflow-y: auto;
  }
  .modalBox h2 { color: #f7c948; margin-bottom: 14px; font-size: 18px; }
  .modalBox label { display: block; font-size: 12px; opacity: 0.8; margin-bottom: 4px; margin-top: 12px; }
  .modalBox input[type="text"] {
    width: 100%; background: rgba(255,255,255,0.1); color: #fff;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; padding: 10px; font-size: 14px; outline: none;
  }
  .modalActions { display: flex; gap: 8px; margin-top: 18px; }
  .modalActions button {
    flex: 1; padding: 10px; border-radius: 8px; border: none; font-weight: bold; cursor: pointer; font-size: 14px;
  }
  .btnPrimary { background: #f7c948; color: #000; }
  .btnSecondary { background: rgba(255,255,255,0.15); color: #fff; }
  .iconPreview { width: 80px; height: 80px; border-radius: 50%; margin: 12px auto; background: #444; overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: bold; }
  .iconPreview img { width: 100%; height: 100%; object-fit: cover; }
  .uploadBtn {
    display: block; width: 100%; padding: 10px; background: rgba(255,255,255,0.1);
    border: 1px dashed rgba(255,255,255,0.3); border-radius: 8px; color: #fff;
    text-align: center; cursor: pointer; font-size: 13px;
  }

  .toast {
    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.9); color: #fff; padding: 10px 18px; border-radius: 20px;
    font-size: 13px; z-index: 200; opacity: 0; transition: opacity 0.3s; pointer-events: none;
    border: 1px solid #f7c948;
  }
  .toast.show { opacity: 1; }

  /* P2Pステータス */
  .p2pStatus {
    position: absolute; top: 70px; right: 10px; z-index: 3;
    background: rgba(0,0,0,0.7); padding: 4px 10px; border-radius: 12px;
    font-size: 11px; border: 1px solid rgba(255,255,255,0.2);
  }
  .p2pStatus .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #f44; margin-right: 4px; vertical-align: middle; }
  .p2pStatus .dot.on { background: #4f4; box-shadow: 0 0 6px #4f4; }
</style>
</head>
<body>
<div id="app">
  <!-- ====== メニュー画面 ====== -->
  <div class="screen active" id="screen-menu">
    <div class="bg-photo"></div>
    <div class="bg-overlay"></div>
    <div class="content">
      <header class="topbar">
        <div class="icon" id="topIcon">G</div>
        <div class="nameWrap">
          <span class="nm" id="topName">ゲスト</span>
          <span class="sub" id="topSub">タップして編集</span>
        </div>
        <button class="iconBtn" id="btnProfile">プロフィール</button>
      </header>
      <h1 class="title">ガリガリ柔道</h1>
      <div class="subtitle">〜 痩せ型最強の道 〜</div>
      <div class="p2pStatus" id="p2pStatus"><span class="dot" id="p2pDot"></span><span id="p2pText">P2P切断</span> / <span id="p2pCount">0人</span></div>
      <div class="menu">
        <button data-go="live">
          <span class="emoji">🌆</span>
          <div>
            ガリガリライブ <span style="color:#ffd76b;font-size:11px;">NEW</span>
            <span class="desc">オープンワールドPVPVE・市民/警察/車/信号あり</span>
          </div>
        </button>
        <button data-go="judo">
          <span class="emoji">🥋</span>
          <div>
            ガリガリ柔道(本編)
            <span class="desc">タックル・投げ・固め・ガードで相手を制圧せよ</span>
          </div>
        </button>
        <button data-go="boxing">
          <span class="emoji">🥊</span>
          <div>
            ガリガリ殴り合い
            <span class="desc">パンチ・キック・タックルが飛び交う路地裏の乱闘</span>
          </div>
        </button>
        <button data-go="omikuji">
          <span class="emoji">🎴</span>
          <div>
            ガリみくじ
            <span class="desc">1日1回限定のおみくじ</span>
          </div>
        </button>
        <button data-go="buster">
          <span class="emoji">👊</span>
          <div>
            極太バスター
            <span class="desc">タッチで巨漢を倒せ!</span>
          </div>
        </button>
      </div>
    </div>
    <div class="tabbar">
      <button class="active" data-tab="menu"><span class="ic">🏠</span>ホーム</button>
      <button data-tab="news"><span class="ic">📰</span>ニュース</button>
      <button data-tab="rank"><span class="ic">🏆</span>ランキング</button>
      <button data-tab="chat"><span class="ic">💬</span>チャット</button>
    </div>
  </div>

  <!-- ====== ニュース ====== -->
  <div class="screen" id="screen-news">
    <div class="bg-photo"></div>
    <div class="bg-overlay"></div>
    <div class="content" style="padding:0;">
      <div class="gameHeader">
        <button class="backBtn" data-back>← 戻る</button>
        <div class="gameTitle">📰 ニュース</div>
        <button class="iconBtn" id="newsRefresh">更新</button>
      </div>
      <div class="listWrap" id="newsList"></div>
    </div>
    <div class="tabbar">
      <button data-tab="menu"><span class="ic">🏠</span>ホーム</button>
      <button class="active" data-tab="news"><span class="ic">📰</span>ニュース</button>
      <button data-tab="rank"><span class="ic">🏆</span>ランキング</button>
      <button data-tab="chat"><span class="ic">💬</span>チャット</button>
    </div>
  </div>

  <!-- ====== ランキング ====== -->
  <div class="screen" id="screen-rank">
    <div class="bg-photo"></div>
    <div class="bg-overlay"></div>
    <div class="content" style="padding:0;">
      <div class="gameHeader">
        <button class="backBtn" data-back>← 戻る</button>
        <div class="gameTitle">🏆 ランキング</div>
        <select id="rankSelect" style="background:#222;color:#fff;border:1px solid #555;border-radius:6px;padding:4px;font-size:12px;">
          <option value="judo">ガリガリ柔道</option>
          <option value="buster">極太バスター</option>
        </select>
      </div>
      <div class="listWrap" id="rankList"></div>
    </div>
    <div class="tabbar">
      <button data-tab="menu"><span class="ic">🏠</span>ホーム</button>
      <button data-tab="news"><span class="ic">📰</span>ニュース</button>
      <button class="active" data-tab="rank"><span class="ic">🏆</span>ランキング</button>
      <button data-tab="chat"><span class="ic">💬</span>チャット</button>
    </div>
  </div>

  <!-- ====== チャット ====== -->
  <div class="screen" id="screen-chat">
    <div class="bg-photo"></div>
    <div class="bg-overlay"></div>
    <div class="content" style="padding:0;">
      <div class="gameHeader">
        <button class="backBtn" data-back>← 戻る</button>
        <div class="gameTitle">💬 みんなのチャット</div>
        <div class="gameInfo" id="chatPeers">0人</div>
      </div>
      <div class="chatWrap">
        <div class="chatList" id="chatList"></div>
        <div class="chatInput">
          <input id="chatText" type="text" placeholder="メッセージを入力..." maxlength="120">
          <button id="chatSend">送信</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ====== ガリガリ柔道 ====== -->
  <div class="screen" id="screen-judo">
    <div class="gameWrap">
      <div class="gameHeader">
        <button class="backBtn" data-back>← 戻る</button>
        <div class="gameTitle">🥋 ガリガリ柔道</div>
        <div class="gameInfo" id="judoInfo">対戦相手:CPU</div>
      </div>
      <div class="scoreBar">
        <div>あなた: HP<span id="judoHpMe">100</span> 一本<span id="judoIppon">0</span>/3</div>
        <div>得点: <span id="judoScore">0</span></div>
        <div>相手: HP<span id="judoHpEn">100</span> 一本<span id="judoEnIppon">0</span>/3</div>
      </div>
      <div id="judoPinStatus" style="display:none;padding:6px 10px;text-align:center;color:#ffd76b;font-size:13px;font-weight:bold;background:rgba(0,0,0,0.35);border-bottom:1px solid rgba(255,215,107,0.35);">
        🔥 固め技！ 残り <span id="pinTimer">10.0</span>秒 / ボタン制限 <span id="pinBtnTimer">-</span>秒
      </div>
      <div id="judoGripStatus" style="display:none;padding:6px 10px;text-align:center;color:#ff9595;font-size:13px;font-weight:bold;background:rgba(60,0,0,0.45);border-bottom:1px solid rgba(255,120,120,0.45);">
        ⚠️ <span id="gripStatusLabel">掴まれた！</span> 残り <span id="gripTimer">5.0</span>秒 — <b id="gripStatusHelp">ガード連打で脱出</b> 脱出ゲージ <span id="gripStruggle">0</span>%
      </div>
      <div id="judoStage" style="position:relative;flex:1;overflow:hidden;background:#0a0d18;">
        <div id="judoThree" style="position:absolute;inset:0;"></div>
        <div id="judoOverlay" style="position:absolute;inset:0;pointer-events:none;">
          <div id="judoHudNote" style="position:absolute;top:10px;left:10px;z-index:4;padding:8px 12px;background:rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.15);border-radius:12px;font-size:12px;color:#fff;backdrop-filter:blur(4px);">左:移動 / 右:タックル・投げ(→固め技)・ガード　一本3本で勝利</div>
          <div id="judoCtrl" style="position:absolute;left:0;right:0;bottom:0;height:38%;display:flex;justify-content:space-between;align-items:flex-end;padding:12px;gap:12px;pointer-events:none;">
            <div id="stickZone" style="width:min(42vw,200px);height:min(42vw,200px);position:relative;pointer-events:auto;touch-action:none;z-index:3;">
              <div id="stickBase" style="position:absolute;left:50%;top:50%;width:138px;height:138px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(circle at 35% 35%, rgba(255,255,255,0.18), rgba(0,0,0,0.35));border:2px solid rgba(255,255,255,0.18);box-shadow:inset 0 0 24px rgba(0,0,0,0.25),0 0 20px rgba(0,0,0,0.22);"></div>
              <div id="stickKnob" style="position:absolute;left:50%;top:50%;width:66px;height:66px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(circle at 35% 35%, rgba(255,255,255,0.95), rgba(108,180,255,0.9));box-shadow:0 8px 24px rgba(0,0,0,0.35);border:2px solid rgba(255,255,255,0.65);"></div>
            </div>
            <div id="actionPad" style="width:min(52vw,280px);display:flex;flex-direction:column;gap:10px;pointer-events:auto;position:relative;z-index:3;">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div class="judoBtn" id="btnGuard" style="display:flex;align-items:center;justify-content:center;background:rgba(72,175,120,0.22);border:2px solid rgba(72,175,120,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#d8ffe8;font-size:18px;">ガード</div>
                <div class="judoBtn" id="btnTackle" style="display:flex;align-items:center;justify-content:center;background:rgba(120,190,255,0.22);border:2px solid rgba(120,190,255,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#d9eeff;font-size:18px;">タックル</div>
                <div class="judoBtn" id="btnThrow" style="grid-column:span 2;display:flex;align-items:center;justify-content:center;background:rgba(255,140,120,0.22);border:2px solid rgba(255,140,120,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#ffe0d8;font-size:18px;">投げ → 固め技</div>
                <div class="judoBtn" id="btnPin" style="display:none;"></div>
              </div>
            </div>
          </div>
          <div id="judoCenterMsg" style="position:absolute;top:34%;left:0;right:0;text-align:center;font-size:28px;font-weight:bold;color:#fff;text-shadow:0 2px 8px #000;pointer-events:none;display:none;"></div>
          <div id="judoPinLayer" style="position:absolute;inset:0;display:none;pointer-events:none;z-index:5;"></div>
          <div id="judoGripLayer" style="position:absolute;inset:0;display:none;pointer-events:auto;z-index:2;background:radial-gradient(circle at 50% 50%, rgba(255,80,80,0.18), rgba(0,0,0,0.55));">
            <div style="position:absolute;left:50%;top:32%;transform:translate(-50%,-50%);text-align:center;color:#fff;text-shadow:0 2px 8px #000;">
              <div style="font-size:32px;font-weight:bold;color:#ff8888;" id="gripTitle">⚠️ 掴まれた！</div>
              <div style="font-size:18px;margin-top:6px;" id="gripHelp">画面タップまたはガードボタンを連打で脱出！</div>
              <div style="font-size:60px;font-weight:bold;color:#ffd76b;margin-top:10px;" id="gripBigTimer">5.0</div>
              <div style="width:260px;height:22px;background:rgba(0,0,0,0.55);border:2px solid #fff;border-radius:12px;margin:8px auto 0;overflow:hidden;">
                <div id="gripStruggleBar" style="height:100%;width:0%;background:linear-gradient(90deg,#ff8c8c,#ffd76b,#8cffb0);transition:width 0.08s linear;"></div>
              </div>
              <div style="font-size:12px;margin-top:8px;opacity:0.95;" id="gripGoalText">ゲージを100%にすると脱出</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ====== ガリガリ殴り合い ====== -->
  <div class="screen" id="screen-boxing">
    <div class="gameWrap">
      <div class="gameHeader">
        <button class="backBtn" data-back>← 戻る</button>
        <div class="gameTitle">🥊 ガリガリ殴り合い</div>
        <div class="gameInfo" id="boxingInfo">対戦相手:CPU</div>
      </div>
      <div class="scoreBar">
        <div>あなた: HP<span id="boxingHpMe">100</span></div>
        <div>得点: <span id="boxingScore">0</span></div>
        <div>相手: HP<span id="boxingHpEn">100</span></div>
      </div>
      <div id="boxingReviveStatus" style="display:none;padding:6px 10px;text-align:center;color:#ff8c8c;font-size:13px;font-weight:bold;background:rgba(60,0,0,0.55);border-bottom:1px solid rgba(255,80,80,0.55);">
        💔 復活挑戦！ 残り <span id="reviveTimer">10.0</span>秒 ・ ボタン <span id="reviveProg">0</span>/<span id="reviveNeed">6</span> 全押しで HP 80 まで回復
      </div>
      <div id="boxingStage" style="position:relative;flex:1;overflow:hidden;background:#0a0d18;">
        <div id="boxingThree" style="position:absolute;inset:0;"></div>
        <div id="boxingOverlay" style="position:absolute;inset:0;pointer-events:none;">
          <div class="floatBars" id="boxingFloatBars">
            <!-- 頭の横に表示する丸型HPインジケータ -->
            <div class="charHpRing" id="boxingRingMe">
              <svg viewBox="0 0 44 44">
                <circle class="bg" cx="22" cy="22" r="18"></circle>
                <circle class="arc" id="boxingRingMeArc" cx="22" cy="22" r="18" stroke-dasharray="113.1 113.1" stroke-dashoffset="0"></circle>
                <text class="lbl" id="boxingRingMeTxt" x="22" y="23">100</text>
              </svg>
            </div>
            <div class="charHpRing enemy" id="boxingRingEn">
              <svg viewBox="0 0 44 44">
                <circle class="bg" cx="22" cy="22" r="18"></circle>
                <circle class="arc" id="boxingRingEnArc" cx="22" cy="22" r="18" stroke-dasharray="113.1 113.1" stroke-dashoffset="0"></circle>
                <text class="lbl" id="boxingRingEnTxt" x="22" y="23">100</text>
              </svg>
            </div>
          </div>
          <div id="boxingHudNote" style="position:absolute;top:10px;left:10px;z-index:4;padding:8px 12px;background:rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.15);border-radius:12px;font-size:12px;color:#fff;backdrop-filter:blur(4px);">左で移動 / 右でパンチ・キック・タックル・ガード・回避　路地裏で殴り合え</div>
          <!-- ガード耐久UI: モデル横に丸で表示 -->
          <div id="boxingShieldRing" style="position:absolute;display:none;width:54px;height:54px;pointer-events:none;z-index:5;">
            <svg viewBox="0 0 54 54" width="54" height="54" style="display:block;">
              <circle cx="27" cy="27" r="22" fill="rgba(0,0,0,0.55)" stroke="rgba(255,255,255,0.18)" stroke-width="2"></circle>
              <circle id="boxingShieldArc" cx="27" cy="27" r="22" fill="none" stroke="#6fe39a" stroke-width="4" stroke-linecap="round" stroke-dasharray="138.23 138.23" stroke-dashoffset="0" transform="rotate(-90 27 27)"></circle>
              <text id="boxingShieldTxt" x="27" y="31" text-anchor="middle" fill="#d8ffe8" font-size="14" font-weight="bold" font-family="Hiragino Sans, sans-serif">30</text>
            </svg>
          </div>
          <div id="boxingCtrl" style="position:absolute;left:0;right:0;bottom:0;height:44%;display:flex;justify-content:space-between;align-items:flex-end;padding:12px;gap:12px;pointer-events:none;">
            <div id="boxingStickZone" style="width:min(42vw,200px);height:min(42vw,200px);position:relative;pointer-events:auto;touch-action:none;">
              <div id="boxingStickBase" style="position:absolute;left:50%;top:50%;width:138px;height:138px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(circle at 35% 35%, rgba(255,255,255,0.18), rgba(0,0,0,0.35));border:2px solid rgba(255,255,255,0.18);box-shadow:inset 0 0 24px rgba(0,0,0,0.25),0 0 20px rgba(0,0,0,0.22);"></div>
              <div id="boxingStickKnob" style="position:absolute;left:50%;top:50%;width:66px;height:66px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(circle at 35% 35%, rgba(255,255,255,0.95), rgba(255,180,108,0.9));box-shadow:0 8px 24px rgba(0,0,0,0.35);border:2px solid rgba(255,255,255,0.65);"></div>
            </div>
            <div id="boxingActionPad" style="width:min(48vw,260px);display:flex;flex-direction:column;gap:10px;pointer-events:auto;">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div class="judoBtn" id="bxBtnPunch" style="display:flex;align-items:center;justify-content:center;background:rgba(255,120,120,0.22);border:2px solid rgba(255,120,120,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#ffd3d3;font-size:18px;">パンチ</div>
                <div class="judoBtn" id="bxBtnKick" style="display:flex;align-items:center;justify-content:center;background:rgba(255,180,72,0.22);border:2px solid rgba(255,180,72,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#ffe2a5;font-size:18px;">キック</div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
                <div class="judoBtn" id="bxBtnGuard" style="display:flex;align-items:center;justify-content:center;background:rgba(72,175,120,0.22);border:2px solid rgba(72,175,120,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#d8ffe8;font-size:18px;">ガード</div>
                <div class="judoBtn" id="bxBtnTackle" style="display:flex;align-items:center;justify-content:center;background:rgba(120,190,255,0.22);border:2px solid rgba(120,190,255,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#d9eeff;font-size:18px;">タックル</div>
                <div class="judoBtn" id="bxBtnRoll" style="display:flex;align-items:center;justify-content:center;background:rgba(200,120,255,0.22);border:2px solid rgba(200,120,255,0.45);min-height:58px;border-radius:14px;font-weight:bold;color:#f2dbff;font-size:18px;">回避</div>
              </div>
            </div>
          </div>
          <div id="boxingCenterMsg" style="position:absolute;top:34%;left:0;right:0;text-align:center;font-size:28px;font-weight:bold;color:#fff;text-shadow:0 2px 8px #000;pointer-events:none;display:none;"></div>
          <!-- 復活チャレンジレイヤー (HP0時に出る) -->
          <div id="boxingReviveLayer" style="position:absolute;inset:0;display:none;pointer-events:auto;z-index:6;background:radial-gradient(circle at 50% 40%, rgba(255,30,30,0.22), rgba(0,0,0,0.65));">
            <div style="position:absolute;left:50%;top:14%;transform:translate(-50%,0);text-align:center;color:#fff;text-shadow:0 2px 8px #000;pointer-events:none;">
              <div style="font-size:30px;font-weight:bold;color:#ff8c8c;">💔 掴み技で復活を狙え！</div>
              <div style="font-size:14px;margin-top:4px;color:#ffd76b;">ボタンを<b>すべて</b>叩いたら復活！ ボットの妓邪に注意</div>
              <div style="display:flex;justify-content:center;gap:24px;margin-top:8px;font-size:16px;font-weight:bold;">
                <div>⏱ <span id="reviveBigTimer" style="color:#ffd76b;">10.0</span>秒</div>
                <div>✅ <span id="reviveBigProg" style="color:#8cffb0;">0</span> / <span id="reviveBigNeed">6</span></div>
              </div>
            </div>
            <div id="boxingReviveBtnArea" style="position:absolute;inset:0;"></div>
            <div id="boxingReviveSabotage" style="position:absolute;left:50%;top:48%;transform:translate(-50%,-50%);display:none;font-size:22px;font-weight:bold;color:#ffd76b;text-shadow:0 0 12px #f00, 0 2px 6px #000;text-align:center;pointer-events:none;"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

