<!-- プロフィール編集モーダル -->
<div class="modal" id="profileModal">
  <div class="modalBox">
    <h2>👤 プロフィール編集</h2>
    <div class="iconPreview" id="iconPreview">G</div>
    <label class="uploadBtn" for="iconUpload">📷 アイコン画像をアップロード(PNG)</label>
    <input type="file" id="iconUpload" accept="image/png,image/jpeg" style="display:none;">
    <button id="iconReset" style="width:100%;margin-top:6px;background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.2);padding:6px;border-radius:6px;font-size:12px;cursor:pointer;">デフォルトに戻す</button>
    <label>名前 (12文字以内)</label>
    <input type="text" id="nameInput" maxlength="12" placeholder="例: ガリガリ太郎">
    <div class="modalActions">
      <button class="btnSecondary" id="profileCancel">キャンセル</button>
      <button class="btnPrimary" id="profileSave">保存</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- PeerJS (WebRTC) -->
<script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
<!-- Firebase (任意) -->
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>

<script>
/* ============================================================
   ガリガリ柔道 - メインスクリプト
   ============================================================ */

/* ===== Firebase 設定 =====
 * 自分のFirebase Realtime Databaseを使う場合、下の FIREBASE_CONFIG に
 * Firebaseコンソールから取得した設定を貼り付けてください。
 * 未設定の場合は localStorage のみで動作します(ランキング/ニュース/チャットはローカル限定)。
 * ============================================================ */
const FIREBASE_CONFIG = {
  // apiKey: "...",
  // authDomain: "...",
  // databaseURL: "https://xxxx-default-rtdb.firebaseio.com",
  // projectId: "...",
  // storageBucket: "...",
  // messagingSenderId: "...",
  // appId: "..."
};

let fbDb = null;
try {
  if (FIREBASE_CONFIG.databaseURL) {
    firebase.initializeApp(FIREBASE_CONFIG);
    fbDb = firebase.database();
    console.log('[Firebase] initialized');
  }
} catch(e) { console.warn('[Firebase] init failed', e); }

/* ===== ユーティリティ ===== */
const $ = s => document.querySelector(s);
const $$ = s => document.querySelectorAll(s);
function showToast(msg, ms=1800) {
  const t = $('#toast'); t.textContent = msg; t.classList.add('show');
  clearTimeout(showToast._t); showToast._t = setTimeout(()=>t.classList.remove('show'), ms);
}
function todayKey(){ const d=new Date(); return d.getFullYear()+'-'+(d.getMonth()+1).toString().padStart(2,'0')+'-'+d.getDate().toString().padStart(2,'0'); }
function randID(n=6){ const s='ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; let r=''; for(let i=0;i<n;i++) r+=s[Math.floor(Math.random()*s.length)]; return r; }

/* ===== ユーザープロフィール ===== */
const UserStore = {
  load() {
    let p = JSON.parse(localStorage.getItem('garigari_user') || 'null');
    if (!p) {
      p = { id: randID(8), name: 'ゲスト'+randID(3), icon: null };
      this.save(p);
    }
    return p;
  },
  save(p) { localStorage.setItem('garigari_user', JSON.stringify(p)); }
};
let user = UserStore.load();

function renderTopBar() {
  $('#topName').textContent = user.name;
  $('#topSub').textContent = 'ID: ' + user.id;
  const ic = $('#topIcon');
  if (user.icon) { ic.innerHTML = '<img src="'+user.icon+'">'; }
  else { ic.innerHTML = ''; ic.textContent = user.name.charAt(0).toUpperCase(); }
}
renderTopBar();

/* ===== 画面切替 ===== */
function go(name) {
  $$('.screen').forEach(s=>s.classList.remove('active'));
  const el = document.getElementById('screen-'+name);
  if (el) el.classList.add('active');
  // 他モードの3Dシーンを明示的に破棄 (WebGLコンテキストリーク防止)
  if (name !== 'judo'   && typeof _disposeJudo   === 'function' && Judo.renderer)   _disposeJudo();
  if (name !== 'boxing' && typeof _disposeBoxing === 'function' && Boxing.renderer) _disposeBoxing();
  if (name !== 'live'   && typeof _disposeLive   === 'function' && typeof Live!=='undefined' && Live.renderer)   _disposeLive();
  if (name==='news') renderNews();
  if (name==='rank') renderRank();
  if (name==='chat') renderChat();
  if (name==='judo') startJudo();
  if (name==='boxing') startBoxing();
  if (name==='omikuji') renderOmikuji();
  if (name==='buster') startBuster();
  if (name==='live') startLive();
}

document.addEventListener('click', e => {
  const tab = e.target.closest('[data-tab]');
  if (tab) { go(tab.dataset.tab); return; }
  const goBtn = e.target.closest('[data-go]');
  if (goBtn) { go(goBtn.dataset.go); return; }
  const back = e.target.closest('[data-back]');
  if (back) { go('menu'); return; }
});

/* ===== プロフィール編集 ===== */
$('#btnProfile').addEventListener('click', ()=> openProfile());
function openProfile() {
  $('#nameInput').value = user.name;
  const ip = $('#iconPreview');
  if (user.icon) ip.innerHTML = '<img src="'+user.icon+'">';
  else { ip.innerHTML=''; ip.textContent = user.name.charAt(0).toUpperCase(); }
  $('#profileModal').classList.add('active');
}
$('#profileCancel').addEventListener('click', ()=> $('#profileModal').classList.remove('active'));
$('#profileSave').addEventListener('click', ()=>{
  const nm = $('#nameInput').value.trim();
  if (!nm) { showToast('名前を入力してください'); return; }
  user.name = nm;
  const ipImg = $('#iconPreview img');
  user.icon = ipImg ? ipImg.src : null;
  UserStore.save(user);
  renderTopBar();
  $('#profileModal').classList.remove('active');
  showToast('保存しました');
  // P2P側にも通知
  P2P.broadcastProfile();
});
$('#iconUpload').addEventListener('change', e=>{
  const f = e.target.files[0]; if (!f) return;
  // PNGに統一 + 縮小
  const img = new Image();
  const reader = new FileReader();
  reader.onload = ev => { img.src = ev.target.result; };
  img.onload = ()=>{
    const c = document.createElement('canvas');
    const size = 128;
    c.width = size; c.height = size;
    const ctx = c.getContext('2d');
    // センタークロップ
    const sc = Math.min(img.width, img.height);
    const sx = (img.width-sc)/2, sy = (img.height-sc)/2;
    ctx.drawImage(img, sx, sy, sc, sc, 0, 0, size, size);
    const dataUrl = c.toDataURL('image/png');
    $('#iconPreview').innerHTML = '<img src="'+dataUrl+'">';
  };
  reader.readAsDataURL(f);
});
$('#iconReset').addEventListener('click', ()=>{
  const ip = $('#iconPreview');
  ip.innerHTML=''; ip.textContent = ($('#nameInput').value||'G').charAt(0).toUpperCase();
});

/* ============================================================
   P2P (PeerJS) — ロビー方式の自動接続
   仕組み: 既知のロビーIDリストへ順に接続を試行。誰もいなければ
   自分が代表ノードとして待機。接続できたノードを介して全員と
   フルメッシュ的に接続を広げる。
   ============================================================ */
const P2P = {
  peer: null,
  myId: null,
  conns: new Map(), // peerId -> conn
  profiles: new Map(), // peerId -> {name, icon}
  LOBBY_PREFIX: 'garigari-judo-lobby-',
  LOBBY_SLOTS: 12, // 同時ロビー枠

  init() {
    // 既存のロビーIDに参加トライ
    this.tryJoinLobby();
  },

  setStatus(connected, count) {
    $('#p2pDot').classList.toggle('on', connected);
    $('#p2pText').textContent = connected ? 'P2P接続中' : 'P2P接続待機';
    $('#p2pCount').textContent = (count||this.conns.size)+'人';
    $('#chatPeers').textContent = (this.conns.size+1)+'人';
  },

  tryJoinLobby(attempt=0) {
    if (attempt >= this.LOBBY_SLOTS) {
      // 全部空いていなかった→自分が空きスロットを取りに行く
      this.becomeHost();
      return;
    }
    const lobbyId = this.LOBBY_PREFIX + attempt;
    const tmpId = this.LOBBY_PREFIX + 'c-' + randID(8);
    try {
      const peer = new Peer(tmpId, { debug: 0 });
      let resolved = false;
      peer.on('open', () => {
        // ロビーホストへ接続トライ
        const conn = peer.connect(lobbyId, { reliable: true, metadata: { profile: { name: user.name, icon: user.icon, uid: user.id } } });
        let connected = false;
        conn.on('open', () => {
          connected = true; resolved = true;
          this.peer = peer; this.myId = tmpId;
          this.attachPeerHandlers();
          this.attachConn(conn);
          this.setStatus(true);
          showToast('P2P接続: ロビー'+attempt+'に参加');
          // ロビーホストからピア一覧を受け取って広げる
        });
        conn.on('error', () => {});
        setTimeout(() => {
          if (!connected && !resolved) {
            try { peer.destroy(); } catch(e){}
            this.tryJoinLobby(attempt+1);
          }
        }, 2500);
      });
      peer.on('error', err => {
        if (!resolved) {
          try { peer.destroy(); } catch(e){}
          this.tryJoinLobby(attempt+1);
        }
      });
    } catch(e) {
      this.tryJoinLobby(attempt+1);
    }
  },

  becomeHost(slot=0) {
    if (slot >= this.LOBBY_SLOTS) {
      console.warn('[P2P] 全ロビースロット占有失敗');
      this.setStatus(false);
      return;
    }
    const lobbyId = this.LOBBY_PREFIX + slot;
    try {
      const peer = new Peer(lobbyId, { debug: 0 });
      peer.on('open', () => {
        this.peer = peer; this.myId = lobbyId;
        this.attachPeerHandlers();
        this.setStatus(false, 0);
        showToast('ロビー'+slot+'のホストとして待機');
      });
      peer.on('error', err => {
        if (err && (err.type === 'unavailable-id' || (''+err).indexOf('unavailable') >= 0)) {
          try { peer.destroy(); } catch(e){}
          this.becomeHost(slot+1);
        }
      });
    } catch(e) {
      this.becomeHost(slot+1);
    }
  },

  attachPeerHandlers() {
    this.peer.on('connection', conn => {
      conn.on('open', () => {
        this.attachConn(conn);
        // 既存ピア一覧を送って自動接続を広げる
        const peerList = Array.from(this.conns.keys()).filter(id=>id!==conn.peer);
        try { conn.send({ type:'peers', list: peerList }); } catch(e){}
        try { conn.send({ type:'profile', uid: user.id, name: user.name, icon: user.icon }); } catch(e){}
      });
    });
    this.peer.on('disconnected', ()=> { this.setStatus(false); try { this.peer.reconnect(); } catch(e){} });
  },

  attachConn(conn) {
    if (this.conns.has(conn.peer)) return;
    this.conns.set(conn.peer, conn);
    if (conn.metadata && conn.metadata.profile) {
      this.profiles.set(conn.peer, conn.metadata.profile);
    }
    this.setStatus(this.conns.size>0);
    conn.on('data', d => this.onData(conn, d));
    conn.on('close', () => {
      this.conns.delete(conn.peer);
      this.profiles.delete(conn.peer);
      this.setStatus(this.conns.size>0);
    });
    // 自分のプロフィールを送る
    try { conn.send({ type:'profile', uid: user.id, name: user.name, icon: user.icon }); } catch(e){}
  },

  connectTo(peerId) {
    if (!this.peer || this.conns.has(peerId) || peerId === this.myId) return;
    try {
      const conn = this.peer.connect(peerId, { reliable: true, metadata: { profile: { name: user.name, icon: user.icon, uid: user.id } } });
      conn.on('open', () => this.attachConn(conn));
    } catch(e){}
  },

  onData(conn, d) {
    if (!d || !d.type) return;
    switch(d.type) {
      case 'peers':
        (d.list||[]).forEach(pid => this.connectTo(pid));
        break;
      case 'profile':
        this.profiles.set(conn.peer, { name: d.name, icon: d.icon, uid: d.uid });
        break;
      case 'chat':
        Chat.recv({ from: d.uid||conn.peer, name: d.name, icon: d.icon, text: d.text, ts: d.ts });
        break;
      case 'rank':
        Rank.recvRemote(d.game, d.entry);
        break;
      case 'live':
        if (typeof Live !== 'undefined' && Live.onNet) Live.onNet(conn.peer, d);
        break;
    }
  },

  broadcast(obj) {
    this.conns.forEach(c => { try { c.send(obj); } catch(e){} });
  },
  broadcastProfile() {
    this.broadcast({ type:'profile', uid:user.id, name:user.name, icon:user.icon });
  }
};
P2P.init();

/* ============================================================
   ニュース
   ============================================================ */
const DEFAULT_NEWS = [
  { ttl: '🥋 ガリガリ柔道リリース!', meta: 'お知らせ', body: 'ガリガリ柔道がついに公開されました。本編、ガリみくじ、極太バスターの3つが遊べます。' },
  { ttl: '🎴 ガリみくじについて', meta: 'システム', body: '1日1回引けるおみくじです。日付が変わると再度引けるようになります。' },
  { ttl: '👊 極太バスターのコツ', meta: '攻略', body: '画面に出てくる巨漢を素早くタップ! コンボを繋げてハイスコアを狙え。' },
  { ttl: '🌐 P2P自動接続稼働中', meta: 'システム', body: '同じゲームを開いている人と自動でつながります。チャットやランキングがリアルタイムに更新されます。' },
];
function renderNews() {
  const list = $('#newsList'); list.innerHTML = '';
  const render = (items) => {
    items.forEach(n => {
      const c = document.createElement('div');
      c.className = 'card';
      c.innerHTML = '<div class="ttl">'+escapeHtml(n.ttl)+'</div><div class="meta">'+escapeHtml(n.meta||'')+'</div><div class="body">'+escapeHtml(n.body)+'</div>';
      list.appendChild(c);
    });
  };
  if (fbDb) {
    fbDb.ref('news').limitToLast(20).once('value').then(snap => {
      const arr = []; snap.forEach(ch => arr.push(ch.val()));
      arr.reverse();
      render(arr.length ? arr : DEFAULT_NEWS);
    }).catch(()=>render(DEFAULT_NEWS));
  } else {
    render(DEFAULT_NEWS);
  }
}
$('#newsRefresh').addEventListener('click', ()=>{ renderNews(); showToast('更新しました'); });

function escapeHtml(s){ return (''+s).replace(/[&<>"']/g, m=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[m]); }

/* ============================================================
   ランキング
   ============================================================ */
const Rank = {
  local: { judo: [], buster: [] },
  load() {
    try { this.local = JSON.parse(localStorage.getItem('garigari_rank')||'null') || { judo: [], buster: [] }; } catch(e){ this.local = { judo: [], buster: [] }; }
  },
  save() { localStorage.setItem('garigari_rank', JSON.stringify(this.local)); },
  submit(game, score) {
    const entry = { uid: user.id, name: user.name, icon: user.icon, score: score, ts: Date.now() };
    this.local[game] = this.local[game] || [];
    this.local[game].push(entry);
    this.local[game].sort((a,b)=>b.score-a.score);
    this.local[game] = this.local[game].slice(0, 50);
    this.save();
    if (fbDb) { try { fbDb.ref('rank/'+game).push(entry); } catch(e){} }
    P2P.broadcast({ type:'rank', game, entry });
  },
  recvRemote(game, entry) {
    if (!entry || typeof entry.score !== 'number') return;
    this.local[game] = this.local[game] || [];
    // 同じユーザの上位だけ保持
    this.local[game].push(entry);
    this.local[game].sort((a,b)=>b.score-a.score);
    this.local[game] = this.local[game].slice(0, 50);
    this.save();
    if ($('#screen-rank').classList.contains('active')) renderRank();
  }
};
Rank.load();

function renderRank() {
  const game = $('#rankSelect').value;
  const list = $('#rankList'); list.innerHTML = '';
  const draw = (arr) => {
    if (!arr.length) { list.innerHTML = '<div class="card"><div class="body">まだスコアがありません</div></div>'; return; }
    arr.slice(0,30).forEach((e,i)=>{
      const row = document.createElement('div'); row.className = 'rankRow';
      const rkCls = i===0?'gold':i===1?'silver':i===2?'bronze':'';
      const icHtml = e.icon ? '<img src="'+e.icon+'">' : escapeHtml((e.name||'?').charAt(0).toUpperCase());
      row.innerHTML = '<div class="rk '+rkCls+'">'+(i+1)+'</div>'
        + '<div class="ic">'+icHtml+'</div>'
        + '<div class="nm">'+escapeHtml(e.name||'名無し')+'</div>'
        + '<div class="sc">'+e.score+'</div>';
      list.appendChild(row);
    });
  };
  if (fbDb) {
    fbDb.ref('rank/'+game).limitToLast(100).once('value').then(snap=>{
      const arr = []; snap.forEach(ch=>arr.push(ch.val()));
      arr.sort((a,b)=>b.score-a.score);
      // ローカルもマージ
      const merged = [...arr, ...(Rank.local[game]||[])];
      const seen = new Set(); const uniq=[];
      for (const e of merged) {
        const k = (e.uid||e.name)+'_'+e.score+'_'+(e.ts||0);
        if (!seen.has(k)) { seen.add(k); uniq.push(e); }
      }
      uniq.sort((a,b)=>b.score-a.score);
      draw(uniq);
    }).catch(()=>draw(Rank.local[game]||[]));
  } else {
    draw(Rank.local[game]||[]);
  }
}
$('#rankSelect').addEventListener('change', renderRank);

/* ============================================================
   チャット
   ============================================================ */
const Chat = {
  msgs: [],
  MAX: 60,
  load() {
    try { this.msgs = JSON.parse(localStorage.getItem('garigari_chat')||'[]'); } catch(e){ this.msgs=[]; }
  },
  save() { localStorage.setItem('garigari_chat', JSON.stringify(this.msgs.slice(-this.MAX))); },
  push(m) {
    this.msgs.push(m); if (this.msgs.length>this.MAX) this.msgs.shift();
    this.save();
    if ($('#screen-chat').classList.contains('active')) renderChat();
  },
  recv(m) {
    this.push({ ...m, mine:false });
    if (fbDb) { /* Firebaseは別購読で更新 */ }
  },
  send(text) {
    const m = { from:user.id, name:user.name, icon:user.icon, text, ts:Date.now(), mine:true };
    this.push(m);
    P2P.broadcast({ type:'chat', uid:user.id, name:user.name, icon:user.icon, text, ts:m.ts });
    if (fbDb) { try { fbDb.ref('chat').push({ uid:user.id, name:user.name, icon:user.icon, text, ts:m.ts }); } catch(e){} }
  }
};
Chat.load();

let chatFbListener = null;
function renderChat() {
  const list = $('#chatList'); list.innerHTML='';
  this_render(Chat.msgs);
  function this_render(arr) {
    arr.slice(-Chat.MAX).forEach(m=>{
      const d = document.createElement('div');
      d.className = 'chatMsg' + (m.mine||m.from===user.id?' me':'');
      const icHtml = m.icon ? '<img src="'+m.icon+'">' : escapeHtml((m.name||'?').charAt(0).toUpperCase());
      d.innerHTML = '<div class="ic">'+icHtml+'</div>'
        + '<div><div class="nm">'+escapeHtml(m.name||'匿名')+'</div><div class="bubble">'+escapeHtml(m.text)+'</div></div>';
      list.appendChild(d);
    });
    list.scrollTop = list.scrollHeight;
  }
  // Firebase購読(初回のみ)
  if (fbDb && !chatFbListener) {
    chatFbListener = fbDb.ref('chat').limitToLast(50);
    chatFbListener.on('child_added', snap => {
      const m = snap.val(); if (!m || m.uid===user.id) return;
      if (Chat.msgs.find(x=>x.ts===m.ts && x.from===m.uid)) return;
      Chat.msgs.push({ from:m.uid, name:m.name, icon:m.icon, text:m.text, ts:m.ts });
      if ($('#screen-chat').classList.contains('active')) renderChat();
    });
  }
}
$('#chatSend').addEventListener('click', ()=>{
  const v = $('#chatText').value.trim(); if (!v) return;
  Chat.send(v); $('#chatText').value='';
});
$('#chatText').addEventListener('keydown', e=>{ if (e.key==='Enter') $('#chatSend').click(); });

/* ============================================================
   🎴 ガリみくじ
   ============================================================ */
const FORTUNES = [
  { f:'大吉', m:'今日は何をやっても勝てる!ガリガリパワー全開!' },
  { f:'中吉', m:'良い1日になりそう。柔道で1勝できるかも。' },
  { f:'小吉', m:'まあまあの日。極太バスターでコンボを狙え。' },
  { f:'吉',   m:'平穏な1日。チャットで誰かと話してみよう。' },
  { f:'末吉', m:'伸び代しかない日。練習あるのみ。' },
  { f:'凶',   m:'今日はおとなしくしておこう…でも明日はきっと大吉!' },
  { f:'大凶', m:'まさかの大凶。デブに気をつけろ。' },
  { f:'超大吉',m:'伝説の日!ランキング1位を狙える運勢!' },
];
function renderOmikuji() {
  const last = localStorage.getItem('garigari_omikuji_'+todayKey());
  const btn = $('#omikujiBtn');
  if (last) {
    const r = JSON.parse(last);
    $('#omikujiFortune').textContent = r.f;
    $('#omikujiMsg').textContent = r.m;
    $('#omikujiDate').textContent = todayKey() + ' (本日分は引きました)';
    btn.disabled = true; btn.textContent = '本日は引きました';
  } else {
    $('#omikujiFortune').textContent = '???';
    $('#omikujiMsg').textContent = '下のボタンを押してみくじを引きましょう';
    $('#omikujiDate').textContent = todayKey();
    btn.disabled = false; btn.textContent = 'みくじを引く';
  }
}
$('#omikujiBtn').addEventListener('click', ()=>{
  const r = FORTUNES[Math.floor(Math.random()*FORTUNES.length)];
  localStorage.setItem('garigari_omikuji_'+todayKey(), JSON.stringify(r));
  $('#omikujiFortune').textContent = r.f;
  $('#omikujiMsg').textContent = r.m;
  $('#omikujiDate').textContent = todayKey();
  $('#omikujiBtn').disabled = true;
  $('#omikujiBtn').textContent = '本日は引きました';
  // 演出
  const card = $('#omikujiCard');
  card.animate(
    [{ transform:'rotate(0deg) scale(1)' },{ transform:'rotate(2deg) scale(1.05)' },{ transform:'rotate(0deg) scale(1)' }],
    { duration: 600 }
  );
});

/* ============================================================
   🥊 ガリガリ柔道 本編
   ・仮想ジョイスティックで移動
   ・視点は常時ロックオンで敵方向を向く
   ・タックル / ガード のみ（パンチ・キック・回避はボクシングモードへ移植済み）
   ============================================================ */
const Judo = {
  THREE: null,
  container: null,
  renderer: null, scene: null, camera: null,
  me: null, en: null,
  mePose: 'idle', enPose: 'idle',
  meHP: 100, enHP: 100,
  score: 0,
  ippon: 0,
  enIppon: 0, // 相手の一本数 (3本で負け)
  running: false, raf: 0,
  lastT: 0,
  attackCD: 0, enemyAtkCD: 55,
  mode: 'fight', // 'fight' | 'pin' | 'gripped' | 'enemyPin' | 'result'
  meAnim: 0, enAnim: 0,
  shakeT: 0,
  arenaRadius: 4.2,
  moveSpeed: 4.2,
  enemySpeed: 2.75,
  meAction: null,
  enAction: null,
  meGuard: false,
  meInvuln: 0,
  meRollT: 0,
  meStunT: 0, // 転んだ状態の残り秒数 (動けない)
  enStunT: 0, // 敵が転んだ状態の残り秒数
  meRollDir: { x: 0, z: 1 },
  input: { x: 0, y: 0, lastX: 0, lastY: -1, pointerId: null },
  pin: null, // v2 スタイルの固め技モード状態
  grip: null, // 敵に掴まれた状態 ({ remain, struggle, ... })
  enemyPin: null, // 敵の固め技を受けている状態
  // 賢い敵AI 用ステート
  enGuard: false, enGuardT: 0, enGuardCD: 0,
  enStrafeDir: 1, enStrafeT: 0,
  enThinkT: 0,
  enFeintT: 0,
  enemyThrowBias: 1.0,
};

const JUDO_ATTACKS = {
  tackle: { label:'タックル', range:1.95, damage:[13, 18], hitAt:0.20, total:0.46, cooldown:30, score:14, color:'#9fd3ff' },
  // 投げ: 距離内で 60% 成功 → 固め技モードへ。失敗は隔で反撃を許す
  throw:  { label:'投げ',     range:1.55, damage:[6, 10],  hitAt:0.22, total:0.58, cooldown:50, score:15, color:'#ffbf9f', launch:0.6, pinTrigger:true, successRate:0.6 },
  // 掴み技 (敵専用): 接近して成功で gripped モード遷移。プレイヤーがガード/回避中は成功率激減。
  grapple:{ label:'掴み',     range:1.45, damage:[3, 5],   hitAt:0.30, total:0.62, cooldown:65, score:0,  color:'#ff9090', successRate:0.7 },
};

function _ensureThree() {
  if (Judo.THREE) return Promise.resolve(Judo.THREE);
  return window.loadThreeWithRetry().then(THREE => { Judo.THREE = THREE; return THREE; });
}

function startJudo() {
  _ensureThree().then(THREE => _initJudo(THREE)).catch(err => {
    console.error(err);
    showToast('Three.js の読み込みに失敗しました');
  });
}

function _initJudo(THREE) {
  _disposeJudo();

  Judo.container = $('#judoThree');
  const w = Judo.container.clientWidth || window.innerWidth;
  const h = Judo.container.clientHeight || 400;

  Judo.scene = new THREE.Scene();
  Judo.scene.background = new THREE.Color(0x09111d);
  Judo.scene.fog = new THREE.Fog(0x09111d, 9, 26);

  Judo.camera = new THREE.PerspectiveCamera(58, w/h, 0.1, 100);
  Judo.camera.position.set(0, 2.4, 4.8);

  const _isMobile = /Mobi|Android/i.test(navigator.userAgent);
  Judo.renderer = new THREE.WebGLRenderer({ antialias: !_isMobile, alpha:false, powerPreference:'high-performance' });
  Judo.renderer.setPixelRatio(Math.min(window.devicePixelRatio, _isMobile ? 1 : 1.5));
  Judo.renderer.setSize(w, h);
  Judo.renderer.shadowMap.enabled = true;
  Judo.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  Judo.container.innerHTML = '';
  Judo.container.appendChild(Judo.renderer.domElement);

  const amb = new THREE.AmbientLight(0xffffff, 0.58);
  Judo.scene.add(amb);
  const dir = new THREE.DirectionalLight(0xffe6b8, 1.25);
  dir.position.set(5, 8, 6);
  dir.castShadow = true;
  dir.shadow.mapSize.set(512, 512);
  dir.shadow.camera.left = -8; dir.shadow.camera.right = 8;
  dir.shadow.camera.top = 8; dir.shadow.camera.bottom = -8;
  dir.shadow.autoUpdate = false;
  dir.shadow.needsUpdate = true;
  Judo.scene.add(dir);
  const rim = new THREE.DirectionalLight(0x7ea6ff, 0.45);
  rim.position.set(-6, 3, -4);
  Judo.scene.add(rim);

  const floor = new THREE.Mesh(
    new THREE.CircleGeometry(7.5, 64),
    new THREE.MeshStandardMaterial({ color: 0x203f33, roughness: 0.94 })
  );
  floor.rotation.x = -Math.PI/2;
  floor.receiveShadow = true;
  Judo.scene.add(floor);

  const ring = new THREE.Mesh(
    new THREE.RingGeometry(4.25, 4.42, 64),
    new THREE.MeshBasicMaterial({ color: 0xffd76b, side: THREE.DoubleSide })
  );
  ring.rotation.x = -Math.PI/2;
  ring.position.y = 0.02;
  Judo.scene.add(ring);

  for (let i=-4; i<=4; i+=2) {
    const g = new THREE.BufferGeometry().setFromPoints([
      new THREE.Vector3(-5.4, 0.01, i), new THREE.Vector3(5.4, 0.01, i)
    ]);
    Judo.scene.add(new THREE.Line(g, new THREE.LineBasicMaterial({ color:0xffffff, transparent:true, opacity:0.15 })));
  }

  const wall = new THREE.Mesh(
    new THREE.PlaneGeometry(30, 12),
    new THREE.MeshStandardMaterial({ color:0x111b30, roughness:1 })
  );
  wall.position.set(0, 6, -9);
  Judo.scene.add(wall);

  Judo.me = _buildJudoka(THREE, 0xf4b448, false);
  Judo.me.position.set(-1.8, 0, 2.4);
  Judo.scene.add(Judo.me);

  Judo.en = _buildJudoka(THREE, 0xcc4444, true);
  Judo.en.position.set(1.8, 0, -1.4);
  Judo.scene.add(Judo.en);

  Judo.meHP = 100; Judo.enHP = 100; Judo.score = 0; Judo.ippon = 0; Judo.enIppon = 0;
  Judo.mePose = 'idle'; Judo.enPose = 'idle';
  Judo.mode = 'fight';
  Judo.meAnim = 0; Judo.enAnim = 0;
  Judo.attackCD = 0; Judo.enemyAtkCD = 45;
  Judo.shakeT = 0;
  Judo.meAction = null; Judo.enAction = null;
  Judo.meGuard = false; Judo.meInvuln = 0; Judo.meRollT = 0;
  Judo.meStunT = 0; Judo.enStunT = 0;
  Judo.meRollDir = { x: 0, z: 1 };
  Judo.input = { x: 0, y: 0, lastX: 0, lastY: -1, pointerId: null };
  Judo.pin = null;
  Judo.grip = null;
  Judo.enemyPin = null;
  _setGripUiMode('grip');
  Judo.enGuard = false; Judo.enGuardT = 0; Judo.enGuardCD = 0;
  Judo.enStrafeDir = Math.random() < 0.5 ? -1 : 1; Judo.enStrafeT = 0;
  Judo.enThinkT = 0; Judo.enFeintT = 0;
  Judo.enemyThrowBias = 1.0;

  $('#judoInfo').textContent = '対戦相手: CPU [投げ強化AI] / ロックオン';
  $('#judoCenterMsg').style.display = 'none';
  $('#judoPinLayer').style.display = 'none';
  const gl0 = $('#judoGripLayer'); if (gl0) gl0.style.display = 'none';
  const gs0 = $('#judoGripStatus'); if (gs0) gs0.style.display = 'none';
  _setGripUiMode('grip');
  updateJudoHUD();
  _bindJudoControls();

  window.addEventListener('resize', _resizeJudo);
  Judo.running = true;
  Judo.lastT = performance.now();
  Judo.raf = requestAnimationFrame(_judoLoop);
}

function _buildJudoka(THREE, giColor, isFat) {
  const g = new THREE.Group();
  const skinMat   = new THREE.MeshStandardMaterial({ color: 0xf2c79a, roughness:0.7 });
  const giMat     = new THREE.MeshStandardMaterial({ color: giColor, roughness:0.8 });
  const beltMat   = new THREE.MeshStandardMaterial({ color: 0x111111, roughness:0.8 });
  const gloveMat  = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness:0.6, metalness:0.1 });
  const hairMat   = new THREE.MeshStandardMaterial({ color: 0x222222, roughness:0.6 });

  const bodyW = isFat ? 1.35 : 0.92;
  const bodyD = isFat ? 0.95 : 0.58;

  const torso = new THREE.Mesh(new THREE.BoxGeometry(bodyW, 1.45, bodyD), giMat);
  torso.position.y = 1.5; torso.castShadow = true; g.add(torso);

  const belt = new THREE.Mesh(new THREE.BoxGeometry(bodyW+0.05, 0.18, bodyD+0.05), beltMat);
  belt.position.y = 0.95; belt.castShadow = true; g.add(belt);

  const head = new THREE.Mesh(new THREE.SphereGeometry(0.42, 16, 12), skinMat);
  head.position.y = 2.56; head.castShadow = true; g.add(head);

  const hair = new THREE.Mesh(new THREE.SphereGeometry(0.44, 16, 12, 0, Math.PI*2, 0, Math.PI/2), hairMat);
  hair.position.y = 2.58; g.add(hair);

  const eyeMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
  const eyeL = new THREE.Mesh(new THREE.SphereGeometry(0.05, 8, 6), eyeMat);
  eyeL.position.set(-0.13, 2.55, 0.38); g.add(eyeL);
  const eyeR = eyeL.clone(); eyeR.position.x = 0.13; g.add(eyeR);

  const armGeo = new THREE.BoxGeometry(0.28, 1.05, 0.28);
  const armL = new THREE.Mesh(armGeo, giMat);
  armL.position.set(-bodyW/2 - 0.18, 1.55, 0); armL.castShadow = true; g.add(armL);
  const armR = armL.clone(); armR.position.x = bodyW/2 + 0.18; g.add(armR);

  const gloveL = new THREE.Mesh(new THREE.BoxGeometry(0.24, 0.24, 0.34), gloveMat);
  gloveL.position.set(0, -0.56, 0.04); armL.add(gloveL);
  const gloveR = gloveL.clone(); armR.add(gloveR);

  const legGeo = new THREE.BoxGeometry(0.36, 1.05, 0.4);
  const legL = new THREE.Mesh(legGeo, giMat);
  legL.position.set(-0.25, 0.55, 0); legL.castShadow = true; g.add(legL);
  const legR = legL.clone(); legR.position.x = 0.25; g.add(legR);

  g.userData = { torso, head, hair, armL, armR, legL, legR, belt, walkPhase:0, moveBlend:0, guardBlend:0, collisionRadius: isFat ? 0.88 : 0.66 };
  g._parts = { torso, head, armL, armR, legL, legR, belt, hair };
  g._partRadii = { torso: bodyW * 0.34, head: 0.34, armL: 0.19, armR: 0.19, legL: 0.23, legR: 0.23, belt: bodyW * 0.26, hair: 0.22 };
  return g;
}

function _resizeJudo() {
  if (!Judo.container || !Judo.renderer || !Judo.camera) return;
  const w = Judo.container.clientWidth || window.innerWidth;
  const h = Judo.container.clientHeight || 400;
  Judo.renderer.setSize(w, h);
  Judo.camera.aspect = w / h;
  Judo.camera.updateProjectionMatrix();
}

const _hudCache = { meHP: -1, enHP: -1, score: -1, ippon: -1, enIppon: -1 };
function updateJudoHUD() {
  const mh = Math.max(0, Math.round(Judo.meHP));
  const eh = Math.max(0, Math.round(Judo.enHP));
  if (_hudCache.meHP !== mh) { $('#judoHpMe').textContent = mh; _hudCache.meHP = mh; }
  if (_hudCache.enHP !== eh) { $('#judoHpEn').textContent = eh; _hudCache.enHP = eh; }
  if (_hudCache.score !== Judo.score) { $('#judoScore').textContent = Judo.score; _hudCache.score = Judo.score; }
  const ipEl = $('#judoIppon');
  if (ipEl && _hudCache.ippon !== Judo.ippon) { ipEl.textContent = Judo.ippon; _hudCache.ippon = Judo.ippon; }
  const enIpEl = $('#judoEnIppon');
  if (enIpEl && _hudCache.enIppon !== Judo.enIppon) { enIpEl.textContent = Judo.enIppon; _hudCache.enIppon = Judo.enIppon; }
}

function _flashMsg(text, color, ms) {
  const el = $('#judoCenterMsg');
  el.innerHTML = String(text).replace(/\n/g, '<br>');
  el.style.color = color || '#fff';
  el.style.display = 'block';
  clearTimeout(Judo._msgT);
  Judo._msgT = setTimeout(()=>{ if (Judo.mode !== 'result') el.style.display='none'; }, ms || 700);
}

function _bindJudoControls() {
  const zone = $('#stickZone');
  const base = $('#stickBase');
  const knob = $('#stickKnob');
  const maxR = 46;

  function updateStick(clientX, clientY) {
    const rect = base.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    let dx = clientX - cx;
    let dy = clientY - cy;
    const len = Math.hypot(dx, dy) || 1;
    if (len > maxR) { dx = dx / len * maxR; dy = dy / len * maxR; }
    knob.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
    Judo.input.x = dx / maxR;
    Judo.input.y = dy / maxR;
    const m = Math.hypot(Judo.input.x, Judo.input.y);
    if (m > 0.14) {
      Judo.input.lastX = Judo.input.x;
      Judo.input.lastY = Judo.input.y;
    }
  }

  function resetStick() {
    Judo.input.pointerId = null;
    Judo.input.x = 0;
    Judo.input.y = 0;
    knob.style.transform = 'translate(-50%, -50%)';
  }

  zone.onpointerdown = e => {
    e.preventDefault();
    Judo.input.pointerId = e.pointerId;
    zone.setPointerCapture?.(e.pointerId);
    updateStick(e.clientX, e.clientY);
  };
  zone.onpointermove = e => {
    if (Judo.input.pointerId !== e.pointerId) return;
    e.preventDefault();
    updateStick(e.clientX, e.clientY);
  };
  zone.onpointerup = e => {
    if (Judo.input.pointerId !== e.pointerId) return;
    e.preventDefault();
    resetStick();
  };
  zone.onpointercancel = resetStick;
  zone.onpointerleave = e => {
    if (Judo.input.pointerId !== e.pointerId) return;
    resetStick();
  };

  $('#btnTackle').onclick = () => _playerAction('tackle');
  $('#btnThrow').onclick = () => _playerAction('throw');
  // 「固め」ボタンは UI 上非表示。固め技は投げ成功後のモード内でスポーンする pinBtn を叩く形として処理される。
  const bp = $('#btnPin'); if (bp) bp.onclick = null;

  const guardBtn = $('#btnGuard');
  const guardOn = e => {
    e.preventDefault();
    // 掴まれ中は「ガード連打」で脱出ゲージを加算
    if (Judo.mode === 'gripped' && Judo.grip) {
      _gripStruggle();
      guardBtn.style.transform = 'scale(0.92)';
      guardBtn.style.background = 'rgba(255,140,140,0.45)';
      setTimeout(() => { guardBtn.style.transform = ''; guardBtn.style.background = 'rgba(72,175,120,0.22)'; }, 80);
      return;
    }
    _setGuard(true);
    guardBtn.style.transform = 'scale(0.96)';
    guardBtn.style.background = 'rgba(72,175,120,0.38)';
  };
  const guardOff = e => {
    if (e) e.preventDefault();
    if (Judo.mode === 'gripped') return;
    _setGuard(false);
    guardBtn.style.transform = '';
    guardBtn.style.background = 'rgba(72,175,120,0.22)';
  };
  guardBtn.onpointerdown = guardOn;
  guardBtn.onpointerup = guardOff;
  guardBtn.onpointerleave = guardOff;
  guardBtn.onpointercancel = guardOff;

  // 掴まれレイヤーもタップで脱出ゲージ加算 (画面どこでもOK)
  const gripLayer = $('#judoGripLayer');
  if (gripLayer) {
    gripLayer.onpointerdown = (e) => {
      e.preventDefault();
      if (Judo.mode === 'gripped' && Judo.grip) _gripStruggle();
      else if (Judo.mode === 'enemyPin' && Judo.enemyPin) _enemyPinStruggle();
    };
  }
}

function _setGuard(on) {
  if (!Judo.running || Judo.mode !== 'fight') return;
  if (Judo.meStunT > 0) on = false; // スタン中はガード不可
  if (Judo.meRollT > 0 || Judo.meAction) on = false;
  Judo.meGuard = !!on;
  if (Judo.meStunT > 0) { Judo.mePose = 'down'; return; }
  if (!Judo.meAction && Judo.meRollT <= 0) {
    Judo.mePose = Judo.meGuard ? 'guard' : (Math.hypot(Judo.input.x, Judo.input.y) > 0.1 ? 'move' : 'idle');
    Judo.meAnim = 0;
  }
}

function _randRange(a, b) {
  return a + Math.random() * (b - a);
}

function _distXZ(a, b) {
  return Math.hypot(a.position.x - b.position.x, a.position.z - b.position.z);
}

function _angleTo(from, to) {
  return Math.atan2(to.x - from.x, to.z - from.z);
}

function _turnToward(group, target, ease=0.18) {
  if (!group || !target) return;
  const desired = _angleTo(group.position, target.position || target);
  let delta = desired - group.rotation.y;
  while (delta > Math.PI) delta -= Math.PI * 2;
  while (delta < -Math.PI) delta += Math.PI * 2;
  group.rotation.y += delta * ease;
}

function _clampArena(group) {
  const len = Math.hypot(group.position.x, group.position.z);
  if (len > Judo.arenaRadius) {
    group.position.x *= Judo.arenaRadius / len;
    group.position.z *= Judo.arenaRadius / len;
  }
}

function _resolveJudoCollision(pushMe=0.5, pushEn=0.5) {
  if (!Judo.me || !Judo.en) return;
  let dx = Judo.en.position.x - Judo.me.position.x;
  let dz = Judo.en.position.z - Judo.me.position.z;
  let dist = Math.hypot(dx, dz);
  const minDist = (Judo.me.userData?.collisionRadius || 0.66) + (Judo.en.userData?.collisionRadius || 0.88);
  if (dist < 0.0001) { dx = 0.001; dz = 0; dist = 0.001; }
  if (dist >= minDist) return;
  const overlap = minDist - dist;
  const nx = dx / dist;
  const nz = dz / dist;
  Judo.me.position.x -= nx * overlap * pushMe;
  Judo.me.position.z -= nz * overlap * pushMe;
  Judo.en.position.x += nx * overlap * pushEn;
  Judo.en.position.z += nz * overlap * pushEn;
  _clampArena(Judo.me);
  _clampArena(Judo.en);
}

/* ====== 固め技モード (v2 仕様) ======
   投げ成功 → _enterPin() で起動。
   10秒間、ランダムに pinBtn をレイヤ上にスポーン。
   - ボタンを 2秒以内に押すと +5点 ・ 相手 HP を少し削る
   - 2秒以内に押せないと 「逃げられた」でモード終了 + ダメージ
   - 10秒耐えると一本! +150点, ippon++, 相手 HP 100 リセット
*/
function _enterPin() {
  if (Judo.mode === 'pin') return;
  Judo.mode = 'pin';
  Judo.mePose = 'pin';
  Judo.enPose = 'pinDef';
  Judo.pin = {
    remain: 10.0,
    btnEl: null,
    btnTimer: 0,
    nextSpawn: 0.6 + Math.random() * 0.8,
    pressed: 0,
    missed: 0,
    cheatRollAt: 1.5 + Math.random() * 1.5,
    cheatDone: false,
  };
  Judo.meAction = null;
  Judo.enAction = null;
  Judo.meGuard = false;
  Judo.meRollT = 0;
  const layer = $('#judoPinLayer');
  if (layer) {
    layer.style.display = 'block';
    layer.style.pointerEvents = 'auto';
  }
  const status = $('#judoPinStatus');
  if (status) status.style.display = 'block';
  $('#judoCenterMsg').style.display = 'none';
}

function _spawnPinButton() {
  const layer = $('#judoPinLayer');
  if (!layer) return;
  const rect = layer.getBoundingClientRect();
  const pad = 30, btnSize = 64;
  // 下部38%はコントロール(スティック/アクションボタン)領域なので避ける
  const safeBottomRatio = 0.40;
  const usableHeight = Math.max(120, rect.height * (1 - safeBottomRatio) - pad*2 - btnSize);
  const x = pad + Math.random() * Math.max(1, rect.width  - pad*2 - btnSize);
  const y = pad + Math.random() * usableHeight;
  const btn = document.createElement('div');
  btn.className = 'pinBtn';
  btn.textContent = '!';
  btn.style.left = x + 'px';
  btn.style.top  = y + 'px';
  btn.onclick = (e) => {
    e.stopPropagation();
    if (btn._hit || !Judo.pin) return;
    btn._hit = true;
    btn.classList.add('hit');
    Judo.pin.pressed++;
    Judo.score += 5;
    Judo.enHP = Math.max(0, Judo.enHP - 3);
    setTimeout(()=> btn.remove(), 250);
    Judo.pin.btnEl = null;
    Judo.pin.nextSpawn = 0.5 + Math.random() * 0.8;
    updateJudoHUD();
  };
  layer.appendChild(btn);
  Judo.pin.btnEl = btn;
  Judo.pin.btnTimer = 1.0;
}

function _failPin() {
  if (!Judo.pin) return;
  if (Judo.pin.btnEl) {
    Judo.pin.btnEl.remove();
    Judo.pin.btnEl = null;
  }
  Judo.pin.missed++;
  Judo.meHP = Math.max(0, Judo.meHP - 12);
  Judo.shakeT = 12;
  _exitPin(false);
}

function _exitPin(success) {
  const layer = $('#judoPinLayer');
  if (layer) {
    layer.style.display = 'none';
    layer.style.pointerEvents = 'none';
    layer.querySelectorAll('.pinBtn').forEach(b => b.remove());
  }
  const status = $('#judoPinStatus');
  if (status) status.style.display = 'none';
  Judo.pin = null;
  Judo.mode = 'fight';
  Judo.mePose = 'idle';
  Judo.enPose = 'idle';
  Judo.meAnim = 0;
  Judo.enAnim = 0;
  Judo.attackCD = 30;
  Judo.enemyAtkCD = 70 + Math.random() * 40;
  // 両者を少し離す
  if (Judo.me && Judo.en) {
    const ang = _angleTo(Judo.me.position, Judo.en.position);
    Judo.en.position.x = Judo.me.position.x + Math.sin(ang) * 2.2;
    Judo.en.position.z = Judo.me.position.z + Math.cos(ang) * 2.2;
    _clampArena(Judo.en);
  }
  if (success) {
    Judo.ippon++;
    Judo.score += 150;
    _flashMsg('一本!\n+150点', '#ffd76b', 1500);
    Judo.enHP = 100; // 相手 HP リセットして続行 (v2 仕様)
  } else {
    _flashMsg('逃げられた!', '#ff8080', 1200);
  }
  updateJudoHUD();
}

/* ====== 掴まれモード (敵の掴み技成功時) ======
   - 5秒間掴まれ、ガードボタン連打で脱出ゲージを満タンにして脱出。
   - 5秒耐えれずに時間が切れると 「相手の一本」 → enIppon++ ・HPリセットして続行。
   - 脱出成功で fight 復帰。 */
function _setGripUiMode(kind) {
  const isEnemyPin = kind === 'enemyPin';
  const title = isEnemyPin ? '⚠️ 固められた！' : '⚠️ 掴まれた！';
  const label = isEnemyPin ? '固められた！' : '掴まれた！';
  const help = isEnemyPin ? 'ガード連打で切り返せ' : 'ガード連打で脱出';
  const helpLong = isEnemyPin ? '画面タップまたはガードボタンを連打で切り返せ！' : '画面タップまたはガードボタンを連打で脱出！';
  const goal = isEnemyPin ? 'ゲージを100%にすると切り返し成功' : 'ゲージを100%にすると脱出';
  const titleEl = $('#gripTitle'); if (titleEl) titleEl.textContent = title;
  const labelEl = $('#gripStatusLabel'); if (labelEl) labelEl.textContent = label;
  const helpEl = $('#gripStatusHelp'); if (helpEl) helpEl.textContent = help;
  const helpLongEl = $('#gripHelp'); if (helpLongEl) helpLongEl.textContent = helpLong;
  const goalEl = $('#gripGoalText'); if (goalEl) goalEl.textContent = goal;
}

function _enterEnemyPin() {
  if (Judo.mode === 'enemyPin') return;
  Judo.mode = 'enemyPin';
  Judo.mePose = 'pinDef';
  Judo.enPose = 'pin';
  Judo.meAction = null;
  Judo.enAction = null;
  Judo.meGuard = false;
  Judo.meRollT = 0;
  Judo.enemyPin = {
    remain: 6.0,
    struggle: 0,
    decay: 21,
    perTap: 10,
    lastTap: 0,
  };
  _setGripUiMode('enemyPin');
  const gl = $('#judoGripLayer');
  if (gl) { gl.style.display = 'block'; gl.style.pointerEvents = 'auto'; }
  const gs = $('#judoGripStatus'); if (gs) gs.style.display = 'block';
}

function _enemyPinStruggle() {
  if (!Judo.enemyPin) return;
  Judo.enemyPin.struggle = Math.min(100, Judo.enemyPin.struggle + Judo.enemyPin.perTap);
  Judo.enemyPin.lastTap = 0.12;
  const bar = $('#gripStruggleBar');
  if (bar) bar.style.width = Judo.enemyPin.struggle + '%';
  if (Judo.enemyPin.struggle >= 100) _exitEnemyPin(true);
}

function _exitEnemyPin(escaped) {
  const gl = $('#judoGripLayer');
  if (gl) { gl.style.display = 'none'; gl.style.pointerEvents = 'none'; }
  const gs = $('#judoGripStatus'); if (gs) gs.style.display = 'none';
  Judo.enemyPin = null;
  _setGripUiMode('grip');
  Judo.mode = 'fight';
  Judo.mePose = 'idle';
  Judo.enPose = 'idle';
  Judo.meAnim = 0;
  Judo.enAnim = 0;
  Judo.attackCD = 28;
  Judo.enemyAtkCD = 72 + Math.random() * 40;
  Judo.meInvuln = 0.85;
  if (Judo.me && Judo.en) {
    const ang = _angleTo(Judo.me.position, Judo.en.position);
    Judo.en.position.x = Judo.me.position.x + Math.sin(ang) * 2.5;
    Judo.en.position.z = Judo.me.position.z + Math.cos(ang) * 2.5;
    _clampArena(Judo.en);
  }
  if (escaped) {
    Judo.score += 45;
    _flashMsg('固め技を切り返した!\n+45点', '#8cffb0', 1200);
  } else {
    Judo.enIppon++;
    Judo.meHP = Math.max(Judo.meHP, 55);
    Judo.enHP = 100;
    _flashMsg('固め技で一本…\n相手IPPON +1', '#ff8080', 1500);
  }
  updateJudoHUD();
}

function _updateEnemyPin(dt) {
  if (!Judo.enemyPin) return;
  const g = Judo.enemyPin;
  g.remain -= dt;
  if (g.lastTap > 0) g.lastTap -= dt;
  else g.struggle = Math.max(0, g.struggle - g.decay * dt);

  const t1 = $('#gripTimer'); if (t1) t1.textContent = Math.max(0, g.remain).toFixed(1);
  const t2 = $('#gripBigTimer'); if (t2) t2.textContent = Math.max(0, g.remain).toFixed(1);
  const t3 = $('#gripStruggle'); if (t3) t3.textContent = Math.round(g.struggle);
  const bar = $('#gripStruggleBar'); if (bar) bar.style.width = g.struggle + '%';

  if (Judo.me && Judo.en) {
    const ang = _angleTo(Judo.me.position, Judo.en.position);
    const sep = 0.74;
    Judo.en.position.x = Judo.me.position.x + Math.sin(ang) * sep;
    Judo.en.position.z = Judo.me.position.z + Math.cos(ang) * sep;
  }
  Judo.mePose = 'pinDef';
  Judo.enPose = 'pin';

  if (g.remain <= 0) _exitEnemyPin(false);
}

function _enterGripped() {
  if (Judo.mode === 'gripped') return;
  Judo.mode = 'gripped';
  Judo.mePose = 'grappled';
  Judo.enPose = 'grappling';
  Judo.meAction = null;
  Judo.enAction = null;
  Judo.meGuard = false;
  Judo.meRollT = 0;
  Judo.grip = {
    remain: 5.0,
    struggle: 0,    // 0～100
    decay: 18,      // 連打しないとゲージが減る /sec
    perTap: 8,      // タップあたりのゲージ增加
    lastTap: 0,
  };
  const gl = $('#judoGripLayer');
  if (gl) { gl.style.display = 'block'; gl.style.pointerEvents = 'auto'; }
  _setGripUiMode('grip');
  const gs = $('#judoGripStatus'); if (gs) gs.style.display = 'block';
}

function _gripStruggle() {
  if (!Judo.grip) return;
  Judo.grip.struggle = Math.min(100, Judo.grip.struggle + Judo.grip.perTap);
  Judo.grip.lastTap = 0.12; // 最近タップしたフラグ (decay一時停止)
  // 画面フィードバック
  const bar = $('#gripStruggleBar');
  if (bar) bar.style.width = Judo.grip.struggle + '%';
  if (Judo.grip.struggle >= 100) {
    _exitGripped(true);
  }
}

function _exitGripped(escaped) {
  const gl = $('#judoGripLayer');
  if (gl) { gl.style.display = 'none'; gl.style.pointerEvents = 'none'; }
  const gs = $('#judoGripStatus'); if (gs) gs.style.display = 'none';
  Judo.grip = null;
  _setGripUiMode('grip');
  Judo.mode = 'fight';
  Judo.mePose = 'idle';
  Judo.enPose = 'idle';
  Judo.meAnim = 0;
  Judo.enAnim = 0;
  Judo.attackCD = 25;
  Judo.enemyAtkCD = 60 + Math.random() * 40;
  Judo.meInvuln = 0.8; // 脱出/一本後は少しの間袲間
  // 両者を離す
  if (Judo.me && Judo.en) {
    const ang = _angleTo(Judo.me.position, Judo.en.position);
    Judo.en.position.x = Judo.me.position.x + Math.sin(ang) * 2.4;
    Judo.en.position.z = Judo.me.position.z + Math.cos(ang) * 2.4;
    _clampArena(Judo.en);
  }
  if (escaped) {
    Judo.score += 40;
    _flashMsg('脱出成功!\n+40点', '#8cffb0', 1200);
  } else {
    // 相手の一本
    Judo.enIppon++;
    _flashMsg('掴め込まれて一本…\n相手IPPON +1', '#ff8080', 1500);
    // HPを 60 もしくは リセット (連続されないため)
    Judo.meHP = Math.max(Judo.meHP, 60);
    Judo.enHP = 100; // 敵はリセットして次ラウンドへ
  }
  updateJudoHUD();
}

function _updateGripped(dt) {
  if (!Judo.grip) return;
  const g = Judo.grip;
  g.remain -= dt;
  if (g.lastTap > 0) g.lastTap -= dt;
  else g.struggle = Math.max(0, g.struggle - g.decay * dt);

  // UI 更新
  const t1 = $('#gripTimer'); if (t1) t1.textContent = Math.max(0, g.remain).toFixed(1);
  const t2 = $('#gripBigTimer'); if (t2) t2.textContent = Math.max(0, g.remain).toFixed(1);
  const t3 = $('#gripStruggle'); if (t3) t3.textContent = Math.round(g.struggle);
  const bar = $('#gripStruggleBar'); if (bar) bar.style.width = g.struggle + '%';

  // 両者を掴み姿勢で重ねる (キャラ位置を掴まれているように押さえる)
  if (Judo.me && Judo.en) {
    const ang = _angleTo(Judo.me.position, Judo.en.position);
    const sep = 0.72;
    Judo.en.position.x = Judo.me.position.x + Math.sin(ang) * sep;
    Judo.en.position.z = Judo.me.position.z + Math.cos(ang) * sep;
  }
  Judo.mePose = 'grappled';
  Judo.enPose = 'grappling';

  if (g.remain <= 0) _exitGripped(false);
}

function _updateJudoPin(dt) {
  if (Judo.mode !== 'pin' || !Judo.pin) return;
  const pin = Judo.pin;
  pin.remain -= dt;

  // ボタンタイマー処理
  if (pin.btnEl) {
    pin.btnTimer -= dt;
    if (pin.btnTimer <= 0) { _failPin(); return; }
  } else {
    pin.nextSpawn -= dt;
    if (pin.nextSpawn <= 0 && pin.remain > 0.3) _spawnPinButton();
  }

  if (!pin.cheatDone && pin.remain < 8.6) {
    pin.cheatRollAt -= dt;
    if (pin.cheatRollAt <= 0) {
      pin.cheatDone = true;
      const roll = Math.random();
      if (roll < 0.18) {
        _flashMsg('ボットが強引に抜け出した!', '#ff9f9f', 900);
        _exitPin(false);
        return;
      }
      if (roll < 0.42) {
        pin.remain += 2.0;
        _flashMsg('ボットが粘って固め時間延長! +2.0秒', '#ffd76b', 900);
      }
    }
  }

  // ステータス UI 更新
  const pt = $('#pinTimer'); if (pt) pt.textContent = Math.max(0, pin.remain).toFixed(1);
  const bt = $('#pinBtnTimer'); if (bt) bt.textContent = pin.btnEl ? Math.max(0, pin.btnTimer).toFixed(1) : '-';

  // キャラを接近して固め姿勢
  if (Judo.me && Judo.en) {
    const ang = _angleTo(Judo.me.position, Judo.en.position);
    const sep = 0.78;
    Judo.en.position.x = Judo.me.position.x + Math.sin(ang) * sep;
    Judo.en.position.z = Judo.me.position.z + Math.cos(ang) * sep;
  }
  Judo.mePose = 'pin';
  Judo.enPose = 'pinDef';

  // 10秒耐えたら一本
  if (pin.remain <= 0) {
    _exitPin(true);
  }
}

function _getMoveVector(ix, iy) {
  if (!Judo.me || !Judo.en) return { x:0, z:0, mag:0 };
  let fx = Judo.en.position.x - Judo.me.position.x;
  let fz = Judo.en.position.z - Judo.me.position.z;
  let fl = Math.hypot(fx, fz);
  if (fl < 0.001) { fx = 0; fz = -1; fl = 1; }
  fx /= fl; fz /= fl;
  const rx = fz;
  const rz = -fx;
  let mx = rx * ix + fx * (-iy);
  let mz = rz * ix + fz * (-iy);
  const ml = Math.hypot(mx, mz);
  if (ml > 1) { mx /= ml; mz /= ml; }
  return { x:mx, z:mz, mag:Math.min(1, ml) };
}

function _playerAction(kind) {
  if (!Judo.running || Judo.mode !== 'fight') return;
  if (Judo.attackCD > 0 || Judo.meRollT > 0 || Judo.meAction) return;
  if (Judo.meStunT > 0) return; // 転んだ状態中は動けない
  const spec = JUDO_ATTACKS[kind];
  if (!spec) return;

  Judo.meGuard = false;
  Judo.mePose = kind;
  Judo.meAnim = 0;
  Judo.attackCD = spec.cooldown;
  // タックルはたまに「強タックル」が発動 (25% 確率): 3秒スタン + 強ノックバック
  const action = { side:'me', kind, t:0, hitDone:false, ...spec };
  if (kind === 'tackle' && Math.random() < 0.25) {
    action.strong = true;
    action.label = '強タックル';
    action.damage = [spec.damage[0] + 4, spec.damage[1] + 6];
    action.color = '#ffd76b';
    _flashMsg('🔥 強タックル!!', '#ffd76b', 600);
  }
  Judo.meAction = action;
}

/* 投げ成功判定 (v2 仕様): 60% で成功 → 固め技モード、失敗で反撃 */
function _throwResolve(action) {
  if (action.side === 'me') {
    const dist = _distXZ(Judo.me, Judo.en);
    if (dist > action.range) {
      _flashMsg('投げ 空振り', '#cfd8dc', 500);
      return;
    }
    if (Math.random() < (action.successRate || 0.6)) {
      // 成功
      Judo.enHP = Math.max(0, Judo.enHP - 6);
      Judo.score += 15;
      Judo.shakeT = 8;
      _flashMsg('投げ 成功!\n固め技へ!', '#7fffd4', 900);
      updateJudoHUD();
      setTimeout(() => { if (Judo.running && Judo.mode === 'fight') _enterPin(); }, 600);
    } else {
      // 失敗 → すきを作る (反撃のため attackCD を伸ばす)
      Judo.meHP = Math.max(0, Judo.meHP - 8);
      Judo.shakeT = 14;
      Judo.attackCD = 55;
      _flashMsg('投失敗…', '#ff8080', 800);
      updateJudoHUD();
    }
  } else {
    // 敵の投げ: 成功率を強化。まず投げで崩し、成功時は高確率でそのまま固めへ。
    const dist = _distXZ(Judo.me, Judo.en);
    if (dist > action.range + 0.12) return;
    if (Judo.meInvuln > 0) {
      Judo.score += 2;
      _flashMsg('回避成功!', '#8fd9ff', 320);
      return;
    }
    const throwBias = Judo.enemyThrowBias || 1.0;
    const baseRate = Judo.meGuard ? (0.26 * throwBias) : (0.72 * throwBias);
    const successRate = Math.max(0.18, Math.min(0.92, baseRate));
    if (Math.random() < successRate) {
      const dmg = Judo.meGuard ? 6 : 12;
      Judo.meHP = Math.max(0, Judo.meHP - dmg);
      Judo.shakeT = 16;
      Judo.enemyThrowBias = 1.0;
      const pinChance = Judo.meGuard ? 0.28 : 0.86;
      const doPin = Math.random() < pinChance;
      _flashMsg(
        Judo.meGuard
          ? (doPin ? '投げを耐えたが押さえ込まれる!' : '投げをしのいだ!')
          : (doPin ? '投げられた!\n相手の固め技へ!' : '豪快に投げられた!'),
        Judo.meGuard ? '#8cffb0' : '#ff9595',
        760
      );
      updateJudoHUD();
      if (doPin) {
        setTimeout(() => { if (Judo.running && Judo.mode === 'fight') _enterEnemyPin(); }, 430);
      }
    } else {
      Judo.enemyThrowBias = Math.min(1.25, throwBias + 0.05);
      if (Judo.meGuard) _flashMsg('投げを返した!', '#8cffb0', 500);
      else _flashMsg('投げをよけた!', '#ffe08f', 500);
    }
  }
}

// (柔道本編にあった 回避ロール _startRoll はボクシングモードに移植されたため削除)

function _startEnemyAction(kind) {
  const spec = JUDO_ATTACKS[kind];
  if (!spec || Judo.enAction || Judo.mode !== 'fight') return;
  // ガード中は攻撃しない (ガードを解除してから)
  Judo.enGuard = false; Judo.enGuardT = 0;
  Judo.enPose = kind;
  Judo.enAnim = 0;
  Judo.enAction = {
    side:'en', kind,
    label:'敵' + spec.label,
    range: spec.range + (kind === 'tackle' ? 0.12 : 0),
    damage:[Math.max(4, spec.damage[0]-1), Math.max(7, spec.damage[1]-1)],
    hitAt: spec.hitAt + 0.07,
    total: spec.total + 0.12,
    cooldown: spec.cooldown + 12,
    color: kind === 'grapple' ? '#ff9090' : '#ffb08f',
    score:0,
    t:0,
    hitDone:false,
    successRate: spec.successRate,
  };
  // 敵タックルもたまに強化版 (20% 確率)
  if (kind === 'tackle' && Math.random() < 0.20) {
    Judo.enAction.strong = true;
    Judo.enAction.label = '敵の強タックル';
    Judo.enAction.damage = [Judo.enAction.damage[0] + 3, Judo.enAction.damage[1] + 5];
    Judo.enAction.color = '#ff7b3a';
    _flashMsg('⚠️ 敵が強タックル!', '#ff7b3a', 500);
  }
  Judo.enemyAtkCD = spec.cooldown + 28 + Math.random()*24;
}

function _applyHit(action) {
  const from = action.side === 'me' ? Judo.me : Judo.en;
  const to = action.side === 'me' ? Judo.en : Judo.me;
  if (!from || !to) return;

  const dist = _distXZ(from, to);
  if (dist > action.range) {
    if (action.side === 'me') _flashMsg(action.label + ' 空振り', '#cfd8dc', 320);
    return;
  }

  const dmg = _randRange(action.damage[0], action.damage[1]);
  const dx = to.position.x - from.position.x;
  const dz = to.position.z - from.position.z;
  const dl = Math.hypot(dx, dz) || 1;
  const push = action.kind === 'throw' ? (action.launch || 1.28) : (action.kind === 'tackle' ? 0.44 : 0.18);

  // 投げは専用処理 (v2 仕様に揃える)
  if (action.kind === 'throw') {
    _throwResolve(action);
    return;
  }
  // 掴み技 (敵専用): 成功判定 → gripped モードへ
  if (action.kind === 'grapple') {
    if (action.side !== 'en') return; // プレイヤーは掴みを使わない仕様
    if (Judo.meInvuln > 0) { _flashMsg('スルッと回避!', '#8fd9ff', 360); return; }
    // ガード中は掴みを振りほどける確率が高い
    const sr = (action.successRate || 0.7) * (Judo.meGuard ? 0.35 : 1);
    if (Math.random() < sr) {
      if (!Judo.meGuard && Math.random() < 0.35) {
        _flashMsg('掴みからそのまま固められた!', '#ff9090', 700);
        _enterEnemyPin();
      } else {
        _flashMsg('掴まれた!', '#ff9090', 600);
        _enterGripped();
      }
    } else {
      // 振りほどいた
      _flashMsg(Judo.meGuard ? 'ガードで振りほどいた!' : '掴みを逃れた!', '#8cffb0', 500);
    }
    return;
  }

  if (action.side === 'me') {
    // 敵のガードでダメージ軽減
    const enGuardMul = Judo.enGuard ? (action.kind === 'tackle' ? 0.45 : 0.30) : 1;
    const finalDmg = dmg * enGuardMul;
    Judo.enHP = Math.max(0, Judo.enHP - finalDmg);
    Judo.score += Math.round(action.score * (Judo.enGuard ? 0.4 : 1));
    if (!Judo.enGuard) {
      // 強タックルはノックバック増幅 + 3秒スタン
      const isStrong = action.kind === 'tackle' && action.strong;
      const knockMul = isStrong ? 4.0 : 1.0;
      to.position.x += dx / dl * push * knockMul;
      to.position.z += dz / dl * push * knockMul;
      _clampArena(to);
      _resolveJudoCollision(0.15, 0.6);
      Judo.shakeT = isStrong ? 22 : (action.kind === 'throw' ? 14 : (action.kind === 'tackle' ? 10 : 6));
      if (isStrong) {
        Judo.enStunT = 3.0;
        Judo.enPose = 'down';
        Judo.enAction = null;
        Judo.enAnim = 0;
        Judo.score += 8;
        _flashMsg(action.label + ' ヒット!\n敵が転んだ!!', '#ffd76b', 700);
      } else {
        _flashMsg(action.label + ' ヒット!', action.color, 420);
      }
    } else {
      Judo.shakeT = 3;
      _flashMsg('敵にガードされた!', '#ffd76b', 380);
      // ガードを難したら解除側も者随う
      Judo.enGuardT = Math.max(0.05, Judo.enGuardT - 0.4);
    }
  } else {
    if (Judo.meInvuln > 0) {
      Judo.score += 2;
      _flashMsg('回避成功!', '#8fd9ff', 320);
      return;
    }
    const guardRate = Judo.meGuard ? (action.kind === 'tackle' ? 0.58 : 0.36) : 1;
    const finalDmg = dmg * guardRate;
    Judo.meHP = Math.max(0, Judo.meHP - finalDmg);
    if (!Judo.meGuard) {
      // 敵の強タックルを被弾：3秒スタン + 強ノックバック
      const isStrong = action.kind === 'tackle' && action.strong;
      const knockMul = isStrong ? 4.0 : 0.9;
      Judo.me.position.x -= dx / dl * push * knockMul;
      Judo.me.position.z -= dz / dl * push * knockMul;
      _clampArena(Judo.me);
      _resolveJudoCollision(0.55, 0.15);
      Judo.shakeT = isStrong ? 24 : (action.kind === 'throw' ? 16 : (action.kind === 'tackle' ? 14 : 8));
      if (isStrong) {
        Judo.meStunT = 3.0;
        Judo.mePose = 'down';
        Judo.meAction = null;
        Judo.meAnim = 0;
        Judo.meRollT = 0;
        Judo.meGuard = false;
        _flashMsg(action.label + ' 被弾!\n転んだ…動けない!', '#ff5050', 1000);
      } else {
        _flashMsg(action.label + ' 被弾!', '#ff9595', 420);
      }
    } else {
      Judo.shakeT = 4;
      _flashMsg('ガード!', '#8cffb0', 260);
    }
  }
  updateJudoHUD();
}

function _updateAction(action, dt) {
  if (!action) return null;
  action.t += dt;
  if (action.kind === 'tackle' || action.kind === 'throw') {
    const actor = action.side === 'me' ? Judo.me : Judo.en;
    const target = action.side === 'me' ? Judo.en : Judo.me;
    const ang = _angleTo(actor.position, target.position);
    let rush = 0;
    if (action.kind === 'tackle') rush = action.t < action.hitAt ? 3.4 : 1.6;
    else rush = action.t < action.hitAt ? 2.7 : 0.8;
    actor.position.x += Math.sin(ang) * rush * dt;
    actor.position.z += Math.cos(ang) * rush * dt;
    _clampArena(actor);
    _resolveJudoCollision(action.side === 'me' ? 0.18 : 0.52, action.side === 'me' ? 0.52 : 0.18);
  }
  if (!action.hitDone && action.t >= action.hitAt) {
    action.hitDone = true;
    _applyHit(action);
  }
  if (action.t >= action.total) return null;
  return action;
}

/* ====== 賢い敵 AI ======
   状況を見て「接近 / 距離をとる / ストレイフ / ガード / タックル / 投げ / 掴み」を使い分ける。
   ・ プレイヤーが攻撃モーション中 → ガード・カウンター
   ・ プレイヤーがガード中 → 掴み or 距離をとる
   ・ 自分のHPが低い → より守り重視、ガード高頻度
   ・ クールダウンを見てプレイヤーの隽を突く
*/
function _enemyThink(dt, time) {
  if (Judo.enAction || Judo.mode !== 'fight') return;
  const dist = _distXZ(Judo.me, Judo.en);
  const ang = _angleTo(Judo.en.position, Judo.me.position);
  const enLowHP = Judo.enHP < 35;
  const meLowHP = Judo.meHP < 25;
  const playerAttacking = !!Judo.meAction;
  const playerInRange = playerAttacking && _distXZ(Judo.me, Judo.en) < (Judo.meAction.range + 0.3);
  const playerGuarding = Judo.meGuard;

  // ガード クールダウン・持続処理
  if (Judo.enGuardCD > 0) Judo.enGuardCD -= dt;
  if (Judo.enGuard) {
    Judo.enGuardT -= dt;
    if (Judo.enGuardT <= 0) { Judo.enGuard = false; Judo.enGuardCD = 0.4; }
  }

  /* 「リアクションガード」:
     プレイヤーの攻撃モーション中、hitタイミング直前だと高確率でガード */
  if (playerAttacking && playerInRange && Judo.enGuardCD <= 0 && !Judo.enGuard) {
    const a = Judo.meAction;
    const timeToHit = a.hitAt - a.t;
    // 反応速度 (やや人間らしく): hitAt の 0～0.18秒手前でガードを見したてる
    if (timeToHit <= 0.18 && timeToHit > -0.05) {
      const guardProb = enLowHP ? 0.85 : (a.kind === 'tackle' ? 0.7 : 0.5);
      if (Math.random() < guardProb) {
        Judo.enGuard = true;
        Judo.enGuardT = 0.4 + Math.random() * 0.25;
        Judo.enPose = 'guard';
        return; // このターンはガードに専念
      }
    }
  }

  // ストレイフ方向タイマー (不規則に差右を切り替え)
  Judo.enStrafeT -= dt;
  if (Judo.enStrafeT <= 0) {
    Judo.enStrafeDir = (Math.random() < 0.5 ? -1 : 1);
    Judo.enStrafeT = 0.7 + Math.random() * 1.0;
  }

  // ムーブメント: 投げ主体に寄せ、近距離を維持しやすくする
  let targetDist = 1.34;
  if (enLowHP) targetDist = 1.95;          // HP低い → 少しだけ距離をとる
  else if (meLowHP) targetDist = 1.12;     // プレイヤーのHP低い → 一気に詰める
  else if (playerGuarding) targetDist = 1.08; // ガード中は投げ/掴み距離へ詰める
  else if (playerAttacking) targetDist = 1.75;  // プレイヤー攻撃中も完全には離れず投げ返しを狙う

  const distErr = dist - targetDist;
  let advance = 0;
  if (Math.abs(distErr) > 0.18) advance = distErr > 0 ? 1 : -0.85; // 接近・后退
  // ガード中は動き遅い
  const moveMul = Judo.enGuard ? 0.4 : 1;
  const fwdSpd = Judo.enemySpeed * moveMul * advance;
  Judo.en.position.x += Math.sin(ang) * fwdSpd * dt;
  Judo.en.position.z += Math.cos(ang) * fwdSpd * dt;
  // ストレイフ (接近しているとき主に)
  const strafeMag = Math.abs(distErr) < 0.6 ? 1.4 : 0.5;
  const strafe = Judo.enStrafeDir * strafeMag * moveMul;
  Judo.en.position.x += Math.cos(ang) * strafe * dt * 0.6;
  Judo.en.position.z -= Math.sin(ang) * strafe * dt * 0.6;
  _clampArena(Judo.en);
  _resolveJudoCollision(0.32, 0.22);

  // ポーズ処理 (ガード中以外は move/idle)
  if (!Judo.enGuard) {
    Judo.enPose = (Math.abs(advance) > 0.05 || Math.abs(strafe) > 0.4) ? 'move' : 'idle';
  }

  // 攻撃 CD
  Judo.enemyAtkCD -= dt * 60;
  if (Judo.enemyAtkCD > 0) return;
  if (Judo.enGuard) return; // ガード中は攻撃しない

  // 「クールダウンを見た反撃」: プレイヤーが攻撃クールダウン中なら積極的に攻撃
  const playerVulnerable = Judo.attackCD > 18 || playerAttacking;

  /* 技選択:
     - 距離近い ⊕ プレイヤーガード中 → grapple (ガード越しに掴まえる)
     - 距離近い + ランダムで掴みを使う
     - 距離中間 → タックル
     - 超近距離 → 投げ
     - プレイヤーが攻撃クールダウン中ならタックルで強袲 */
  let kind = null;
  if (dist < 1.34) {
    if (playerGuarding) {
      kind = Math.random() < 0.68 ? 'throw' : 'grapple';
    } else if (playerVulnerable) {
      kind = Math.random() < 0.72 ? 'throw' : 'grapple';
    } else {
      const r = Math.random();
      kind = r < 0.55 ? 'throw' : (r < 0.82 ? 'grapple' : 'tackle');
    }
  } else if (dist < 1.82) {
    if (playerVulnerable || playerGuarding) kind = Math.random() < 0.6 ? 'throw' : 'tackle';
    else kind = Math.random() < 0.38 ? 'throw' : 'tackle';
  } else if (dist < 2.3) {
    kind = playerVulnerable ? (Math.random() < 0.55 ? 'tackle' : 'throw') : 'tackle';
  } else {
    // 遠いときは詰める動きを優先して攻撃しない
    Judo.enemyAtkCD = 6 + Math.random() * 6;
    return;
  }

  // HPが低いときも投げは維持し、掴みを少し減らす
  if (enLowHP && kind === 'grapple') kind = Math.random() < 0.7 ? 'throw' : 'tackle';

  _startEnemyAction(kind);
}

function _updateCamera() {
  if (!Judo.camera || !Judo.me || !Judo.en || !Judo.THREE) return;
  let bx = Judo.me.position.x - Judo.en.position.x;
  let bz = Judo.me.position.z - Judo.en.position.z;
  let bl = Math.hypot(bx, bz);
  if (bl < 0.001) { bx = 0; bz = 1; bl = 1; }
  bx /= bl; bz /= bl;
  const fighterDist = Math.max(0, Math.min(2.2, _distXZ(Judo.me, Judo.en) - 1.2));
  const camBack = 4.55 + fighterDist * 0.55;
  const focusX = (Judo.me.position.x + Judo.en.position.x) * 0.5;
  const focusZ = (Judo.me.position.z + Judo.en.position.z) * 0.5;
  if (!Judo._camVec) Judo._camVec = new Judo.THREE.Vector3();
  const desired = Judo._camVec;
  desired.set(
    focusX + bx * camBack,
    2.95 + fighterDist * 0.22,
    focusZ + bz * camBack
  );
  if (Judo.shakeT > 0) {
    desired.x += (Math.random() - 0.5) * 0.12;
    desired.y += (Math.random() - 0.5) * 0.12;
  }
  Judo.camera.position.lerp(desired, 0.11);
  Judo.camera.lookAt(focusX, 1.45, focusZ);
}

function _judoLoop(now) {
  if (!Judo.running || !$('#screen-judo').classList.contains('active')) {
    Judo.running = false;
    if (Judo.score > 0) Rank.submit('judo', Judo.score);
    return;
  }

  const dt = Math.min(0.05, (now - Judo.lastT) / 1000);
  Judo.lastT = now;
  const time = now * 0.001;

  if (Judo.attackCD > 0) Judo.attackCD -= dt * 60;
  if (Judo.meInvuln > 0) Judo.meInvuln -= dt;
  if (Judo.shakeT > 0) Judo.shakeT -= dt * 60;
  // 転んだ状態のタイマー
  if (Judo.meStunT > 0) {
    Judo.meStunT -= dt;
    if (Judo.meStunT <= 0) {
      Judo.meStunT = 0;
      Judo.mePose = 'idle';
      _flashMsg('立ち上がった!', '#8cffb0', 500);
    } else {
      Judo.mePose = 'down';
    }
  }
  if (Judo.enStunT > 0) {
    Judo.enStunT -= dt;
    if (Judo.enStunT <= 0) {
      Judo.enStunT = 0;
      Judo.enPose = 'idle';
    } else {
      Judo.enPose = 'down';
    }
  }

  if (Judo.mode === 'fight') {
    // スタン中は動けない
    if (Judo.meStunT > 0) {
      // スタン中は何もしない。アクションも中断済。
    } else if (Judo.meRollT > 0) {
      const rollSpeed = 7.8 * (0.55 + Judo.meRollT);
      Judo.me.position.x += Judo.meRollDir.x * rollSpeed * dt;
      Judo.me.position.z += Judo.meRollDir.z * rollSpeed * dt;
      _clampArena(Judo.me);
      Judo.meRollT -= dt;
      if (Judo.meRollT <= 0 && !Judo.meAction) {
        Judo.mePose = Judo.meGuard ? 'guard' : 'idle';
      }
    } else if (!Judo.meAction) {
      const mv = _getMoveVector(Judo.input.x, Judo.input.y);
      const spd = Judo.moveSpeed * mv.mag * (Judo.meGuard ? 0.45 : 1);
      Judo.me.position.x += mv.x * spd * dt;
      Judo.me.position.z += mv.z * spd * dt;
      _clampArena(Judo.me);
      _resolveJudoCollision(0.55, 0.15);
      if (mv.mag > 0.12) {
        Judo.input.lastX = Judo.input.x;
        Judo.input.lastY = Judo.input.y;
      }
      if (!Judo.meGuard) Judo.mePose = mv.mag > 0.12 ? 'move' : 'idle';
      else Judo.mePose = 'guard';
    }

    Judo.meAction = _updateAction(Judo.meAction, dt);
    Judo.enAction = _updateAction(Judo.enAction, dt);
    if (!Judo.meAction && Judo.meRollT <= 0 && Judo.meStunT <= 0) {
      const mv = _getMoveVector(Judo.input.x, Judo.input.y);
      Judo.mePose = Judo.meGuard ? 'guard' : (mv.mag > 0.12 ? 'move' : 'idle');
    } else if (Judo.meStunT > 0) {
      Judo.mePose = 'down';
    }
    if (!Judo.enAction && Judo.enStunT <= 0) _enemyThink(dt, time);
    if (!Judo.enAction && Judo.enStunT <= 0) {
      const d = _distXZ(Judo.me, Judo.en);
      Judo.enPose = d > 1.7 ? 'move' : 'idle';
    } else if (Judo.enStunT > 0) {
      Judo.enPose = 'down';
    }
    _resolveJudoCollision(0.5, 0.5);
  } else if (Judo.mode === 'pin') {
    _updateJudoPin(dt);
  } else if (Judo.mode === 'gripped') {
    _updateGripped(dt);
  } else if (Judo.mode === 'enemyPin') {
    _updateEnemyPin(dt);
  }

  _turnToward(Judo.me, Judo.en, Judo.meRollT > 0 ? 0.1 : 0.22);
  _turnToward(Judo.en, Judo.me, 0.18);

  Judo.meAnim = Math.min(1, Judo.meAnim + dt * 5.5);
  Judo.enAnim = Math.min(1, Judo.enAnim + dt * 5.2);
  _animateJudoka(Judo.me, Judo.mePose, Judo.meAnim, time);
  _animateJudoka(Judo.en, Judo.enPose, Judo.enAnim, time + 0.7);
  _updateCamera();

  Judo.renderer.render(Judo.scene, Judo.camera);

  // 仕様変更: HPが0になってもゲームオーバーにせず続行。
  // 勝敗は「一本3本」でだけ決まる。
  // ボットが掴みで一本を取ると enIppon が加算され、プレイヤーの一本と同じ嬽で評価。
  if (Judo.ippon >= 3)   { _judoGameOver(true);  return; }
  if (Judo.enIppon >= 3) { _judoGameOver(false); return; }

  Judo.raf = requestAnimationFrame(_judoLoop);
}

function _animateJudoka(g, pose, t, time) {
  if (!g || !g.userData) return;
  const u = g.userData;

  const isMove = pose === 'move';
  const walkAmp = isMove ? 1 : 0;
  u.walkPhase += 0.18 + walkAmp * 0.55;
  // 事前計算でサイン演算を集約
  const sinWalk = Math.sin(time * 9.5 + u.walkPhase);
  const walk = sinWalk * 0.7;
  const breath = Math.sin(time * 2.2) * 0.03;

  let armLrx = -0.08, armRrx = -0.08, armLrz = 0, armRrz = 0;
  let legLrx = 0, legRrx = 0;
  let torsoRx = 0, torsoRy = 0;
  let posY = breath;

  if (pose === 'move') {
    armLrx = -walk * 0.45;
    armRrx = walk * 0.45;
    legLrx = walk * 0.75;
    legRrx = -walk * 0.75;
    torsoRx = Math.abs(walk) * 0.08;
  } else if (pose === 'guard') {
    armLrx = -1.2; armRrx = -1.2;
    armLrz = -0.35; armRrz = 0.35;
    torsoRx = 0.15;
    posY *= 0.4;
  } else if (pose === 'punch') {
    const swing = Math.sin(Math.PI * Math.min(1, t));
    armRrx = -1.8 * swing;
    armLrx = -0.5;
    torsoRx = 0.14 * swing;
    torsoRy = -0.18 * swing;
    legLrx = 0.18 * swing;
    legRrx = -0.18 * swing;
  } else if (pose === 'kick') {
    const swing = Math.sin(Math.PI * Math.min(1, t));
    armLrx = -0.95; armRrx = -0.95;
    legRrx = -1.5 * swing;
    legLrx = 0.28 * swing;
    torsoRx = 0.12 + 0.18 * swing;
  } else if (pose === 'tackle') {
    const swing = Math.sin(Math.PI * Math.min(1, t));
    torsoRx = -0.72 * swing;
    armLrx = -1.45 * swing;
    armRrx = -1.45 * swing;
    legLrx = 0.72 * swing;
    legRrx = -0.72 * swing;
    posY += 0.04 * swing;
  } else if (pose === 'throw') {
    const swing = Math.sin(Math.PI * Math.min(1, t));
    torsoRx = -0.18 + 0.5 * swing;
    torsoRy = -0.55 * swing;
    armLrx = -1.25 + 0.35 * swing;
    armRrx = -1.55 * swing;
    armLrz = -0.28; armRrz = 0.22;
    legLrx = 0.48 * swing;
    legRrx = -0.82 * swing;
    posY += 0.05 * swing;
  } else if (pose === 'pin') {
    torsoRx = 0.32;
    armLrx = -1.55; armRrx = -1.55;
    armLrz = -0.18; armRrz = 0.18;
    legLrx = -0.18; legRrx = 0.18;
    posY -= 0.03;
  } else if (pose === 'pinDef') {
    torsoRx = 0.56;
    armLrx = -0.45; armRrx = -0.45;
    legLrx = 0.24; legRrx = 0.24;
    posY -= 0.08;
  } else if (pose === 'roll') {
    const swing = Math.sin(Math.PI * Math.min(1, t));
    torsoRx = -1.05 * swing;
    armLrx = -1.4; armRrx = -1.25;
    legLrx = 1.15 * swing;
    legRrx = 1.15 * swing;
    posY -= 0.12 * swing;
  } else if (pose === 'grapple') {
    // 敵の掴み動作 (両手を前へ伸ばして掛けてくる)
    const swing = Math.sin(Math.PI * Math.min(1, t));
    armLrx = -1.55 - 0.2 * swing; armRrx = -1.55 - 0.2 * swing;
    armLrz = -0.30; armRrz = 0.30;
    torsoRx = 0.18 + 0.12 * swing;
    legLrx = 0.18 * swing; legRrx = -0.18 * swing;
  } else if (pose === 'grappling') {
    // 敵がプレイヤーを掴んでいる状態 (両手を前へ、やや踏み込み)
    armLrx = -1.65; armRrx = -1.65;
    armLrz = -0.28; armRrz = 0.28;
    torsoRx = 0.22 + Math.sin(time * 4) * 0.04;
    legLrx = 0.10; legRrx = -0.10;
  } else if (pose === 'grappled') {
    // プレイヤーが掴まれた状態 (上体を押さえられてもがいている描写)
    armLrx = -0.85; armRrx = -0.85;
    armLrz = -0.42 + Math.sin(time * 6) * 0.12;
    armRrz = 0.42 + Math.cos(time * 6) * 0.12;
    torsoRx = 0.45 + Math.sin(time * 3) * 0.08;
    legLrx = 0.22; legRrx = -0.22;
    posY -= 0.05;
  } else if (pose === 'down') {
    // 転んだ状態: 仰向けに倒れて動けない
    torsoRx = 1.45; // もろに倒れる
    armLrx = -0.25; armRrx = -0.25;
    armLrz = -0.85; armRrz = 0.85;
    legLrx = -0.15; legRrx = 0.15;
    posY -= 0.55; // 地面近くまで下がる
  } else if (pose === 'reviveCrawl') {
    // 四つん這いになり、片腕で腹を押さえてもがく姿勢 (リバイブ専用)
    const writhe = Math.sin(time * 5.8);
    const writhe2 = Math.sin(time * 7.4 + 1.2);
    torsoRx = 1.22 + writhe * 0.06;          // 前傾 (四つん這い)
    torsoRy = writhe2 * 0.10;                 // 体をくねらせる
    // 左腕: 腹を押さえる (前方・内側に折る)
    armLrx = -1.85 - writhe2 * 0.08;
    armLrz = -0.95;
    // 右腕: 地面についている (前方やや下向き)
    armRrx = -1.10 + writhe * 0.15;
    armRrz = 0.30;
    // 脚: 折りたたむ
    legLrx = 0.85 - writhe * 0.10;
    legRrx = 0.85 + writhe * 0.10;
    posY -= 0.62 + writhe * 0.02;             // 地面近くに沈む
  }

  u.torso.rotation.x = torsoRx;
  u.torso.rotation.y = torsoRy;
  u.head.rotation.x  = torsoRx * 0.42;
  u.hair.rotation.x  = torsoRx * 0.42;
  u.armL.rotation.x  = armLrx;
  u.armR.rotation.x  = armRrx;
  u.armL.rotation.z  = armLrz;
  u.armR.rotation.z  = armRrz;
  u.legL.rotation.x  = legLrx;
  u.legR.rotation.x  = legRrx;
  g.position.y = posY;
}

function _judoGameOver(win) {
  Judo.running = false;
  Judo.mode = 'result';
  const pinLayer = $('#judoPinLayer');
  if (pinLayer) {
    pinLayer.style.display = 'none';
    pinLayer.style.pointerEvents = 'none';
    pinLayer.querySelectorAll('.pinBtn').forEach(b => b.remove());
  }
  const ps = $('#judoPinStatus'); if (ps) ps.style.display = 'none';
  const gl = $('#judoGripLayer'); if (gl) { gl.style.display = 'none'; gl.style.pointerEvents = 'none'; }
  const gs = $('#judoGripStatus'); if (gs) gs.style.display = 'none';
  Judo.pin = null;
  Judo.grip = null;
  const msg = win
    ? `🏆 一本勝ち!
あなた ${Judo.ippon} : ${Judo.enIppon} 相手
スコア: ${Judo.score}
タップで戻る`
    : `🥊 掴み負け…
あなた ${Judo.ippon} : ${Judo.enIppon} 相手
スコア: ${Judo.score}
タップで戻る`;
  const el = $('#judoCenterMsg');
  el.innerHTML = msg.replace(/\n/g, '<br>');
  el.style.color = win ? '#ffd76b' : '#ff8c8c';
  el.style.display = 'block';
  Rank.submit('judo', Judo.score);
  const back = () => {
    Judo.container.onclick = null;
    el.onclick = null;
    go('menu');
  };
  Judo.container.onclick = back;
  el.style.pointerEvents = 'auto';
  el.onclick = back;
}

function _disposeScene(scene) {
  if (!scene) return;
  scene.traverse(obj => {
    if (obj.geometry) { try { obj.geometry.dispose(); } catch(e) {} }
    if (obj.material) {
      const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
      mats.forEach(m => {
        if (m.map) m.map.dispose();
        try { m.dispose(); } catch(e) {}
      });
    }
  });
}

function _disposeJudo() {
  if (Judo.raf) cancelAnimationFrame(Judo.raf);
  Judo.raf = 0;
  Judo.running = false;
  window.removeEventListener('resize', _resizeJudo);
  const pinLayer = $('#judoPinLayer');
  if (pinLayer) {
    pinLayer.style.display = 'none';
    pinLayer.style.pointerEvents = 'none';
    pinLayer.querySelectorAll('.pinBtn').forEach(b => b.remove());
  }
  const ps = $('#judoPinStatus'); if (ps) ps.style.display = 'none';
  Judo.pin = null;
  if (Judo.scene) _disposeScene(Judo.scene);
  if (Judo.renderer) {
    try { Judo.renderer.renderLists.dispose(); Judo.renderer.dispose(); } catch(e) {}
    if (Judo.renderer.domElement && Judo.renderer.domElement.parentNode) {
      Judo.renderer.domElement.parentNode.removeChild(Judo.renderer.domElement);
    }
  }
  Judo.renderer = null; Judo.scene = null; Judo.camera = null;
  Judo.me = null; Judo.en = null;
  if (Judo.container) Judo.container.innerHTML = '';
  const zone = $('#stickZone');
  if (zone) {
    zone.onpointerdown = null;
    zone.onpointermove = null;
    zone.onpointerup = null;
    zone.onpointercancel = null;
    zone.onpointerleave = null;
  }
  ['btnTackle','btnThrow','btnPin','btnGuard'].forEach(id => {
    const el = $('#' + id);
    if (!el) return;
    el.onclick = null;
    el.onpointerdown = null;
    el.onpointerup = null;
    el.onpointerleave = null;
    el.onpointercancel = null;
  });
  const knob = $('#stickKnob');
  if (knob) knob.style.transform = 'translate(-50%, -50%)';
  const cm = $('#judoCenterMsg');
  if (cm) { cm.style.display = 'none'; cm.style.pointerEvents = 'none'; }
}

/* ============================================================
   🥊 ガリガリ殴り合い
   ・パンチ / キック / タックル(ノクバ付き10ダメ) / ガード(耐久30、未使用時に漸進回復) / 回避
   ・3D描画・アニメーション関数は柔道の _buildJudoka / _animateJudoka を共有
   ============================================================ */
const Boxing = {
  THREE: null,
  container: null,
  renderer: null, scene: null, camera: null,
  me: null, en: null,
  mePose: 'idle', enPose: 'idle',
  meHP: 100, enHP: 100,
  score: 0,
  running: false, raf: 0,
  lastT: 0,
  attackCD: 0, enemyAtkCD: 55,
  mode: 'fight', // 'fight' | 'revive' | 'enemyRevive' | 'result'
  meAnim: 0, enAnim: 0,
  shakeT: 0,
  arenaRadius: 4.2,
  moveSpeed: 4.2,
  enemySpeed: 2.75,
  meAction: null,
  enAction: null,
  meGuard: false,
  meInvuln: 0,
  meRollT: 0,
  meRollDir: { x: 0, z: 1 },
  input: { x: 0, y: 0, lastX: 0, lastY: -1, pointerId: null },
  // シールド (ガード耐久)
  shieldMax: 30,
  shield: 30,
  shieldRegen: 4.5,           // /sec : 未使用時の回復速度
  shieldRegenDelay: 0.9,      // 被ダメやガード解除後、回復開始までの遅延
  shieldRegenT: 0,            // 遅延残り
  shieldBroken: false,        // 耐久ゼロで一時的にガード不可
  // 復活システム (HP0 時に発動)
  reviveLeft: 2,              // 復活可能回数 (初期2回)
  revive: null,               // { remain, needed, pressed, btnEl, btnTimer, nextSpawn, sabotageT, sabotageMsgT }
  enRevive: null,             // ボットの復活チャレンジ { remain, needed, pressed, pressTimer, recovering, recoverT, recoverDur, sabotageMsgT }
  totalWins: 0,
  proUnlocked: false,
  isPro: false,
  proChance: 0,
  enemyPowerMul: 1,
  enemyCooldownMul: 1,
  enemyPredictT: 0,
  enemyDodgeT: 0,
  enemyDodgeDir: { x: 0, z: 0 },
  enemyAfterimages: [],
  nextAfterimageT: 0,
  arenaRect: { minX:-5.6, maxX:5.6, minZ:-8.8, maxZ:8.8 },
  alleyColliders: [],
  meRagdoll: null,
  enRagdoll: null,
};

const BOXING_ATTACKS = {
  punch:  { label:'パンチ',  range:1.65, damage:[7, 9],   hitAt:0.10, total:0.26, cooldown:16, score:5,  color:'#ffb3b3', shieldDmg:6 },
  kick:   { label:'キック',  range:2.05, damage:[5, 5],   hitAt:0.18, total:0.36, cooldown:22, score:7,  color:'#ffe08f', shieldDmg:8 },
  tackle: { label:'タックル', range:1.95, damage:[10, 10], hitAt:0.22, total:0.50, cooldown:34, score:12, color:'#9fd3ff', shieldDmg:14, knockback:true },
};

const BOXING_PRO_WIN_THRESHOLD = 5;

function _getBoxingWinCount() {
  return parseInt(localStorage.getItem('garigari_boxing_wins') || '0', 10) || 0;
}
function _setBoxingWinCount(v) {
  localStorage.setItem('garigari_boxing_wins', String(Math.max(0, Math.floor(v))));
}
function _recordBoxingWin() {
  const wins = _getBoxingWinCount() + 1;
  _setBoxingWinCount(wins);
  return wins;
}
function _spawnEnemyAfterimage() {
  if (!Boxing.en) return;
  Boxing.enemyAfterimages.push({
    x: Boxing.en.position.x,
    z: Boxing.en.position.z,
    rotY: Boxing.en.rotation.y,
    pose: Boxing.enPose || 'move',
    anim: Boxing.enAnim || 0,
    life: 0.34,
    maxLife: 0.34,
  });
  if (Boxing.enemyAfterimages.length > 6) Boxing.enemyAfterimages.shift(); // 最大数を9→6に削減
}
function _disposeAfterimageEntry(g) {
  if (!g.mesh) return;
  if (g.mesh.parent) g.mesh.parent.remove(g.mesh);
  g.mesh.traverse(obj => {
    if (obj.geometry) try { obj.geometry.dispose(); } catch(e) {}
    if (obj.material) {
      const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
      mats.forEach(m => { try { m.dispose(); } catch(e) {} });
    }
  });
  g.mesh = null;
}
function _updateEnemyAfterimages(dt, time) {
  if (!Boxing.enemyAfterimages.length || !Boxing.scene || !Boxing.THREE) return;
  const next = [];
  for (let i = 0; i < Boxing.enemyAfterimages.length; i++) {
    const g = Boxing.enemyAfterimages[i];
    g.life -= dt;
    if (g.life <= 0) { _disposeAfterimageEntry(g); continue; }
    // 古いメッシュを破棄して毎フレーム再生成 (軽量版: 毎フレーム再生成は維持するが dispose を正しく実施)
    _disposeAfterimageEntry(g);
    const mesh = _buildJudoka(Boxing.THREE, 0xaef6ff, false);
    mesh.position.set(g.x, 0, g.z);
    mesh.rotation.y = g.rotY;
    mesh.scale.setScalar(0.985);
    const alpha = Math.max(0.08, Math.min(0.45, g.life / g.maxLife * 0.42));
    mesh.traverse(obj => {
      if (obj.isMesh && obj.material) {
        const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
        obj.material = mats.map(m => {
          const mm = m.clone();
          mm.transparent = true;
          mm.opacity = alpha;
          if (mm.color) mm.color.offsetHSL(0.02, -0.08, 0.16);
          return mm;
        });
      }
    });
    _animateJudoka(mesh, g.pose, g.anim, time);
    Boxing.scene.add(mesh);
    g.mesh = mesh;
    next.push(g);
  }
  Boxing.enemyAfterimages = next;
}
function _cleanupEnemyAfterimages() {
  if (!Boxing.enemyAfterimages) return;
  Boxing.enemyAfterimages.forEach(g => _disposeAfterimageEntry(g));
  Boxing.enemyAfterimages = [];
}
function _boxingStartEnemyDodge(reason) {
  if (!Boxing.en || Boxing.enemyDodgeT > 0 || Boxing.enAction || Boxing.mode !== 'fight') return false;
  const ang = Math.atan2(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
  const side = Math.random() < 0.5 ? -1 : 1;
  const backMul = reason === 'tackle' ? -0.85 : -0.45;
  const sideMul = reason === 'tackle' ? 1.45 : 1.2;
  const dx = Math.cos(ang) * side * sideMul + Math.sin(ang) * backMul;
  const dz = -Math.sin(ang) * side * sideMul + Math.cos(ang) * backMul;
  const len = Math.hypot(dx, dz) || 1;
  Boxing.enemyDodgeDir = { x: dx / len, z: dz / len };
  Boxing.enemyDodgeT = reason === 'tackle' ? 0.34 : 0.26;
  Boxing.nextAfterimageT = 0;
  Boxing.enPose = 'roll';
  Boxing.enAnim = 0;
  Boxing.enAction = null;
  _spawnEnemyAfterimage();
  _flashMsgBoxing(Boxing.isPro ? 'プロが先読み回避!' : 'CPUが先読み回避!', '#9fe7ff', 320);
  return true;
}


function _boxingClearRagdollEntry(entry) {
  if (!entry || !entry.parts) return;
  entry.parts.forEach(p => { if (p.mesh && p.mesh.parent) p.mesh.parent.remove(p.mesh); });
}

function _boxingClearAllRagdolls() {
  _boxingClearRagdollEntry(Boxing.meRagdoll);
  _boxingClearRagdollEntry(Boxing.enRagdoll);
  Boxing.meRagdoll = null;
  Boxing.enRagdoll = null;
  if (Boxing.me) { Boxing.me.visible = true; Boxing.me.position.y = 0; }
  if (Boxing.en) { Boxing.en.visible = true; Boxing.en.position.y = 0; }
}

function _boxingArenaProject(pos, radius) {
  const rect = Boxing.arenaRect || { minX:-4.2, maxX:4.2, minZ:-4.2, maxZ:4.2 };
  if (pos.x < rect.minX + radius) pos.x = rect.minX + radius;
  if (pos.x > rect.maxX - radius) pos.x = rect.maxX - radius;
  if (pos.z < rect.minZ + radius) pos.z = rect.minZ + radius;
  if (pos.z > rect.maxZ - radius) pos.z = rect.maxZ - radius;
}

function _boxingResolvePartWorld(part) {
  const bounce = part.bounce == null ? 0.22 : part.bounce;
  const floorY = part.radius;
  if (part.mesh.position.y < floorY) {
    part.mesh.position.y = floorY;
    if (part.vel.y < 0) part.vel.y = -part.vel.y * bounce;
    part.vel.x *= 0.78;
    part.vel.z *= 0.78;
    part.angVel.multiplyScalar(0.72);
  }
  _boxingArenaProject(part.mesh.position, part.radius);
  const walls = Boxing.alleyColliders || [];
  for (const c of walls) {
    const dx = part.mesh.position.x - c.x;
    const dz = part.mesh.position.z - c.z;
    const hx = c.hx + part.radius;
    const hz = c.hz + part.radius;
    if (Math.abs(dx) < hx && Math.abs(dz) < hz) {
      const ox = hx - Math.abs(dx);
      const oz = hz - Math.abs(dz);
      if (ox < oz) {
        part.mesh.position.x = c.x + (dx >= 0 ? 1 : -1) * hx;
        part.vel.x = (dx >= 0 ? 1 : -1) * Math.max(0.35, Math.abs(part.vel.x) * 0.35);
      } else {
        part.mesh.position.z = c.z + (dz >= 0 ? 1 : -1) * hz;
        part.vel.z = (dz >= 0 ? 1 : -1) * Math.max(0.35, Math.abs(part.vel.z) * 0.35);
      }
      part.angVel.multiplyScalar(0.86);
    }
  }
}

function _boxingSolveRagdollPairs(parts) {
  for (let i=0; i<parts.length; i++) {
    for (let j=i+1; j<parts.length; j++) {
      const a = parts[i], b = parts[j];
      const dx = b.mesh.position.x - a.mesh.position.x;
      const dy = b.mesh.position.y - a.mesh.position.y;
      const dz = b.mesh.position.z - a.mesh.position.z;
      let dist = Math.hypot(dx, dy, dz);
      const minDist = a.radius + b.radius;
      if (dist < 0.0001) {
        dist = 0.0001;
      }
      if (dist >= minDist) continue;
      const nx = dx / dist, ny = dy / dist, nz = dz / dist;
      const overlap = minDist - dist;
      const pushA = b.mass / (a.mass + b.mass);
      const pushB = a.mass / (a.mass + b.mass);
      a.mesh.position.x -= nx * overlap * pushA;
      a.mesh.position.y -= ny * overlap * pushA;
      a.mesh.position.z -= nz * overlap * pushA;
      b.mesh.position.x += nx * overlap * pushB;
      b.mesh.position.y += ny * overlap * pushB;
      b.mesh.position.z += nz * overlap * pushB;
      a.vel.addScaledVector(new Boxing.THREE.Vector3(-nx, -ny, -nz), overlap * 1.8 * pushA);
      b.vel.addScaledVector(new Boxing.THREE.Vector3(nx, ny, nz), overlap * 1.8 * pushB);
    }
  }
}

function _boxingSolveRagdollConstraints(entry) {
  if (!entry || !entry.constraints) return;
  for (const c of entry.constraints) {
    const a = c.a, b = c.b;
    const dx = b.mesh.position.x - a.mesh.position.x;
    const dy = b.mesh.position.y - a.mesh.position.y;
    const dz = b.mesh.position.z - a.mesh.position.z;
    let dist = Math.hypot(dx, dy, dz);
    if (dist < 0.0001) dist = 0.0001;
    const diff = (dist - c.rest) / dist;
    const stiffness = c.stiffness || 0.4;
    const nx = dx * diff * stiffness;
    const ny = dy * diff * stiffness;
    const nz = dz * diff * stiffness;
    const pushA = b.mass / (a.mass + b.mass);
    const pushB = a.mass / (a.mass + b.mass);
    a.mesh.position.x += nx * pushA;
    a.mesh.position.y += ny * pushA;
    a.mesh.position.z += nz * pushA;
    b.mesh.position.x -= nx * pushB;
    b.mesh.position.y -= ny * pushB;
    b.mesh.position.z -= nz * pushB;
  }
}

function _boxingRecoverRagdoll(side) {
  const key = side === 'me' ? 'meRagdoll' : 'enRagdoll';
  const entry = Boxing[key];
  if (!entry) return;
  const anchor = entry.parts.find(p => p.name === 'torso') || entry.parts[0];
  if (entry.fighter) {
    entry.fighter.visible = true;
    entry.fighter.position.set(anchor.mesh.position.x, 0, anchor.mesh.position.z);
    _boxingClampArena(entry.fighter);
    entry.fighter.position.y = 0;
  }
  _boxingClearRagdollEntry(entry);
  Boxing[key] = null;
  if (side === 'me') {
    Boxing.mePose = 'idle';
    Boxing.meAnim = 0;
    Boxing.meInvuln = 0.55;
    Boxing.attackCD = Math.max(Boxing.attackCD, 26);
    Boxing.meGuard = false;
  } else {
    Boxing.enPose = 'idle';
    Boxing.enAnim = 0;
    Boxing.enemyAtkCD = Math.max(Boxing.enemyAtkCD, 34);
    Boxing.enemyDodgeT = 0;
  }
}

function _boxingSpawnRagdoll(side, impulse, duration) {
  const fighter = side === 'me' ? Boxing.me : Boxing.en;
  if (!fighter || !fighter._parts || !Boxing.scene || !Boxing.THREE) return null;
  const key = side === 'me' ? 'meRagdoll' : 'enRagdoll';
  if (Boxing[key]) return Boxing[key];
  fighter.updateMatrixWorld(true);
  const names = ['torso', 'head', 'armL', 'armR', 'legL', 'legR'];
  const parts = [];
  const partMap = {};
  const baseImpulse = impulse || { x:0, y:2.2, z:0 };
  names.forEach((name, idx) => {
    const src = fighter._parts[name];
    if (!src) return;
    const mesh = src.clone(true);
    mesh.traverse(obj => {
      if (obj.isMesh && obj.material) {
        // 単一マテリアルを配列に包むと BoxGeometry の他5面が無描画になる（消える）バグを回避
        if (Array.isArray(obj.material)) {
          obj.material = obj.material.map(m => m.clone());
        } else {
          obj.material = obj.material.clone();
        }
        obj.castShadow = true;
        obj.receiveShadow = true;
        obj.frustumCulled = false;
        obj.visible = true;
      }
    });
    mesh.visible = true;
    const wp = new Boxing.THREE.Vector3();
    const wq = new Boxing.THREE.Quaternion();
    src.getWorldPosition(wp);
    src.getWorldQuaternion(wq);
    mesh.position.copy(wp);
    mesh.quaternion.copy(wq);
    Boxing.scene.add(mesh);
    const part = {
      name,
      mesh,
      radius: fighter._partRadii?.[name] || (name === 'torso' ? 0.34 : 0.2),
      mass: name === 'torso' ? 2.4 : name === 'head' ? 1.2 : 0.9,
      vel: new Boxing.THREE.Vector3(
        baseImpulse.x + (Math.random() - 0.5) * 0.7,
        baseImpulse.y + (name === 'head' ? 0.55 : 0.25) + Math.random() * 0.35,
        baseImpulse.z + (Math.random() - 0.5) * 0.7
      ),
      // 腕・脚の角速度は控えめにして「腕がすごいことになる」のを防ぐ
      angVel: new Boxing.THREE.Vector3(
        (Math.random() - 0.5) * (name === 'torso' ? 2.4 : 1.6),
        (Math.random() - 0.5) * (name === 'torso' ? 2.4 : 1.6),
        (Math.random() - 0.5) * (name === 'torso' ? 2.4 : 1.6)
      ),
      bounce: name === 'head' ? 0.28 : 0.2,
    };
    parts.push(part);
    partMap[name] = part;
  });
  // スティフネスを少し緩めて、ペア衝突との両立を図る
  const link = (a, b, stiff=0.55) => {
    if (!partMap[a] || !partMap[b]) return null;
    return {
      a: partMap[a],
      b: partMap[b],
      rest: partMap[a].mesh.position.distanceTo(partMap[b].mesh.position),
      stiffness: stiff,
    };
  };
  const constraints = [
    link('torso', 'head', 0.65),
    link('torso', 'armL', 0.55),
    link('torso', 'armR', 0.55),
    link('torso', 'legL', 0.6),
    link('torso', 'legR', 0.6),
    // 頭⇔腕 / 腕⇔脚の直接拘束は外す(胴体を介してつながる)。これで腕の暴れが収まる
  ].filter(Boolean);
  const entry = {
    side,
    fighter,
    parts,
    constraints,
    remain: duration || 1.35,
  };
  fighter.visible = false;
  fighter.position.y = 0;
  if (side === 'me') {
    Boxing.meAction = null;
    Boxing.meRollT = 0;
    Boxing.meGuard = false;
    Boxing.mePose = 'down';
    Boxing.meAnim = 0;
    Boxing.meRagdoll = entry;
  } else {
    Boxing.enAction = null;
    Boxing.enemyDodgeT = 0;
    Boxing.enPose = 'down';
    Boxing.enAnim = 0;
    Boxing.enRagdoll = entry;
  }
  return entry;
}

function _boxingHitRagdoll(entry, impulse) {
  if (!entry || !entry.parts || !entry.parts.length) return;
  const ix = impulse?.x || 0;
  const iy = impulse?.y || 0.6;
  const iz = impulse?.z || 0;
  entry.parts.forEach((p, idx) => {
    const mul = p.name === 'torso' ? 1 : (p.name === 'head' ? 0.9 : 1.15);
    p.vel.x += ix * mul * (idx === 0 ? 1 : 0.65);
    p.vel.y += iy * mul * 0.55;
    p.vel.z += iz * mul * (idx === 0 ? 1 : 0.65);
  });
  entry.remain = Math.max(entry.remain, 0.6);
}

function _boxingUpdateRagdollEntry(entry, dt) {
  if (!entry || !entry.parts) return;
  entry.remain -= dt;
  const grav = 20;
  entry.parts.forEach(p => {
    p.vel.y -= grav * dt;
    p.mesh.position.x += p.vel.x * dt;
    p.mesh.position.y += p.vel.y * dt;
    p.mesh.position.z += p.vel.z * dt;
    p.mesh.rotation.x += p.angVel.x * dt;
    p.mesh.rotation.y += p.angVel.y * dt;
    p.mesh.rotation.z += p.angVel.z * dt;
  });
  // 遅延 0: 反復回数を大幅に増やして四肢を胴体に即追従させる
  for (let iter=0; iter<8; iter++) {
    _boxingSolveRagdollPairs(entry.parts);
    _boxingSolveRagdollConstraints(entry);
    entry.parts.forEach(_boxingResolvePartWorld);
  }
  entry.parts.forEach(p => {
    p.vel.x *= (1 - dt * 2.6);
    p.vel.z *= (1 - dt * 2.6);
    p.angVel.multiplyScalar(Math.max(0, 1 - dt * 5.0)); const maxAng=6.0; if (p.angVel.lengthSq() > maxAng*maxAng) p.angVel.setLength(maxAng);
  });
  const torso = entry.parts.find(p => p.name === 'torso') || entry.parts[0];
  if (entry.fighter && torso) {
    entry.fighter.position.x = torso.mesh.position.x;
    entry.fighter.position.z = torso.mesh.position.z;
    _boxingClampArena(entry.fighter);
  }
  if (entry.remain <= 0) _boxingRecoverRagdoll(entry.side);
}

function _boxingUpdateRagdolls(dt) {
  if (Boxing.meRagdoll) _boxingUpdateRagdollEntry(Boxing.meRagdoll, dt);
  if (Boxing.enRagdoll) _boxingUpdateRagdollEntry(Boxing.enRagdoll, dt);
}


function _ensureThreeBoxing() {
  if (Boxing.THREE) return Promise.resolve(Boxing.THREE);
  return window.loadThreeWithRetry().then(THREE => { Boxing.THREE = THREE; return THREE; });
}

function startBoxing() {
  _ensureThreeBoxing().then(THREE => _initBoxing(THREE)).catch(err => {
    console.error(err);
    showToast('Three.js の読み込みに失敗しました');
  });
}

function _initBoxing(THREE) {
  _disposeBoxing();

  Boxing.container = $('#boxingThree');
  const w = Boxing.container.clientWidth || window.innerWidth;
  const h = Boxing.container.clientHeight || 400;

  Boxing.scene = new THREE.Scene();
  Boxing.scene.background = new THREE.Color(0x0c0810);
  Boxing.scene.fog = new THREE.Fog(0x0c0810, 9, 26);

  Boxing.camera = new THREE.PerspectiveCamera(58, w/h, 0.1, 100);
  Boxing.camera.position.set(0, 2.4, 4.8);

  const _bxMobile = /Mobi|Android/i.test(navigator.userAgent);
  Boxing.renderer = new THREE.WebGLRenderer({ antialias: !_bxMobile, alpha:false, powerPreference:'high-performance' });
  Boxing.renderer.setPixelRatio(Math.min(window.devicePixelRatio, _bxMobile ? 1 : 1.5));
  Boxing.renderer.setSize(w, h);
  Boxing.renderer.shadowMap.enabled = true;
  Boxing.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  Boxing.container.innerHTML = '';
  Boxing.container.appendChild(Boxing.renderer.domElement);

  const amb = new THREE.AmbientLight(0xffffff, 0.55);
  Boxing.scene.add(amb);
  const dir = new THREE.DirectionalLight(0xffd6a8, 1.3);
  dir.position.set(5, 8, 6);
  dir.castShadow = true;
  dir.shadow.mapSize.set(512, 512);
  dir.shadow.camera.left = -8; dir.shadow.camera.right = 8;
  dir.shadow.camera.top = 8; dir.shadow.camera.bottom = -8;
  dir.shadow.autoUpdate = false;
  dir.shadow.needsUpdate = true;
  Boxing.scene.add(dir);
  const rim = new THREE.DirectionalLight(0xff7e8e, 0.5);
  rim.position.set(-6, 3, -4);
  Boxing.scene.add(rim);

  Boxing.scene.background = new THREE.Color(0x090c12);
  Boxing.scene.fog = new THREE.Fog(0x090c12, 8, 30);

  const floor = new THREE.Mesh(
    new THREE.PlaneGeometry(14.4, 22.0),
    new THREE.MeshStandardMaterial({ color: 0x262a31, roughness: 0.97, metalness: 0.05 })
  );
  floor.rotation.x = -Math.PI/2;
  floor.receiveShadow = true;
  Boxing.scene.add(floor);

  const lanePaint = new THREE.Mesh(
    new THREE.PlaneGeometry(0.18, 18.2),
    new THREE.MeshStandardMaterial({ color: 0xd7c37a, roughness: 1 })
  );
  lanePaint.rotation.x = -Math.PI/2;
  lanePaint.position.set(0, 0.01, 0);
  Boxing.scene.add(lanePaint);

  const puddleMat = new THREE.MeshStandardMaterial({ color: 0x1a2332, roughness: 0.15, metalness: 0.45 });
  [[-1.8, 1.9, 1.2, 0.8], [1.55, -1.6, 1.0, 0.7], [0.7, 3.3, 0.7, 0.45]].forEach(([x,z,wz,zz]) => {
    const puddle = new THREE.Mesh(new THREE.PlaneGeometry(wz, zz), puddleMat);
    puddle.rotation.x = -Math.PI/2;
    puddle.position.set(x, 0.015, z);
    Boxing.scene.add(puddle);
  });

  const wallMat = new THREE.MeshStandardMaterial({ color:0x1a1d25, roughness:0.95 });
  const brickMat = new THREE.MeshStandardMaterial({ color:0x3a2b28, roughness:0.98 });
  const fenceMat = new THREE.MeshStandardMaterial({ color:0x535b66, roughness:0.55, metalness:0.4 });
  const wallL = new THREE.Mesh(new THREE.BoxGeometry(0.42, 4.8, 22.4), brickMat);
  wallL.position.set(-6.95, 2.4, 0); wallL.receiveShadow = true; wallL.castShadow = true; Boxing.scene.add(wallL);
  const wallR = new THREE.Mesh(new THREE.BoxGeometry(0.42, 4.8, 22.4), wallMat);
  wallR.position.set(6.95, 2.4, 0); wallR.receiveShadow = true; wallR.castShadow = true; Boxing.scene.add(wallR);
  const backWall = new THREE.Mesh(new THREE.BoxGeometry(13.5, 4.8, 0.42), wallMat);
  backWall.position.set(0, 2.4, -9.55); backWall.receiveShadow = true; backWall.castShadow = true; Boxing.scene.add(backWall);
  const frontWall = new THREE.Mesh(new THREE.BoxGeometry(13.5, 3.2, 0.3), new THREE.MeshStandardMaterial({ color:0x111317, roughness:1 }));
  frontWall.position.set(0, 1.6, 9.55); frontWall.receiveShadow = true; Boxing.scene.add(frontWall);

  const fence = new THREE.Mesh(new THREE.PlaneGeometry(3.6, 2.3), fenceMat);
  fence.position.set(5.4, 1.6, -6.5);
  fence.rotation.y = -Math.PI * 0.08;
  Boxing.scene.add(fence);

  const lampPole = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.08, 4.8, 12), new THREE.MeshStandardMaterial({ color:0x2b2d31, roughness:0.8, metalness:0.2 }));
  lampPole.position.set(-5.4, 2.4, -4.3); lampPole.castShadow = true; Boxing.scene.add(lampPole);
  const lamp = new THREE.Mesh(new THREE.BoxGeometry(0.55, 0.18, 0.38), new THREE.MeshStandardMaterial({ color:0xffd89b, emissive:0xffaa55, emissiveIntensity:0.45 }));
  lamp.position.set(-5.1, 4.18, -4.3); Boxing.scene.add(lamp);
  const lampGlow = new THREE.PointLight(0xffb46a, 1.2, 12, 2);
  lampGlow.position.set(-5.1, 4.0, -4.3); Boxing.scene.add(lampGlow);

  const dumpsterMat = new THREE.MeshStandardMaterial({ color:0x245043, roughness:0.8, metalness:0.15 });
  const dumpster1 = new THREE.Mesh(new THREE.BoxGeometry(1.45, 1.05, 0.85), dumpsterMat);
  dumpster1.position.set(-4.85, 0.52, 4.1); dumpster1.castShadow = true; dumpster1.receiveShadow = true; Boxing.scene.add(dumpster1);
  const dumpster2 = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.95, 0.78), dumpsterMat);
  dumpster2.position.set(4.55, 0.48, -0.85); dumpster2.castShadow = true; dumpster2.receiveShadow = true; Boxing.scene.add(dumpster2);

  const trashMat = new THREE.MeshStandardMaterial({ color:0x88836c, roughness:0.92 });
  [[-3.55, 0.22, 1.8], [3.25, 0.22, 3.8], [1.85, 0.22, -4.8], [-1.9, 0.22, -2.9]].forEach(([x,y,z], idx) => {
    const bag = new THREE.Mesh(new THREE.SphereGeometry(0.22 + (idx % 2) * 0.06, 10, 8), trashMat);
    bag.scale.set(1.0, 0.8, 1.15);
    bag.position.set(x, y, z);
    bag.castShadow = true;
    Boxing.scene.add(bag);
  });

  Boxing.alleyColliders = [
    { x:-4.85, z:4.1,  hx:0.82, hz:0.52 },
    { x: 4.55, z:-0.85, hx:0.68, hz:0.48 },
    { x:-6.95, z:0.0, hx:0.21, hz:11.2 },
    { x: 6.95, z:0.0, hx:0.21, hz:11.2 },
    { x: 0.0, z:-9.55, hx:6.75, hz:0.21 },
    { x: 0.0, z: 9.55, hx:6.75, hz:0.15 },
  ];

  // キャラクター(柔道と同ジオメトリ、色分けは青紅)
  Boxing.me = _buildJudoka(THREE, 0x3d7bff, false);
  Boxing.me.position.set(-2.4, 0, 3.6);
  Boxing.scene.add(Boxing.me);

  Boxing.en = _buildJudoka(THREE, 0xcc4444, false);
  Boxing.en.position.set(2.4, 0, -2.2);
  Boxing.scene.add(Boxing.en);

  Boxing.meHP = 100; Boxing.enHP = 100; Boxing.score = 0;
  Boxing.mePose = 'idle'; Boxing.enPose = 'idle';
  Boxing.mode = 'fight';
  Boxing.meAnim = 0; Boxing.enAnim = 0;
  Boxing.attackCD = 0; Boxing.enemyAtkCD = 45;
  Boxing.shakeT = 0;
  Boxing.meAction = null; Boxing.enAction = null;
  Boxing.meGuard = false; Boxing.meInvuln = 0; Boxing.meRollT = 0;
  Boxing.meRollDir = { x: 0, z: 1 };
  Boxing.input = { x: 0, y: 0, lastX: 0, lastY: -1, pointerId: null };
  Boxing.shield = Boxing.shieldMax;
  Boxing.shieldRegenT = 0;
  Boxing.shieldBroken = false;
  // 復活システム初期化（リバイブは 2 回まで）
  Boxing.reviveLeft = 2;
  Boxing.revive = null;
  Boxing.enRevive = null;
  const enBar0 = document.getElementById('boxingEnemyReviveStatus'); if (enBar0) enBar0.style.display = 'none';
  Boxing.totalWins = _getBoxingWinCount();
  Boxing.proUnlocked = Boxing.totalWins >= BOXING_PRO_WIN_THRESHOLD;
  Boxing.isPro = Boxing.proUnlocked && Math.random() < 0.45;
  Boxing.proChance = Boxing.proUnlocked ? 0.45 : 0;
  Boxing.enemyPowerMul = Boxing.isPro ? 1.7 : 1;
  Boxing.enemyCooldownMul = Boxing.isPro ? 0.62 : 1;
  Boxing.enemyPredictT = 0;
  Boxing.enemyDodgeT = 0;
  Boxing.enemyDodgeDir = { x: 0, z: 0 };
  Boxing.arenaRect = { minX:-5.6, maxX:5.6, minZ:-8.8, maxZ:8.8 };
  _boxingClearAllRagdolls();
  _cleanupEnemyAfterimages();
  Boxing.nextAfterimageT = 0;
  const rl0 = $('#boxingReviveLayer'); if (rl0) { rl0.style.display = 'none'; rl0.style.pointerEvents = 'none'; }
  const rs0 = $('#boxingReviveStatus'); if (rs0) rs0.style.display = 'none';

  $('#boxingInfo').textContent = Boxing.isPro
    ? '対戦相手: プロCPU / 路地裏で先読み回避'
    : (Boxing.proUnlocked
        ? '対戦相手: CPU / 路地裏・連勝でまれにプロ出現'
        : '対戦相手: CPU / 路地裏ロックオン');
  $('#boxingCenterMsg').style.display = 'none';
  updateBoxingHUD();
  _bindBoxingControls();

  window.addEventListener('resize', _resizeBoxing);
  Boxing.running = true;
  Boxing.lastT = performance.now();
  Boxing.raf = requestAnimationFrame(_boxingLoop);
}

function _resizeBoxing() {
  if (!Boxing.container || !Boxing.renderer || !Boxing.camera) return;
  const w = Boxing.container.clientWidth || window.innerWidth;
  const h = Boxing.container.clientHeight || 400;
  Boxing.renderer.setSize(w, h);
  Boxing.camera.aspect = w / h;
  Boxing.camera.updateProjectionMatrix();
}

function updateBoxingHUD() {
  $('#boxingHpMe').textContent = Math.max(0, Math.round(Boxing.meHP));
  $('#boxingHpEn').textContent = Math.max(0, Math.round(Boxing.enHP));
  $('#boxingScore').textContent = Boxing.score;
}

// ガード耐久UI をモデルの横に表示
const _shieldVec3 = { x: 0, y: 0, z: 0, project: null }; // 遅延初期化
function _updateShieldUI() {
  const ring = $('#boxingShieldRing');
  const arc = $('#boxingShieldArc');
  const txt = $('#boxingShieldTxt');
  if (!ring || !arc || !txt) return;

  // ガード中 or 耐久が減っている間は表示、満タンなら隠す
  const shouldShow = Boxing.running && (Boxing.mode === 'fight' || Boxing.mode === 'enemyRevive') && (Boxing.meGuard || Boxing.shield < Boxing.shieldMax - 0.01 || Boxing.shieldBroken);
  if (!shouldShow) { ring.style.display = 'none'; return; }
  if (!Boxing.me || !Boxing.camera || !Boxing.renderer) { ring.style.display = 'none'; return; }

  // Vector3 を毎フレーム new せずキャッシュ
  if (!Boxing._shieldVec) Boxing._shieldVec = new Boxing.THREE.Vector3();
  const vec = Boxing._shieldVec;
  vec.set(Boxing.me.position.x, 1.6, Boxing.me.position.z);
  vec.project(Boxing.camera);
  const rect = Boxing.renderer.domElement.getBoundingClientRect();
  const stageRect = $('#boxingStage').getBoundingClientRect();
  const sx = rect.left - stageRect.left + (vec.x * 0.5 + 0.5) * rect.width;
  const sy = rect.top  - stageRect.top  + (-vec.y * 0.5 + 0.5) * rect.height;

  ring.style.display = 'block';
  // モデルの右横にオフセット
  ring.style.left = (sx + 36) + 'px';
  ring.style.top  = (sy - 30) + 'px';

  const ratio = Math.max(0, Math.min(1, Boxing.shield / Boxing.shieldMax));
  const circ = 2 * Math.PI * 22; // 半径22
  arc.setAttribute('stroke-dasharray', circ.toFixed(2) + ' ' + circ.toFixed(2));
  arc.setAttribute('stroke-dashoffset', (circ * (1 - ratio)).toFixed(2));
  // 色: 満=緑、中間=黄、低=赤、ブレイク=グレー
  let col = '#6fe39a';
  if (Boxing.shieldBroken) col = '#888';
  else if (ratio < 0.33) col = '#ff7a7a';
  else if (ratio < 0.66) col = '#ffd76b';
  arc.setAttribute('stroke', col);
  txt.textContent = Math.max(0, Math.ceil(Boxing.shield));
}

function _flashMsgBoxing(text, color, ms) {
  const el = $('#boxingCenterMsg');
  el.innerHTML = String(text).replace(/\n/g, '<br>');
  el.style.color = color || '#fff';
  el.style.display = 'block';
  clearTimeout(Boxing._msgT);
  Boxing._msgT = setTimeout(()=>{ if (Boxing.mode !== 'result') el.style.display='none'; }, ms || 700);
}

function _bindBoxingControls() {
  const zone = $('#boxingStickZone');
  const base = $('#boxingStickBase');
  const knob = $('#boxingStickKnob');
  const maxR = 46;

  function updateStick(clientX, clientY) {
    const rect = base.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    let dx = clientX - cx;
    let dy = clientY - cy;
    const len = Math.hypot(dx, dy) || 1;
    if (len > maxR) { dx = dx / len * maxR; dy = dy / len * maxR; }
    knob.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
    Boxing.input.x = dx / maxR;
    Boxing.input.y = dy / maxR;
    const m = Math.hypot(Boxing.input.x, Boxing.input.y);
    if (m > 0.14) {
      Boxing.input.lastX = Boxing.input.x;
      Boxing.input.lastY = Boxing.input.y;
    }
  }
  function resetStick() {
    Boxing.input.pointerId = null;
    Boxing.input.x = 0;
    Boxing.input.y = 0;
    knob.style.transform = 'translate(-50%, -50%)';
  }

  zone.onpointerdown = e => {
    e.preventDefault();
    Boxing.input.pointerId = e.pointerId;
    zone.setPointerCapture?.(e.pointerId);
    updateStick(e.clientX, e.clientY);
  };
  zone.onpointermove = e => {
    if (Boxing.input.pointerId !== e.pointerId) return;
    e.preventDefault();
    updateStick(e.clientX, e.clientY);
  };
  zone.onpointerup = e => {
    if (Boxing.input.pointerId !== e.pointerId) return;
    e.preventDefault();
    resetStick();
  };
  zone.onpointercancel = resetStick;
  zone.onpointerleave = e => {
    if (Boxing.input.pointerId !== e.pointerId) return;
    resetStick();
  };

  $('#bxBtnPunch').onclick  = () => _boxingPlayerAction('punch');
  $('#bxBtnKick').onclick   = () => _boxingPlayerAction('kick');
  $('#bxBtnTackle').onclick = () => _boxingPlayerAction('tackle');
  $('#bxBtnRoll').onclick   = () => _boxingStartRoll();

  const guardBtn = $('#bxBtnGuard');
  const guardOn = e => {
    e.preventDefault();
    _boxingSetGuard(true);
    guardBtn.style.transform = 'scale(0.96)';
    guardBtn.style.background = 'rgba(72,175,120,0.38)';
  };
  const guardOff = e => {
    if (e) e.preventDefault();
    _boxingSetGuard(false);
    guardBtn.style.transform = '';
    guardBtn.style.background = 'rgba(72,175,120,0.22)';
  };
  guardBtn.onpointerdown = guardOn;
  guardBtn.onpointerup = guardOff;
  guardBtn.onpointerleave = guardOff;
  guardBtn.onpointercancel = guardOff;
}

function _boxingSetGuard(on) {
  if (!Boxing.running || Boxing.mode !== 'fight') return;
  if (Boxing.meRagdoll) on = false;
  if (Boxing.meRollT > 0 || Boxing.meAction) on = false;
  if (Boxing.shieldBroken) on = false;
  Boxing.meGuard = !!on;
  if (!Boxing.meAction && Boxing.meRollT <= 0) {
    Boxing.mePose = Boxing.meGuard ? 'guard' : (Math.hypot(Boxing.input.x, Boxing.input.y) > 0.1 ? 'move' : 'idle');
    Boxing.meAnim = 0;
  }
  // ガードを離したら回復遅延をリセット
  if (!Boxing.meGuard) Boxing.shieldRegenT = Math.max(Boxing.shieldRegenT, Boxing.shieldRegenDelay);
}

function _boxingPlayerAction(kind) {
  if (!Boxing.running || (Boxing.mode !== 'fight' && Boxing.mode !== 'enemyRevive')) return;
  if (Boxing.meRagdoll) return;
  if (Boxing.attackCD > 0 || Boxing.meRollT > 0 || Boxing.meAction) return;
  const spec = BOXING_ATTACKS[kind];
  if (!spec) return;
  Boxing.meGuard = false;
  Boxing.mePose = kind;
  Boxing.meAnim = 0;
  Boxing.attackCD = spec.cooldown;
  Boxing.meAction = { side:'me', kind, t:0, hitDone:false, ...spec };
}

function _boxingStartRoll() {
  if (!Boxing.running || (Boxing.mode !== 'fight' && Boxing.mode !== 'enemyRevive')) return;
  if (Boxing.meRagdoll) return;
  if (Boxing.attackCD > 0 || Boxing.meAction || Boxing.meRollT > 0) return;
  const v = _boxingGetMoveVector(
    Math.abs(Boxing.input.x) > 0.08 ? Boxing.input.x : Boxing.input.lastX,
    Math.abs(Boxing.input.y) > 0.08 ? Boxing.input.y : Boxing.input.lastY
  );
  let x = v.x, z = v.z;
  if (Math.hypot(x, z) < 0.01) {
    const ang = Boxing.me.rotation.y;
    x = Math.sin(ang); z = Math.cos(ang);
  }
  const len = Math.hypot(x, z) || 1;
  Boxing.meRollDir = { x:x/len, z:z/len };
  Boxing.meRollT = 0.42;
  Boxing.meInvuln = 0.34;
  Boxing.meGuard = false;
  Boxing.mePose = 'roll';
  Boxing.meAnim = 0;
  Boxing.attackCD = 22;
  Boxing.meAction = null;
}

function _boxingStartEnemyAction(kind) {
  const spec = BOXING_ATTACKS[kind];
  if (!spec || Boxing.enAction || Boxing.enRagdoll || Boxing.mode !== 'fight') return;
  Boxing.enPose = kind;
  Boxing.enAnim = 0;
  const powerMul = Boxing.enemyPowerMul || 1;
  const cdMul = Boxing.enemyCooldownMul || 1;
  Boxing.enAction = {
    side:'en', kind,
    label:(Boxing.isPro ? 'プロ' : '敵') + spec.label,
    range: spec.range + (kind === 'tackle' ? 0.18 : 0.04),
    damage:[Math.max(3, (spec.damage[0]-1) * powerMul), Math.max(3, (spec.damage[1]-1) * powerMul)],
    hitAt: Math.max(0.06, (spec.hitAt + 0.07) * cdMul),
    total: Math.max(0.16, (spec.total + 0.12) * cdMul),
    cooldown: Math.max(8, (spec.cooldown + 12) * cdMul),
    color: Boxing.isPro ? '#ff8ad8' : '#ffb08f',
    score:0,
    knockback: !!spec.knockback,
    shieldDmg: Math.round((spec.shieldDmg || 6) * (Boxing.isPro ? 1.25 : 1)),
    t:0,
    hitDone:false,
  };
  Boxing.enemyAtkCD = Math.max(8, (spec.cooldown + 28 + Math.random()*24) * cdMul);
}

function _boxingApplyHit(action) {
  const from = action.side === 'me' ? Boxing.me : Boxing.en;
  const to   = action.side === 'me' ? Boxing.en : Boxing.me;
  const targetEntry = action.side === 'me' ? Boxing.enRagdoll : Boxing.meRagdoll;
  if (targetEntry) {
    const dx0 = (targetEntry.fighter?.position.x || 0) - from.position.x;
    const dz0 = (targetEntry.fighter?.position.z || 0) - from.position.z;
    const dl0 = Math.hypot(dx0, dz0) || 1;
    _boxingHitRagdoll(targetEntry, { x: dx0 / dl0 * 2.4, y: 1.05, z: dz0 / dl0 * 2.4 });
    return;
  }
  if (!from || !to) return;

  const dist = Math.hypot(from.position.x - to.position.x, from.position.z - to.position.z);
  if (dist > action.range) {
    if (action.side === 'me') _flashMsgBoxing(action.label + ' 空振り', '#cfd8dc', 320);
    return;
  }

  const dmg = _randRange(action.damage[0], action.damage[1]);
  const dx = to.position.x - from.position.x;
  const dz = to.position.z - from.position.z;
  const dl = Math.hypot(dx, dz) || 1;
  // タックルはノックバック大、キック/パンチは控えめ
  const push = action.kind === 'tackle' ? 0.85 : action.kind === 'kick' ? 0.28 : 0.18;

  if (action.side === 'me') {
    // ボットの復活チャレンジ中は、プレイヤーの攻撃はサボタージとして作用する
    if (Boxing.mode === 'enemyRevive') {
      _enemyRevivePlayerSabotage(action);
      Boxing.score += Math.max(1, Math.floor(action.score * 0.5));
      Boxing.shakeT = action.kind === 'tackle' ? 10 : 5;
      return;
    }
    Boxing.enHP = Math.max(0, Boxing.enHP - dmg);
    Boxing.score += action.score;
    to.position.x += dx / dl * push;
    to.position.z += dz / dl * push;
    _boxingClampArena(to);
    _resolveBoxingCollision(0.15, 0.6);
    if (action.kind === 'tackle') {
      _boxingSpawnRagdoll('en', { x: dx / dl * 3.2, y: 2.2, z: dz / dl * 3.2 }, 1.25);
      _flashMsgBoxing(action.label + ' で吹っ飛ばした!', '#9fd3ff', 460);
    } else {
      Boxing.shakeT = action.kind === 'tackle' ? 12 : 6;
      _flashMsgBoxing(action.label + ' ヒット!', action.color, 420);
    }
  } else {
    // 復活チャレンジ中はプレイヤーは誘いダメージを受けない（すでに KO 状態）
    if (Boxing.mode === 'revive') return;
    if (Boxing.meInvuln > 0) {
      Boxing.score += 2;
      _flashMsgBoxing('回避成功!', '#8fd9ff', 320);
      return;
    }
    const wasGuarding = Boxing.meGuard && !Boxing.shieldBroken;
    // ガード処理: 耐久を削り、あふれた分は辛うじてダメージに回る
    if (wasGuarding) {
      const sDmg = action.shieldDmg || 6;
      const absorb = Math.min(Boxing.shield, sDmg);
      Boxing.shield = Math.max(0, Boxing.shield - sDmg);
      // 同じヒットで耐久ゼロになったらシールドブレイク
      const guardEfficiency = absorb / sDmg; // 1.0なら完全ガード、不足した分はもろに貫通
      const blockedRate = action.kind === 'tackle' ? 0.55 : 0.18;
      const finalDmg = dmg * (guardEfficiency * blockedRate + (1 - guardEfficiency) * 1.0);
      Boxing.meHP = Math.max(0, Boxing.meHP - finalDmg);
      Boxing.shieldRegenT = Boxing.shieldRegenDelay; // 被ダメで回復遅延
      if (Boxing.shield <= 0) {
        Boxing.shieldBroken = true;
        Boxing.meGuard = false;
        _flashMsgBoxing('シールドブレイク!', '#ff8c8c', 520);
        Boxing.shakeT = 12;
      } else {
        _flashMsgBoxing('ガード!', '#8cffb0', 240);
        Boxing.shakeT = 4;
      }
      // タックルはノックバックをガードしてもやや受ける
      if (action.knockback) {
        Boxing.me.position.x -= dx / dl * push * 0.55;
        Boxing.me.position.z -= dz / dl * push * 0.55;
        _boxingClampArena(Boxing.me);
        _resolveBoxingCollision(0.58, 0.12);
        if (action.kind === 'tackle' && Boxing.shieldBroken) {
          _boxingSpawnRagdoll('me', { x:-dx / dl * 2.7, y: 2.0, z:-dz / dl * 2.7 }, 1.1);
          Boxing.shakeT = 14;
          _flashMsgBoxing('タックルで崩された!', '#ff9e9e', 520);
        }
      }
    } else {
      Boxing.meHP = Math.max(0, Boxing.meHP - dmg);
      Boxing.me.position.x -= dx / dl * push * 0.95;
      Boxing.me.position.z -= dz / dl * push * 0.95;
      _boxingClampArena(Boxing.me);
      _resolveBoxingCollision(0.6, 0.12);
      if (action.kind === 'tackle') {
        _boxingSpawnRagdoll('me', { x:-dx / dl * 3.1, y: 2.2, z:-dz / dl * 3.1 }, 1.2);
        Boxing.shakeT = 16;
        _flashMsgBoxing(action.label + ' で転倒!', '#ff9595', 520);
      } else {
        Boxing.shakeT = action.kind === 'tackle' ? 14 : 8;
        _flashMsgBoxing(action.label + ' 被弾!', '#ff9595', 420);
      }
    }
  }
  updateBoxingHUD();
}

function _boxingUpdateAction(action, dt) {
  if (!action) return null;
  action.t += dt;
  if (action.kind === 'tackle') {
    const actor = action.side === 'me' ? Boxing.me : Boxing.en;
    const target = action.side === 'me' ? Boxing.en : Boxing.me;
    const ang = Math.atan2(target.position.x - actor.position.x, target.position.z - actor.position.z);
    const rush = action.t < action.hitAt ? 3.6 : 1.7;
    actor.position.x += Math.sin(ang) * rush * dt;
    actor.position.z += Math.cos(ang) * rush * dt;
    _boxingClampArena(actor);
    _resolveBoxingCollision(action.side === 'me' ? 0.18 : 0.52, action.side === 'me' ? 0.52 : 0.18);
  }
  if (!action.hitDone && action.t >= action.hitAt) {
    action.hitDone = true;
    _boxingApplyHit(action);
  }
  if (action.t >= action.total) return null;
  return action;
}

function _boxingEnemyThink(dt, time) {
  if (Boxing.enAction || Boxing.enRagdoll || Boxing.mode !== 'fight') return;
  const dist = Math.hypot(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
  const ang = Math.atan2(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);

  const playerAction = Boxing.meAction;
  const predictWindow = playerAction && playerAction.t < playerAction.hitAt + 0.04;
  const incomingDist = playerAction ? playerAction.range + (playerAction.kind === 'tackle' ? 0.35 : 0.18) : 0;
  const dodgeProb = Boxing.isPro ? (playerAction?.kind === 'tackle' ? 0.94 : 0.82) : (playerAction?.kind === 'tackle' ? 0.55 : 0.36);
  if (predictWindow && dist < incomingDist && Math.random() < dodgeProb) {
    if (_boxingStartEnemyDodge(playerAction.kind)) return;
  }

  const baseSpeed = Boxing.enemySpeed * (Boxing.isPro ? 1.42 : 1);
  if (dist > (Boxing.isPro ? 1.58 : 1.72)) {
    Boxing.en.position.x += Math.sin(ang) * baseSpeed * dt;
    Boxing.en.position.z += Math.cos(ang) * baseSpeed * dt;
  } else {
    const strafe = Math.sin(time * (Boxing.isPro ? 2.9 : 1.7)) * (Boxing.isPro ? 1.35 : 0.9);
    Boxing.en.position.x += Math.cos(ang) * strafe * dt * 0.8;
    Boxing.en.position.z -= Math.sin(ang) * strafe * dt * 0.8;
  }
  _boxingClampArena(Boxing.en);
  _resolveBoxingCollision(0.32, 0.22);

  Boxing.enemyAtkCD -= dt * 60;
  if (Boxing.enemyAtkCD > 0) return;

  let kind = 'punch';
  if (dist > 1.95) kind = Math.random() < (Boxing.isPro ? 0.82 : 0.7) ? 'tackle' : 'kick';
  else if (dist > 1.55) kind = Math.random() < (Boxing.isPro ? 0.62 : 0.55) ? 'kick' : (Math.random() < (Boxing.isPro ? 0.68 : 0.5) ? 'punch' : 'tackle');
  else kind = Math.random() < (Boxing.isPro ? 0.68 : 0.55) ? 'punch' : (Math.random() < (Boxing.isPro ? 0.72 : 0.55) ? 'kick' : 'tackle');
  _boxingStartEnemyAction(kind);
}

function _boxingGetMoveVector(ix, iy) {
  if (!Boxing.me || !Boxing.en) return { x:0, z:0, mag:0 };
  let fx = Boxing.en.position.x - Boxing.me.position.x;
  let fz = Boxing.en.position.z - Boxing.me.position.z;
  let fl = Math.hypot(fx, fz);
  if (fl < 0.001) { fx = 0; fz = -1; fl = 1; }
  fx /= fl; fz /= fl;
  const rx = fz;
  const rz = -fx;
  let mx = rx * ix + fx * (-iy);
  let mz = rz * ix + fz * (-iy);
  const ml = Math.hypot(mx, mz);
  if (ml > 1) { mx /= ml; mz /= ml; }
  return { x:mx, z:mz, mag:Math.min(1, ml) };
}

function _boxingClampArena(group) {
  if (!group) return;
  _boxingArenaProject(group.position, group.userData?.collisionRadius || 0.55);
}

function _resolveBoxingCollision(pushMe=0.5, pushEn=0.5) {
  if (!Boxing.me || !Boxing.en) return;
  let dx = Boxing.en.position.x - Boxing.me.position.x;
  let dz = Boxing.en.position.z - Boxing.me.position.z;
  let dist = Math.hypot(dx, dz);
  const minDist = (Boxing.me.userData?.collisionRadius || 0.66) + (Boxing.en.userData?.collisionRadius || 0.66);
  if (dist < 0.0001) { dx = 0.001; dz = 0; dist = 0.001; }
  if (dist >= minDist) return;
  const overlap = minDist - dist;
  const nx = dx / dist;
  const nz = dz / dist;
  Boxing.me.position.x -= nx * overlap * pushMe;
  Boxing.me.position.z -= nz * overlap * pushMe;
  Boxing.en.position.x += nx * overlap * pushEn;
  Boxing.en.position.z += nz * overlap * pushEn;
  _boxingClampArena(Boxing.me);
  _boxingClampArena(Boxing.en);
}

// SVG リングを HP に応じて更新する
function _setBoxingHpRing(el, arc, txt, value, max, x, y) {
  if (!el || !arc) return;
  el.style.display = 'block';
  el.style.left = x + 'px';
  el.style.top = y + 'px';
  const ratio = Math.max(0, Math.min(1, value / max));
  const circumference = 2 * Math.PI * 18; // r=18 の周長 ≈ 113.097
  // stroke-dashoffset で残りHPを表現
  arc.setAttribute('stroke-dasharray', circumference.toFixed(2) + ' ' + circumference.toFixed(2));
  arc.setAttribute('stroke-dashoffset', (circumference * (1 - ratio)).toFixed(2));
  // HP に応じて色を変える(緑→黄→赤)
  let col;
  if (ratio > 0.55) col = '#57ef8c';
  else if (ratio > 0.28) col = '#f7c948';
  else col = '#ff6b6b';
  arc.setAttribute('stroke', col);
  if (txt) txt.textContent = Math.max(0, Math.round(value));
}

function _updateBoxingFloatBars() {
  const layer = $('#boxingFloatBars');
  const meRing = $('#boxingRingMe');
  const meArc  = $('#boxingRingMeArc');
  const meTxt  = $('#boxingRingMeTxt');
  const enRing = $('#boxingRingEn');
  const enArc  = $('#boxingRingEnArc');
  const enTxt  = $('#boxingRingEnTxt');
  if (!layer || !meRing || !meArc || !enRing || !enArc) return;
  const shouldShow = Boxing.running && (Boxing.mode === 'fight' || Boxing.mode === 'enemyRevive') && Boxing.me && Boxing.en && Boxing.camera && Boxing.renderer;
  if (!shouldShow) { meRing.style.display = 'none'; enRing.style.display = 'none'; return; }
  // ラグドール中は列が乱れるのでリングも隠す(胴体に追従)
  const rect = Boxing.renderer.domElement.getBoundingClientRect();
  const stageRect = $('#boxingStage').getBoundingClientRect();
  // Vector3 キャッシュ (毎フレーム new しない)
  if (!Boxing._floatVec) Boxing._floatVec = new Boxing.THREE.Vector3();
  const toHeadScreen = (group) => {
    Boxing._floatVec.set(group.position.x, 2.85, group.position.z);
    Boxing._floatVec.project(Boxing.camera);
    return {
      x: rect.left - stageRect.left + (Boxing._floatVec.x * 0.5 + 0.5) * rect.width,
      y: rect.top  - stageRect.top  + (-Boxing._floatVec.y * 0.5 + 0.5) * rect.height
    };
  };
  const mePos = toHeadScreen(Boxing.me);
  const enPos = toHeadScreen(Boxing.en);
  // 頭の「横」に表示：画面上のオフセットを +34px (右横)
  const offset = 34;
  _setBoxingHpRing(meRing, meArc, meTxt, Boxing.meHP, 100, mePos.x + offset, mePos.y);
  _setBoxingHpRing(enRing, enArc, enTxt, Boxing.enHP, 100, enPos.x + offset, enPos.y);
}

function _updateBoxingCamera() {
  if (!Boxing.camera || !Boxing.me || !Boxing.en || !Boxing.THREE) return;
  let bx = Boxing.me.position.x - Boxing.en.position.x;
  let bz = Boxing.me.position.z - Boxing.en.position.z;
  let bl = Math.hypot(bx, bz);
  if (bl < 0.001) { bx = 0; bz = 1; bl = 1; }
  bx /= bl; bz /= bl;
  const fighterDist = Math.max(0, Math.min(2.2, Math.hypot(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z) - 1.2));
  const camBack = 4.55 + fighterDist * 0.55;
  const focusX = (Boxing.me.position.x + Boxing.en.position.x) * 0.5;
  const focusZ = (Boxing.me.position.z + Boxing.en.position.z) * 0.5;
  if (!Boxing._camVec) Boxing._camVec = new Boxing.THREE.Vector3();
  const desired = Boxing._camVec;
  desired.set(
    focusX + bx * camBack,
    2.95 + fighterDist * 0.22,
    focusZ + bz * camBack
  );
  if (Boxing.shakeT > 0) {
    desired.x += (Math.random() - 0.5) * 0.12;
    desired.y += (Math.random() - 0.5) * 0.12;
  }
  Boxing.camera.position.lerp(desired, 0.11);
  Boxing.camera.lookAt(focusX, 1.45, focusZ);
}

function _boxingLoop(now) {
  if (!Boxing.running || !$('#screen-boxing').classList.contains('active')) {
    Boxing.running = false;
    if (Boxing.score > 0) Rank.submit('judo', Boxing.score); // 同じランキングに計上
    return;
  }

  const dt = Math.min(0.05, (now - Boxing.lastT) / 1000);
  Boxing.lastT = now;
  const time = now * 0.001;

  if (Boxing.attackCD > 0) Boxing.attackCD -= dt * 60;
  if (Boxing.meInvuln > 0) Boxing.meInvuln -= dt;
  if (Boxing.shakeT > 0) Boxing.shakeT -= dt * 60;
  if (Boxing.enemyPredictT > 0) Boxing.enemyPredictT -= dt;
  _boxingUpdateRagdolls(dt);
  if (Boxing.meRagdoll) { Boxing.meGuard = false; Boxing.meAction = null; Boxing.meRollT = 0; }
  if (Boxing.enRagdoll) { Boxing.enAction = null; Boxing.enemyDodgeT = 0; }

  // シールド耐久の漸進回復: ガード中でも、被ダメ近いときは遅延を見てから復活
  if (!Boxing.meGuard) {
    if (Boxing.shieldRegenT > 0) Boxing.shieldRegenT -= dt;
    else if (Boxing.shield < Boxing.shieldMax) {
      Boxing.shield = Math.min(Boxing.shieldMax, Boxing.shield + Boxing.shieldRegen * dt);
      // 十分回復したらブレイク状態解除
      if (Boxing.shieldBroken && Boxing.shield > Boxing.shieldMax * 0.5) {
        Boxing.shieldBroken = false;
      }
    }
  }

  // KO中でも世界が止まらないように: 'revive' / 'enemyRevive' モードでも敵AI/移動/アニメ更新は継続する。
  if (Boxing.mode === 'fight' || Boxing.mode === 'revive' || Boxing.mode === 'enemyRevive') {
    if (!Boxing.enRagdoll && Boxing.enemyDodgeT > 0) {
      const dodgeSpeed = (Boxing.isPro ? 10.2 : 8.1) * (0.45 + Boxing.enemyDodgeT);
      Boxing.en.position.x += Boxing.enemyDodgeDir.x * dodgeSpeed * dt;
      Boxing.en.position.z += Boxing.enemyDodgeDir.z * dodgeSpeed * dt;
      _boxingClampArena(Boxing.en);
      Boxing.enemyDodgeT -= dt;
      Boxing.nextAfterimageT -= dt;
      if (Boxing.nextAfterimageT <= 0) {
        _spawnEnemyAfterimage();
        Boxing.nextAfterimageT = 0.045;
      }
      if (Boxing.enemyDodgeT <= 0 && !Boxing.enAction) {
        Boxing.enPose = 'idle';
      }
    }
    if (Boxing.mode === 'revive') {
      // 復活中はプレイヤーは固められたまま動けない。位置は固定。
      Boxing.mePose = 'grappled';
    } else if (Boxing.meRagdoll) {
      Boxing.mePose = 'down';
    } else if (Boxing.meRollT > 0) {
      const rollSpeed = 7.8 * (0.55 + Boxing.meRollT);
      Boxing.me.position.x += Boxing.meRollDir.x * rollSpeed * dt;
      Boxing.me.position.z += Boxing.meRollDir.z * rollSpeed * dt;
      _boxingClampArena(Boxing.me);
      Boxing.meRollT -= dt;
      if (Boxing.meRollT <= 0 && !Boxing.meAction) {
        Boxing.mePose = Boxing.meGuard ? 'guard' : 'idle';
      }
    } else if (!Boxing.meAction) {
      const mv = _boxingGetMoveVector(Boxing.input.x, Boxing.input.y);
      const spd = Boxing.moveSpeed * mv.mag * (Boxing.meGuard ? 0.45 : 1);
      Boxing.me.position.x += mv.x * spd * dt;
      Boxing.me.position.z += mv.z * spd * dt;
      _boxingClampArena(Boxing.me);
      _resolveBoxingCollision(0.55, 0.15);
      if (mv.mag > 0.12) {
        Boxing.input.lastX = Boxing.input.x;
        Boxing.input.lastY = Boxing.input.y;
      }
      if (!Boxing.meGuard) Boxing.mePose = mv.mag > 0.12 ? 'move' : 'idle';
      else Boxing.mePose = 'guard';
    }

    if (Boxing.mode !== 'revive' && !Boxing.meRagdoll) Boxing.meAction = _boxingUpdateAction(Boxing.meAction, dt);
    if (Boxing.mode !== 'enemyRevive' && !Boxing.enRagdoll) Boxing.enAction = _boxingUpdateAction(Boxing.enAction, dt);
    if (Boxing.mode !== 'revive' && !Boxing.meRagdoll && !Boxing.meAction && Boxing.meRollT <= 0) {
      const mv = _boxingGetMoveVector(Boxing.input.x, Boxing.input.y);
      Boxing.mePose = Boxing.meGuard ? 'guard' : (mv.mag > 0.12 ? 'move' : 'idle');
    }
    // 敵AIの思考は復活中は止める（プレイヤーを掴んでいる扱いのため）
    if (Boxing.mode === 'fight' && !Boxing.enRagdoll && !Boxing.enAction && Boxing.enemyDodgeT <= 0) _boxingEnemyThink(dt, time);
    if (!Boxing.enRagdoll && !Boxing.enAction && Boxing.enemyDodgeT <= 0) {
      if (Boxing.mode === 'revive') {
        Boxing.enPose = 'grappling';
      } else if (Boxing.mode === 'enemyRevive') {
        Boxing.enPose = 'down';
      } else {
        const d = Math.hypot(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
        Boxing.enPose = d > 1.4 ? 'move' : 'idle';
      }
    }
  }

  // 向きを互いにロックオン (柔道と同じ _turnToward ヘルパーを使うために一時的に Judo スコープを使わず自前計算)
  if (!Boxing.meRagdoll) _boxingTurnToward(Boxing.me, Boxing.enRagdoll?.fighter || Boxing.en, Boxing.meRollT > 0 ? 0.1 : 0.22);
  if (!Boxing.enRagdoll) _boxingTurnToward(Boxing.en, Boxing.meRagdoll?.fighter || Boxing.me, 0.18);

  Boxing.meAnim = Math.min(1, Boxing.meAnim + dt * 5.5);
  Boxing.enAnim = Math.min(1, Boxing.enAnim + dt * 5.2);
  if (!Boxing.meRagdoll) _animateJudoka(Boxing.me, Boxing.mePose, Boxing.meAnim, time);
  if (!Boxing.enRagdoll) _animateJudoka(Boxing.en, Boxing.enPose, Boxing.enAnim, time + 0.7);
  _updateBoxingCamera();
  _updateEnemyAfterimages(dt, time);

  if (!Boxing.meRagdoll && !Boxing.enRagdoll) _resolveBoxingCollision(0.5, 0.5);
  Boxing.renderer.render(Boxing.scene, Boxing.camera);
  _updateShieldUI();
  _updateBoxingFloatBars();

  // HP0 になったら 復活チャレンジを起動 (KOしても世界は止まらず、必ずチャレンジが発動する)
  if (Boxing.meHP <= 0 && Boxing.mode === 'fight') {
    _enterBoxingRevive();
  }
  // ボットが HP0 になったらボットの復活チャレンジを起動
  if (Boxing.enHP <= 0 && Boxing.mode === 'fight') {
    _enterBoxingEnemyRevive();
  }
  // 復活モード中は専用更新（世界はそのまま動いている）
  if (Boxing.mode === 'revive') {
    _updateBoxingRevive(dt);
  } else if (Boxing.mode === 'enemyRevive') {
    _updateBoxingEnemyRevive(dt);
  }

  Boxing.raf = requestAnimationFrame(_boxingLoop);
}

/* ====== ボクシング 復活チャレンジ (HP0 になったら発動) ======
   ・ 10秒以内にランダムスポーンするボタン 6個をすべて叩く
   ・ 成功：HP100 で復活、reviveLeft--
   ・ 失敗：ゲームオーバー
   ・ ボット妨害: 1.4~2.3秒ごとに 28% で発動
      · 「掴み込みで強制終了」 (40%)→ 復活失敗
      · 「妓邪で時間短縮」 (60%)→ 残り時間 -2秒 */
function _enterBoxingRevive() {
  if (Boxing.mode === 'revive') return;
  Boxing.mode = 'revive';
  Boxing.meAction = null;
  Boxing.enAction = null;
  Boxing.meGuard = false;
  Boxing.meRollT = 0;
  Boxing.mePose = 'reviveCrawl';
  Boxing.enPose = 'grappling';
  // HP は 0 のまま、復活成功で 80 まで徐々に戻す
  Boxing.meHP = 0;
  Boxing.revive = {
    remain: 10.0,           // 全体制限時間 10秒（ボタン個別の制限はなし）
    needed: 6,              // ボタン 6個全部叩く
    pressed: 0,
    sabotageT: 1.6,
    sabotageMsgT: 0,
    recovering: false,      // true: ボタン全押し → HP 80 まで徐々に回復中
    recoverT: 0,            // 回復経過秒
    recoverDur: 1.6,        // 回復にかける時間
  };
  const layer = $('#boxingReviveLayer');
  if (layer) { layer.style.display = 'block'; layer.style.pointerEvents = 'auto'; }
  const status = $('#boxingReviveStatus'); if (status) status.style.display = 'block';
  const sab = $('#boxingReviveSabotage'); if (sab) sab.style.display = 'none';
  // 掴みを掛けてくる位置に敵を接近
  if (Boxing.me && Boxing.en) {
    const ang = Math.atan2(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
    const sep = 0.78;
    Boxing.en.position.x = Boxing.me.position.x - Math.sin(ang) * sep;
    Boxing.en.position.z = Boxing.me.position.z - Math.cos(ang) * sep;
  }
  // ボタンを一気に全部スポーン（個別の制限時間はなし）
  _spawnAllReviveButtons();
  _updateBoxingReviveUI();
}

// 復活チャレンジのボタンを needed 個　2回規復で重ならないようにランダム配置して一括生成。
function _spawnAllReviveButtons() {
  const area = $('#boxingReviveBtnArea');
  if (!area || !Boxing.revive) return;
  // 既存をクリア
  area.querySelectorAll('.pinBtn').forEach(b => b.remove());
  Boxing.revive.btns = [];
  const rect = area.getBoundingClientRect();
  const pad = 24, btnSize = 64, minDist = btnSize + 12;
  const placed = [];
  const minY = Math.max(1, rect.height * 0.32);
  const maxY = Math.max(minY + 1, rect.height - pad - btnSize);
  const maxX = Math.max(1, rect.width - pad * 2 - btnSize);
  for (let i = 0; i < Boxing.revive.needed; i++) {
    let x, y, ok = false;
    for (let attempt = 0; attempt < 30 && !ok; attempt++) {
      x = pad + Math.random() * maxX;
      y = minY + Math.random() * (maxY - minY);
      ok = placed.every(p => Math.hypot(p.x - x, p.y - y) >= minDist);
    }
    placed.push({ x, y });
    const btn = document.createElement('div');
    btn.className = 'pinBtn';
    btn.textContent = '💔';
    btn.style.left = x + 'px';
    btn.style.top  = y + 'px';
    btn.onpointerdown = (e) => {
      e.stopPropagation();
      e.preventDefault();
      if (btn._hit || !Boxing.revive || Boxing.revive.recovering) return;
      btn._hit = true;
      btn.classList.add('hit');
      Boxing.revive.pressed++;
      Boxing.score += 8;
      setTimeout(() => btn.remove(), 250);
      _updateBoxingReviveUI();
      updateBoxingHUD();
      if (Boxing.revive.pressed >= Boxing.revive.needed) {
        // 全てのボタン成功 → HP を 80 まで徐々に回復
        Boxing.revive.recovering = true;
        Boxing.revive.recoverT = 0;
        _flashMsgBoxing('✨ 復活成功!\nHP 回復中...', '#8cffb0', 1100);
      }
    };
    area.appendChild(btn);
    Boxing.revive.btns.push(btn);
  }
}

function _updateBoxingReviveUI() {
  if (!Boxing.revive) return;
  const r = Boxing.revive;
  const t1 = $('#reviveTimer'); if (t1) t1.textContent = Math.max(0, r.remain).toFixed(1);
  const t2 = $('#reviveBigTimer'); if (t2) t2.textContent = Math.max(0, r.remain).toFixed(1);
  const p1 = $('#reviveProg'); if (p1) p1.textContent = r.pressed;
  const p2 = $('#reviveBigProg'); if (p2) p2.textContent = r.pressed;
  const n1 = $('#reviveNeed'); if (n1) n1.textContent = r.needed;
  const n2 = $('#reviveBigNeed'); if (n2) n2.textContent = r.needed;
  const lf = $('#reviveLeftTxt'); if (lf) lf.textContent = '';
}

// （旧仕様の逐次スポーンは廃止。ボタンは _spawnAllReviveButtons で一気に出す。）
function _spawnReviveButton() { /* deprecated */ }

function _showReviveSabotage(text, color) {
  const sab = $('#boxingReviveSabotage');
  if (!sab) return;
  sab.innerHTML = text.replace(/\n/g, '<br>');
  sab.style.color = color || '#ffd76b';
  sab.style.display = 'block';
  if (Boxing.revive) Boxing.revive.sabotageMsgT = 1.0;
}

function _reviveSabotage() {
  if (!Boxing.revive) return;
  const r = Math.random();
  if (r < 0.40) {
    // 掴み込みで強制終了
    _showReviveSabotage('⚠️ ボットの掴み込み!!\n復活中断!!', '#ff7777');
    Boxing.shakeT = 16;
    setTimeout(() => { if (Boxing.mode === 'revive') _exitBoxingRevive(false); }, 900);
  } else {
    // 妓邪で時間短縮
    const cut = 2.0;
    Boxing.revive.remain = Math.max(0.4, Boxing.revive.remain - cut);
    _showReviveSabotage('⚠️ ボットが妓邪!!\n残り時間 -' + cut.toFixed(1) + '秒', '#ffd76b');
    Boxing.shakeT = 8;
  }
}

function _updateBoxingRevive(dt) {
  if (!Boxing.revive) return;
  const r = Boxing.revive;

  // HP 回復アニメーション中
  if (r.recovering) {
    r.recoverT += dt;
    const t = Math.min(1, r.recoverT / r.recoverDur);
    // ease-out
    const ease = 1 - Math.pow(1 - t, 2);
    Boxing.meHP = Math.round(80 * ease);
    updateBoxingHUD();
    if (t >= 1) {
      Boxing.meHP = 80;
      _exitBoxingRevive(true);
    }
    Boxing.mePose = 'reviveCrawl';
    Boxing.enPose = 'grappling';
    return;
  }

  r.remain -= dt;

  // ボット妨害タイマー
  r.sabotageT -= dt;
  if (r.sabotageT <= 0) {
    r.sabotageT = 1.4 + Math.random() * 0.9;
    if (Math.random() < 0.28) _reviveSabotage();
  }

  // 妨害メッセージ表示タイマー
  if (r.sabotageMsgT > 0) {
    r.sabotageMsgT -= dt;
    if (r.sabotageMsgT <= 0) {
      const sab = $('#boxingReviveSabotage'); if (sab) sab.style.display = 'none';
    }
  }

  // キャラを四つん這い・腹押さえ姿勢に (リバイブ専用)
  Boxing.mePose = 'reviveCrawl';
  Boxing.enPose = 'grappling';

  _updateBoxingReviveUI();

  if (r.remain <= 0) { _exitBoxingRevive(false); return; }
}

function _exitBoxingRevive(success) {
  const layer = $('#boxingReviveLayer');
  if (layer) {
    layer.style.display = 'none';
    layer.style.pointerEvents = 'none';
    const area = $('#boxingReviveBtnArea');
    if (area) area.querySelectorAll('.pinBtn').forEach(b => b.remove());
  }
  const status = $('#boxingReviveStatus'); if (status) status.style.display = 'none';
  const sab = $('#boxingReviveSabotage'); if (sab) sab.style.display = 'none';
  Boxing.revive = null;
  if (success) {
    // クリアしたので HP はアニメの結果 80 になっている
    Boxing.meHP = 80;
    Boxing.shield = Boxing.shieldMax;
    Boxing.shieldBroken = false;
    Boxing.shieldRegenT = 0;
    Boxing.mode = 'fight';
    Boxing.mePose = 'idle';
    Boxing.enPose = 'idle';
    Boxing.meInvuln = 1.2; // 復活直後は袲間
    Boxing.attackCD = 20;
    Boxing.enemyAtkCD = 60 + Math.random() * 40;
    // 両者を離す
    if (Boxing.me && Boxing.en) {
      const ang = Math.atan2(Boxing.en.position.x - Boxing.me.position.x, Boxing.en.position.z - Boxing.me.position.z);
      Boxing.en.position.x = Boxing.me.position.x + Math.sin(ang) * 2.6;
      Boxing.en.position.z = Boxing.me.position.z + Math.cos(ang) * 2.6;
      _boxingClampArena(Boxing.en);
    }
    _flashMsgBoxing('💖 復活成功！\nHP 80 でリスタート', '#8cffb0', 1600);
    updateBoxingHUD();
  } else {
    // 失敗 → ゲームオーバー
    Boxing.mode = 'fight'; // 一旦 fight にして game over 処理へ
    _boxingGameOver(false);
  }
}

/* ====== ボットの復活チャレンジ (プレイヤーと同仕様・ボットが自動でボタンを押す) ======
   ・ 10秒以内に 6個のボタンをすべて押すのと同じ仕様
   ・ ボットは一定間隔で自動押下
   ・ プレイヤーが攻撃を当てるとサボタージ (時間短縮/全て火消し) */
function _enterBoxingEnemyRevive() {
  if (Boxing.mode === 'enemyRevive') return;
  Boxing.mode = 'enemyRevive';
  Boxing.meAction = null;
  Boxing.enAction = null;
  Boxing.enHP = 0;
  Boxing.enRevive = {
    remain: 10.0,
    needed: 6,
    pressed: 0,
    pressTimer: 1.6 + Math.random() * 0.4,
    pressInterval: 1.45,
    recovering: false,
    recoverT: 0,
    recoverDur: 1.6,
    sabotageMsgT: 0,
  };
  // ボットを跡いてる姿勢に
  Boxing.enPose = 'down';
  // 画面上部に表示するステータスバーを生成/表示
  let bar = document.getElementById('boxingEnemyReviveStatus');
  if (!bar) {
    bar = document.createElement('div');
    bar.id = 'boxingEnemyReviveStatus';
    bar.style.cssText = 'position:absolute;top:48px;left:0;right:0;padding:6px 10px;text-align:center;color:#ffd76b;font-size:13px;font-weight:bold;background:rgba(80,30,0,0.55);border-top:1px solid rgba(255,180,80,0.55);border-bottom:1px solid rgba(255,180,80,0.55);z-index:5;pointer-events:none;';
    bar.innerHTML = '🔥 ボット復活中! 残り <span id="enReviveTimer">10.0</span>秒 ・ ボタン <span id="enReviveProg">0</span>/<span id="enReviveNeed">6</span> ・ 攻撃で妨害しよう!';
    const screen = document.getElementById('screen-boxing');
    if (screen) screen.appendChild(bar);
  }
  bar.style.display = 'block';
  _flashMsgBoxing('🔥 ボットが復活を試みている!\n攻撃で妨害しよう!', '#ff7777', 1400);
  _updateBoxingEnemyReviveUI();
}

function _updateBoxingEnemyReviveUI() {
  if (!Boxing.enRevive) return;
  const r = Boxing.enRevive;
  const t = document.getElementById('enReviveTimer'); if (t) t.textContent = Math.max(0, r.remain).toFixed(1);
  const p = document.getElementById('enReviveProg'); if (p) p.textContent = r.pressed;
  const n = document.getElementById('enReviveNeed'); if (n) n.textContent = r.needed;
}

function _updateBoxingEnemyRevive(dt) {
  if (!Boxing.enRevive) return;
  const r = Boxing.enRevive;

  if (r.recovering) {
    r.recoverT += dt;
    const t = Math.min(1, r.recoverT / r.recoverDur);
    const ease = 1 - Math.pow(1 - t, 2);
    Boxing.enHP = Math.round(80 * ease);
    updateBoxingHUD();
    if (t >= 1) {
      Boxing.enHP = 80;
      _exitBoxingEnemyRevive(true);
    }
    Boxing.enPose = 'down';
    return;
  }

  r.remain -= dt;

  // ボットの自動押下タイマー
  r.pressTimer -= dt;
  if (r.pressTimer <= 0) {
    r.pressed++;
    r.pressTimer = r.pressInterval + (Math.random() - 0.5) * 0.4;
    _flashMsgBoxing('ボット ボタン ' + r.pressed + '/' + r.needed + ' 押下!', '#ff9966', 500);
    if (r.pressed >= r.needed) {
      r.recovering = true;
      r.recoverT = 0;
      _flashMsgBoxing('⚠️ ボット復活成功!\nHP 回復中...', '#ffd76b', 1100);
    }
  }

  _updateBoxingEnemyReviveUI();

  if (r.remain <= 0) { _exitBoxingEnemyRevive(false); return; }
}

function _enemyRevivePlayerSabotage(action) {
  if (!Boxing.enRevive || Boxing.enRevive.recovering) return;
  const r = Boxing.enRevive;
  // タックル → 一撃でボットを永久火消し (クリティカルヒット) ⚡
  if (action.kind === 'tackle') {
    _flashMsgBoxing('💥 タックルで復活を粉砕!', '#9fd3ff', 1100);
    _exitBoxingEnemyRevive(false);
    return;
  }
  // パンチ/キック: 時間短縮 + 押下計数を逆をり
  const timeCut = action.kind === 'kick' ? 1.8 : 1.2;
  r.remain = Math.max(0.2, r.remain - timeCut);
  // 逆軻 (押下したボタンを 1個検す)
  if (r.pressed > 0 && Math.random() < (action.kind === 'kick' ? 0.6 : 0.45)) {
    r.pressed = Math.max(0, r.pressed - 1);
    _flashMsgBoxing(action.label + ' で妨害!\nボタン-1 / 時間-' + timeCut.toFixed(1) + '秒', action.color, 700);
  } else {
    _flashMsgBoxing(action.label + ' で妨害!\n残り時間-' + timeCut.toFixed(1) + '秒', action.color, 700);
  }
  Boxing.shakeT = 8;
  // ボットの押下タイマーも少し延ばす
  r.pressTimer = Math.max(r.pressTimer, 0.5);
  _updateBoxingEnemyReviveUI();
}

function _exitBoxingEnemyRevive(success) {
  const bar = document.getElementById('boxingEnemyReviveStatus');
  if (bar) bar.style.display = 'none';
  Boxing.enRevive = null;
  if (success) {
    Boxing.enHP = 80;
    Boxing.mode = 'fight';
    Boxing.enPose = 'idle';
    Boxing.enemyAtkCD = 60 + Math.random() * 40;
    Boxing.attackCD = Math.max(Boxing.attackCD, 18);
    if (Boxing.me && Boxing.en) {
      const ang = Math.atan2(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
      Boxing.me.position.x = Boxing.en.position.x + Math.sin(ang) * 2.8;
      Boxing.me.position.z = Boxing.en.position.z + Math.cos(ang) * 2.8;
      _boxingClampArena(Boxing.me);
    }
    _flashMsgBoxing('⚠️ ボットが復活!\nHP 80 で再戦開始', '#ff8c8c', 1600);
    updateBoxingHUD();
  } else {
    Boxing.enHP = 0;
    Boxing.mode = 'fight';
    _boxingGameOver(true);
  }
}

function _boxingTurnToward(group, target, ease) {
  if (!group || !target) return;
  const desired = Math.atan2(target.position.x - group.position.x, target.position.z - group.position.z);
  let delta = desired - group.rotation.y;
  while (delta > Math.PI) delta -= Math.PI * 2;
  while (delta < -Math.PI) delta += Math.PI * 2;
  group.rotation.y += delta * ease;
}

function _boxingGameOver(win) {
  Boxing.running = false;
  Boxing.mode = 'result';
  const ring = $('#boxingShieldRing'); if (ring) ring.style.display = 'none';
  let winLine = '';
  if (win) {
    const wins = _recordBoxingWin();
    Boxing.totalWins = wins;
    const unlockedNow = wins >= BOXING_PRO_WIN_THRESHOLD;
    winLine = Boxing.isPro
      ? `\n🔥 プロを撃破!`
      : (unlockedNow
          ? `\n通算 ${wins}勝 / これから時々プロ出現!`
          : `\n通算 ${wins}勝`);
  }
  const msg = win
    ? `🥊 KO勝ち!${winLine}
スコア: ${Boxing.score}
タップで戻る`
    : `🥊 KO負け...
スコア: ${Boxing.score}
タップで戻る`;
  const el = $('#boxingCenterMsg');
  el.innerHTML = msg.replace(/\n/g, '<br>');
  el.style.color = win ? '#ffd76b' : '#ff8c8c';
  el.style.display = 'block';
  Rank.submit('judo', Boxing.score);
  const back = () => {
    if (Boxing.container) Boxing.container.onclick = null;
    el.onclick = null;
    go('menu');
  };
  if (Boxing.container) Boxing.container.onclick = back;
  el.style.pointerEvents = 'auto';
  el.onclick = back;
}

function _disposeBoxing() {
  if (Boxing.raf) cancelAnimationFrame(Boxing.raf);
  Boxing.raf = 0;
  Boxing.running = false;
  // 復活レイヤーをクリーンアップ
  const rl = $('#boxingReviveLayer');
  if (rl) { rl.style.display = 'none'; rl.style.pointerEvents = 'none'; }
  const rArea = $('#boxingReviveBtnArea');
  if (rArea) rArea.querySelectorAll('.pinBtn').forEach(b => b.remove());
  const rs = $('#boxingReviveStatus'); if (rs) rs.style.display = 'none';
  const sab = $('#boxingReviveSabotage'); if (sab) sab.style.display = 'none';
  Boxing.revive = null;
  Boxing.enRevive = null;
  const enBar = document.getElementById('boxingEnemyReviveStatus'); if (enBar) enBar.style.display = 'none';
  _boxingClearAllRagdolls();
  Boxing.alleyColliders = [];
  _cleanupEnemyAfterimages();
  window.removeEventListener('resize', _resizeBoxing);
  if (Boxing.scene) _disposeScene(Boxing.scene);
  if (Boxing.renderer) {
    try { Boxing.renderer.renderLists.dispose(); Boxing.renderer.dispose(); } catch(e) {}
    if (Boxing.renderer.domElement && Boxing.renderer.domElement.parentNode) {
      Boxing.renderer.domElement.parentNode.removeChild(Boxing.renderer.domElement);
    }
  }
  Boxing.renderer = null; Boxing.scene = null; Boxing.camera = null;
  Boxing.me = null; Boxing.en = null;
  if (Boxing.container) Boxing.container.innerHTML = '';
  const zone = $('#boxingStickZone');
  if (zone) {
    zone.onpointerdown = null;
    zone.onpointermove = null;
    zone.onpointerup = null;
    zone.onpointercancel = null;
    zone.onpointerleave = null;
  }
  ['bxBtnPunch','bxBtnKick','bxBtnTackle','bxBtnRoll','bxBtnGuard'].forEach(id => {
    const el = $('#' + id);
    if (!el) return;
    el.onclick = null;
    el.onpointerdown = null;
    el.onpointerup = null;
    el.onpointerleave = null;
    el.onpointercancel = null;
  });
  const knob = $('#boxingStickKnob');
  if (knob) knob.style.transform = 'translate(-50%, -50%)';
  const cm = $('#boxingCenterMsg');
  if (cm) { cm.style.display = 'none'; cm.style.pointerEvents = 'none'; cm.onclick = null; }
  const ring = $('#boxingShieldRing');
  if (ring) ring.style.display = 'none';
  const meRing = $('#boxingRingMe'); if (meRing) meRing.style.display = 'none';
  const enRing = $('#boxingRingEn'); if (enRing) enRing.style.display = 'none';
}

/* ============================================================
   👊 極太バスター
   ============================================================ */
const Buster = {
  cv:null, ctx:null, running:false, w:0,h:0,
  enemies:[], score:0, combo:0, comboT:0, hi:0,
  timeLeft:30, lastSec:0, spawnT:0,
};
function startBuster() {
  window.removeEventListener('resize', resizeBuster); // 二重登録防止
  const cv = $('#busterCanvas'); Buster.cv=cv; Buster.ctx=cv.getContext('2d');
  resizeBuster(); window.addEventListener('resize', resizeBuster);
  Buster.enemies = []; Buster.score = 0; Buster.combo=0; Buster.comboT=0;
  Buster.hi = parseInt(localStorage.getItem('garigari_buster_hi')||'0',10);
  Buster.timeLeft = 30; Buster.lastSec = performance.now();
  Buster._bgGrd = null; // グラデーションキャッシュリセット
  updateBusterHUD();
  cv.ontouchstart = cv.onmousedown = e => busterTap(e);
  Buster.running = true;
  requestAnimationFrame(busterLoop);
}
function resizeBuster() {
  if (!Buster.cv) return;
  const r = Buster.cv.getBoundingClientRect();
  Buster.cv.width = r.width; Buster.cv.height = r.height;
  Buster.w = r.width; Buster.h = r.height;
  Buster._bgGrd = null; // サイズ変更時にキャッシュ無効化
}
function updateBusterHUD() {
  $('#busterScore').textContent = Buster.score;
  $('#busterCombo').textContent = Buster.combo;
  $('#busterHi').textContent = Buster.hi;
  $('#busterInfo').textContent = '残り '+Math.max(0,Math.ceil(Buster.timeLeft))+'秒';
}
function busterTap(e) {
  const r = Buster.cv.getBoundingClientRect();
  const x = (e.touches?e.touches[0].clientX:e.clientX) - r.left;
  const y = (e.touches?e.touches[0].clientY:e.clientY) - r.top;
  let hit = false;
  for (let i=Buster.enemies.length-1;i>=0;i--){
    const en = Buster.enemies[i];
    if (en.dead) continue;
    const dx = x-en.x, dy = y-en.y;
    if (Math.sqrt(dx*dx+dy*dy) < en.r+8) {
      en.hp -= 1;
      en.hit = 8;
      if (en.hp<=0) {
        en.dead = true;
        Buster.combo++;
        Buster.comboT = 60;
        const base = 50 + en.size*20;
        const bonus = Math.floor(base * (1 + Buster.combo*0.1));
        Buster.score += bonus;
        spawnPop(en.x, en.y, '+'+bonus);
      }
      hit = true;
      break;
    }
  }
  if (!hit) { Buster.combo = 0; Buster.comboT = 0; }
  updateBusterHUD();
  e.preventDefault();
}
const Pops = [];
function spawnPop(x,y,txt){ Pops.push({x,y,txt,t:30}); }

function busterLoop() {
  if (!Buster.running || !$('#screen-buster').classList.contains('active')) {
    Buster.running=false;
    window.removeEventListener('resize', resizeBuster);
    return;
  }
  const c = Buster.ctx; const W=Buster.w, H=Buster.h;
  // 背景 (グラデーションをキャッシュ)
  if (!Buster._bgGrd) {
    Buster._bgGrd = c.createLinearGradient(0,0,0,H);
    Buster._bgGrd.addColorStop(0,'#2a1a30'); Buster._bgGrd.addColorStop(1,'#0a0510');
  }
  c.fillStyle=Buster._bgGrd; c.fillRect(0,0,W,H);

  // 時間
  const now = performance.now();
  const dt = (now - Buster.lastSec)/1000;
  Buster.lastSec = now;
  Buster.timeLeft -= dt;

  // スポーン
  Buster.spawnT -= dt;
  if (Buster.spawnT<=0 && Buster.timeLeft>0) {
    Buster.spawnT = 0.6 + Math.random()*0.6;
    const size = Math.random()<0.3 ? 2 : (Math.random()<0.5 ? 1 : 0); // 0:小 1:中 2:大
    const r = 30 + size*18;
    const x = r + Math.random()*(W - r*2);
    const y = H + r;
    const hp = 1 + size;
    Buster.enemies.push({ x, y, vy: -(70 + Math.random()*30 + size*15)/60*60, r, size, hp, hit:0, dead:false, sway:Math.random()*Math.PI*2 });
  }

  // 更新と描画
  for (const en of Buster.enemies) {
    if (en.dead) continue;
    en.sway += 0.05;
    en.x += Math.sin(en.sway)*0.6;
    en.y -= 1.5 + en.size*0.4;
    if (en.hit>0) en.hit--;
    // 描画(でぶキャラ)
    drawFatGuy(c, en.x, en.y, en.r, en.hit>0);
    // 画面外で消滅+コンボリセット
    if (en.y < -en.r) {
      en.dead = true;
      Buster.combo = 0; Buster.comboT = 0;
    }
  }
  // 古いの消す (dead フラグのものをインプレースで削除)
  let live = 0;
  for (let i = 0; i < Buster.enemies.length; i++) {
    if (!Buster.enemies[i].dead) Buster.enemies[live++] = Buster.enemies[i];
  }
  Buster.enemies.length = live;
  if (Buster.enemies.length > 80) Buster.enemies.splice(0, Buster.enemies.length - 80);

  // ポップ表記
  for (let i=Pops.length-1;i>=0;i--){
    const p = Pops[i]; p.t--; p.y -= 1.2;
    c.fillStyle='rgba(247,201,72,'+(p.t/30)+')';
    c.font='bold 22px sans-serif'; c.textAlign='center';
    c.fillText(p.txt, p.x, p.y);
    if (p.t<=0) Pops.splice(i,1);
  }

  // コンボタイマー
  if (Buster.comboT>0) {
    Buster.comboT--;
    c.fillStyle='rgba(247,201,72,'+(Buster.comboT/60)+')';
    c.font='bold 30px sans-serif'; c.textAlign='center';
    c.fillText(Buster.combo+' COMBO!', W/2, 60);
  } else if (Buster.combo>0) Buster.combo=0;

  updateBusterHUD();

  // ゲーム終了
  if (Buster.timeLeft<=0) {
    c.fillStyle='rgba(0,0,0,0.8)'; c.fillRect(0,0,W,H);
    c.fillStyle='#f7c948'; c.font='bold 32px sans-serif'; c.textAlign='center';
    c.fillText('TIME UP!', W/2, H/2-20);
    c.fillStyle='#fff'; c.font='18px sans-serif';
    c.fillText('スコア: '+Buster.score, W/2, H/2+14);
    if (Buster.score > Buster.hi) {
      Buster.hi = Buster.score;
      localStorage.setItem('garigari_buster_hi', ''+Buster.hi);
      c.fillStyle='#f7c948'; c.fillText('🎉 NEW RECORD! 🎉', W/2, H/2+44);
    }
    c.fillStyle='#fff'; c.font='14px sans-serif';
    c.fillText('タップで戻る', W/2, H/2+74);
    Buster.cv.ontouchstart = Buster.cv.onmousedown = ()=>{ Rank.submit('buster', Buster.score); go('menu'); };
    Buster.running=false;
    window.removeEventListener('resize', resizeBuster);
    return;
  }

  requestAnimationFrame(busterLoop);
}
function drawFatGuy(c, x, y, r, hit) {
  c.save(); c.translate(x,y);
  // 影
  c.fillStyle='rgba(0,0,0,0.35)'; c.beginPath(); c.ellipse(0, r+8, r*0.8, 4, 0, 0, Math.PI*2); c.fill();
  // 体
  c.fillStyle = hit ? '#ffaa44' : '#e0a988';
  c.beginPath(); c.arc(0, 0, r, 0, Math.PI*2); c.fill();
  // 服(タンクトップ)
  c.fillStyle = hit ? '#fff' : '#5577cc';
  c.beginPath(); c.ellipse(0, r*0.3, r*0.85, r*0.55, 0, 0, Math.PI*2); c.fill();
  // 顔の輪郭
  c.fillStyle = hit ? '#ffcc66' : '#e8b896';
  c.beginPath(); c.arc(0, -r*0.25, r*0.55, 0, Math.PI*2); c.fill();
  // 目
  c.fillStyle='#000';
  c.fillRect(-r*0.2, -r*0.3, r*0.08, r*0.06);
  c.fillRect(r*0.12, -r*0.3, r*0.08, r*0.06);
  // 口
  c.beginPath(); c.arc(0, -r*0.15, r*0.12, 0, Math.PI); c.fill();
  // ほっぺ
  c.fillStyle='rgba(255,100,100,0.4)';
  c.beginPath(); c.arc(-r*0.3, -r*0.18, r*0.1, 0, Math.PI*2); c.fill();
  c.beginPath(); c.arc(r*0.3, -r*0.18, r*0.1, 0, Math.PI*2); c.fill();
  c.restore();
}

/* ============================================================
   ガリガリライブ (PVPVE オープンワールド)
   - GTA5風: 街・道路・信号・車・市民・警察
   - P2Pで他プレイヤーと同期 (位置/攻撃/車)
   - NPC性格: 普通/攻撃的/臆病/警察
   ============================================================ */
let THREE_L = null; // ライブ用 three reference
const Live = {
  running: false,
  scene: null, camera: null, renderer: null,
  clock: null,
  rafId: 0,

  // 街
  CITY_SIZE: 240,      // 全体辺長
  BLOCK: 40,           // 区画サイズ (建物+道路で1区画)
  ROAD_W: 8,           // 道路幅
  trafficLights: [],   // 信号機 {x,z,state,t,group,bulbs:{r,y,g}}
  roadNodes: [],       // 経路ノード {x,z, neighbors:[idx]}
  carSpawns: [],       // 車スポーン点(交差点近く)
  buildings: [],       // 建物コリジョン {x,z,hx,hz} AABB
  ragdolls: [],        // 物理エンジン適用中の死体 {parts:[{mesh,vel,angVel}]}
  playerRagdoll: null, // プレイヤーの物理状態 (車に轢かれたとき発動)

  // エンティティ
  player: null,        // {pos, vel, yaw, hp, inCar:null, mesh, group}
  remotes: new Map(),  // peerId -> {group, hp, name, inCar}
  npcs: [],            // 歩行者
  cars: [],            // 車両(運転中 or 自動)
  police: [],          // 警察
  bullets: [],         // 使わない(殴打のみ) — エフェクト用空配列

  wanted: 0,           // 0-5
  cash: 0,
  kills: 0,
  hp: 100,

  // 入力
  joy: { active:false, dx:0, dy:0, sx:0, sy:0, id:null },
  btnHeld: { attack:false, dash:false, horn:false, car:false },
  dashCD: 0,

  // ネット送信スロットル
  _netT: 0,
  _killFeedEls: [],

  // 設定
  CAM_DIST: 14, CAM_HEIGHT: 9,
};

function _liveLog(msg) {
  const el = document.getElementById('liveKillFeed');
  if (!el) return;
  const d = document.createElement('div');
  d.style.cssText = 'background:rgba(0,0,0,0.55);border-left:3px solid #ffd76b;padding:4px 6px;font-size:11px;color:#fff;border-radius:4px;animation:pinBtnPulse 0.3s ease-out;';
  d.textContent = msg;
  el.appendChild(d);
  Live._killFeedEls.push(d);
  setTimeout(()=>{ try{d.remove();}catch(e){} }, 4500);
  while (Live._killFeedEls.length > 5) {
    const old = Live._killFeedEls.shift();
    try { old.remove(); } catch(e){}
  }
}

function _liveCenterMsg(text, ms) {
  const el = document.getElementById('liveCenterMsg');
  if (!el) return;
  el.textContent = text;
  el.style.display = 'block';
  clearTimeout(Live._msgT);
  Live._msgT = setTimeout(()=>{ el.style.display='none'; }, ms||1200);
}

async function startLive() {
  if (Live.running) return;
  try {
    THREE_L = await window.loadThreeWithRetry();
  } catch(e) {
    showToast('Three.js 読込失敗');
    return;
  }
  _liveBuild();
  Live.running = true;
  Live.clock = new THREE_L.Clock();
  _liveLoop();
  window.addEventListener('resize', _resizeLive);
  showToast('ガリガリライブ開始！');
}

function _resizeLive() {
  if (!Live.renderer) return;
  const stage = document.getElementById('liveStage');
  if (!stage) return;
  const w = stage.clientWidth, h = stage.clientHeight;
  Live.renderer.setSize(w, h, false);
  Live.camera.aspect = w/h;
  Live.camera.updateProjectionMatrix();
}

function _disposeLive() {
  Live.running = false;
  if (Live.rafId) cancelAnimationFrame(Live.rafId);
  Live.rafId = 0;
  window.removeEventListener('resize', _resizeLive);
  if (Live.scene) _disposeScene(Live.scene);
  if (Live.renderer) {
    try {
      Live.renderer.renderLists.dispose();
      Live.renderer.dispose();
      const el = Live.renderer.domElement;
      if (el && el.parentNode) el.parentNode.removeChild(el);
    } catch(e){}
  }
  Live.renderer = null;
  Live.scene = null;
  Live.camera = null;
  Live.player = null;
  Live.npcs = [];
  Live.cars = [];
  Live.police = [];
  Live.trafficLights = [];
  Live.buildings = [];
  Live.ragdolls = [];
  Live.playerRagdoll = null;
  Live.remotes.clear();
  Live.wanted = 0; Live.cash = 0; Live.kills = 0; Live.hp = 100;
}

/* ============ 物理エンジン (コリジョン + ラグドール) ============ */
function _resolveCollision(pos, radius, opts) {
  opts = opts || {};
  const ignoreCar = opts.ignoreCar || null;
  let hit = null;
  // 建物 (AABB)
  for (const b of Live.buildings) {
    const dx = pos.x - b.x;
    const dz = pos.z - b.z;
    const halfX = b.hx + radius;
    const halfZ = b.hz + radius;
    if (Math.abs(dx) < halfX && Math.abs(dz) < halfZ) {
      const overlapX = halfX - Math.abs(dx);
      const overlapZ = halfZ - Math.abs(dz);
      if (overlapX < overlapZ) {
        pos.x = b.x + (dx>=0?1:-1) * halfX;
        hit = { type:'building', nx: (dx>=0?1:-1), nz: 0, obj: b, speed: 0 };
      } else {
        pos.z = b.z + (dz>=0?1:-1) * halfZ;
        hit = { type:'building', nx: 0, nz: (dz>=0?1:-1), obj: b, speed: 0 };
      }
    }
  }
  // 車 (OBB)
  for (const c of Live.cars) {
    if (c === ignoreCar) continue;
    const dx = pos.x - c.pos.x;
    const dz = pos.z - c.pos.z;
    // 車ローカル系へ変換 (yaw=0 で +zが前)
    const cs = Math.cos(c.yaw), sn = Math.sin(c.yaw);
    const lx =  dx * cs - dz * sn;
    const lz =  dx * sn + dz * cs;
    const hx = 0.85 + radius;
    const hz = 1.7 + radius;
    if (Math.abs(lx) < hx && Math.abs(lz) < hz) {
      const overlapX = hx - Math.abs(lx);
      const overlapZ = hz - Math.abs(lz);
      let newLx = lx, newLz = lz, nlx = 0, nlz = 0;
      if (overlapX < overlapZ) {
        const sgn = lx>=0?1:-1; nlx = sgn;
        newLx = sgn * hx;
      } else {
        const sgn = lz>=0?1:-1; nlz = sgn;
        newLz = sgn * hz;
      }
      // ワールドへ逆変換
      const wx = newLx * cs + newLz * sn;
      const wz = -newLx * sn + newLz * cs;
      pos.x = c.pos.x + wx;
      pos.z = c.pos.z + wz;
      const nx = nlx * cs + nlz * sn;
      const nz = -nlx * sn + nlz * cs;
      hit = { type:'car', nx, nz, obj: c, speed: Math.abs(c.speed||0) };
    }
  }
  return hit;
}

// 死体ラグドール化
function _makeRagdoll(group, impulse) {
  if (!group || !group._parts || group._ragdolled) return;
  group._ragdolled = true;
  const parts = group._parts;
  const ragdoll = { parts: [], life: 0 };
  const ix = impulse ? impulse.x : (Math.random()-0.5)*2;
  const iy = impulse ? impulse.y : 2 + Math.random()*2;
  const iz = impulse ? impulse.z : (Math.random()-0.5)*2;
  Object.keys(parts).forEach(k => {
    const p = parts[k];
    if (!p) return;
    p.updateMatrixWorld(true);
    const wp = new THREE_L.Vector3();
    const wq = new THREE_L.Quaternion();
    p.getWorldPosition(wp);
    p.getWorldQuaternion(wq);
    Live.scene.attach(p);
    p.position.copy(wp);
    p.quaternion.copy(wq);
    ragdoll.parts.push({
      mesh: p,
      vel: new THREE_L.Vector3(
        ix + (Math.random()-0.5)*3,
        iy + Math.random()*2,
        iz + (Math.random()-0.5)*3
      ),
      angVel: new THREE_L.Vector3(
        (Math.random()-0.5)*8,
        (Math.random()-0.5)*8,
        (Math.random()-0.5)*8
      ),
      restY: 0.15 + Math.random()*0.15,
    });
  });
  group.visible = false;
  Live.ragdolls.push(ragdoll);
}

function _updateRagdolls(dt) {
  const GRAV = 22;
  for (let i=Live.ragdolls.length-1; i>=0; i--) {
    const r = Live.ragdolls[i];
    r.life += dt;
    r.parts.forEach(p => {
      p.vel.y -= GRAV * dt;
      p.mesh.position.x += p.vel.x * dt;
      p.mesh.position.y += p.vel.y * dt;
      p.mesh.position.z += p.vel.z * dt;
      p.mesh.rotation.x += p.angVel.x * dt;
      p.mesh.rotation.y += p.angVel.y * dt;
      p.mesh.rotation.z += p.angVel.z * dt;
      // 地面
      if (p.mesh.position.y < p.restY) {
        p.mesh.position.y = p.restY;
        if (p.vel.y < 0) p.vel.y = -p.vel.y * 0.25;
        p.vel.x *= 0.6; p.vel.z *= 0.6;
        p.angVel.multiplyScalar(0.55);
      }
      // 建物
      for (const b of Live.buildings) {
        const dx = p.mesh.position.x - b.x;
        const dz = p.mesh.position.z - b.z;
        const hx = b.hx + 0.15, hz = b.hz + 0.15;
        if (Math.abs(dx) < hx && Math.abs(dz) < hz) {
          const ox = hx - Math.abs(dx);
          const oz = hz - Math.abs(dz);
          if (ox < oz) {
            p.mesh.position.x = b.x + (dx>=0?1:-1)*hx;
            p.vel.x = -p.vel.x * 0.3;
          } else {
            p.mesh.position.z = b.z + (dz>=0?1:-1)*hz;
            p.vel.z = -p.vel.z * 0.3;
          }
        }
      }
      // 摩擦
      p.vel.x *= (1 - dt*0.4);
      p.vel.z *= (1 - dt*0.4);
      p.angVel.multiplyScalar(1 - dt*0.6);
    });
    if (r.life > 30) {
      r.parts.forEach(p => { try { Live.scene.remove(p.mesh); } catch(e){} });
      Live.ragdolls.splice(i,1);
    }
  }
}

/* ============ 街構築 ============ */
function _liveBuild() {
  const stage = document.getElementById('liveStage');
  const w = stage.clientWidth, h = stage.clientHeight;
  const sc = new THREE_L.Scene();
  sc.background = new THREE_L.Color(0x86b6e0);
  sc.fog = new THREE_L.Fog(0x86b6e0, 60, 220);
  Live.scene = sc;

  const cam = new THREE_L.PerspectiveCamera(60, w/h, 0.1, 600);
  cam.position.set(0, Live.CAM_HEIGHT, Live.CAM_DIST);
  cam.lookAt(0,0,0);
  Live.camera = cam;

  const renderer = new THREE_L.WebGLRenderer({ antialias:false, powerPreference:'high-performance' });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
  renderer.setSize(w, h, false);
  renderer.shadowMap.enabled = false;
  Live.renderer = renderer;
  document.getElementById('liveThree').appendChild(renderer.domElement);

  // ライト
  const amb = new THREE_L.AmbientLight(0xffffff, 0.7);
  sc.add(amb);
  const dir = new THREE_L.DirectionalLight(0xfff2c8, 0.8);
  dir.position.set(40, 80, 30);
  sc.add(dir);

  // 地面 (グレー)
  const ground = new THREE_L.Mesh(
    new THREE_L.PlaneGeometry(Live.CITY_SIZE*2, Live.CITY_SIZE*2),
    new THREE_L.MeshLambertMaterial({ color: 0x4a5560 })
  );
  ground.rotation.x = -Math.PI/2;
  sc.add(ground);

  _buildRoadsAndBlocks(sc);
  _spawnPlayer(sc);
  _spawnTraffic(sc);
  _spawnPedestrians(sc);
  _spawnPolice(sc);

  _wireLiveInput();
}

/* 道路グリッド + 建物 + 信号 */
function _buildRoadsAndBlocks(sc) {
  const SIZE = Live.CITY_SIZE;
  const BL = Live.BLOCK;
  const RW = Live.ROAD_W;
  const half = SIZE/2;

  // 道路: グリッドで横/縦 道路を配置
  const roadMat = new THREE_L.MeshLambertMaterial({ color: 0x2a2d33 });
  const lineMat = new THREE_L.MeshBasicMaterial({ color: 0xf6e26b });
  const sideMat = new THREE_L.MeshLambertMaterial({ color: 0x7f868f });

  const nodeKey = (x,z) => x+','+z;
  const nodeMap = new Map(); // key -> idx
  const nodes = [];
  function addNode(x,z) {
    const k = nodeKey(x,z);
    if (nodeMap.has(k)) return nodeMap.get(k);
    nodeMap.set(k, nodes.length);
    nodes.push({ x, z, neighbors:[] });
    return nodes.length-1;
  }
  function link(a,b) {
    if (a===b) return;
    if (!nodes[a].neighbors.includes(b)) nodes[a].neighbors.push(b);
    if (!nodes[b].neighbors.includes(a)) nodes[b].neighbors.push(a);
  }

  const lines = [];
  for (let v=-half; v<=half; v+=BL) lines.push(v);

  // 横方向道路 (z=v)
  lines.forEach(z => {
    const g = new THREE_L.Mesh(
      new THREE_L.PlaneGeometry(SIZE, RW),
      roadMat
    );
    g.rotation.x = -Math.PI/2;
    g.position.set(0, 0.02, z);
    sc.add(g);
    // 黄線
    const yl = new THREE_L.Mesh(new THREE_L.PlaneGeometry(SIZE, 0.18), lineMat);
    yl.rotation.x = -Math.PI/2; yl.position.set(0, 0.04, z); sc.add(yl);
  });
  // 縦方向道路 (x=v)
  lines.forEach(x => {
    const g = new THREE_L.Mesh(
      new THREE_L.PlaneGeometry(RW, SIZE),
      roadMat
    );
    g.rotation.x = -Math.PI/2;
    g.position.set(x, 0.02, 0);
    sc.add(g);
    const yl = new THREE_L.Mesh(new THREE_L.PlaneGeometry(0.18, SIZE), lineMat);
    yl.rotation.x = -Math.PI/2; yl.position.set(x, 0.04, 0); sc.add(yl);
  });

  // 交差点ノード追加
  lines.forEach(x => lines.forEach(z => addNode(x, z)));
  // 隣接接続
  for (let i=0; i<lines.length; i++) {
    for (let j=0; j<lines.length; j++) {
      const me = nodeMap.get(nodeKey(lines[i], lines[j]));
      if (i+1<lines.length) link(me, nodeMap.get(nodeKey(lines[i+1], lines[j])));
      if (j+1<lines.length) link(me, nodeMap.get(nodeKey(lines[i], lines[j+1])));
    }
  }
  Live.roadNodes = nodes;

  // 建物 (各ブロック内に1-2個)
  const colors = [0x8a99a8, 0xa68c6d, 0xbf6e6e, 0x7aa68c, 0x6d8aa6, 0xa6a06d, 0x9e7aa6];
  for (let i=0; i<lines.length-1; i++) {
    for (let j=0; j<lines.length-1; j++) {
      const cx = (lines[i]+lines[i+1])/2;
      const cz = (lines[j]+lines[j+1])/2;
      const sizeX = BL - RW - 4;
      const sizeZ = BL - RW - 4;
      // メインビル
      const bh = 4 + Math.random()*16;
      const col = colors[Math.floor(Math.random()*colors.length)];
      const b = new THREE_L.Mesh(
        new THREE_L.BoxGeometry(sizeX*0.7, bh, sizeZ*0.7),
        new THREE_L.MeshLambertMaterial({ color: col })
      );
      const bOffX = (Math.random()-0.5)*2;
      const bOffZ = (Math.random()-0.5)*2;
      b.position.set(cx + bOffX, bh/2, cz + bOffZ);
      sc.add(b);
      // コリジョンAABBを登録
      Live.buildings.push({
        x: cx + bOffX,
        z: cz + bOffZ,
        hx: sizeX*0.7/2,
        hz: sizeZ*0.7/2,
        h: bh,
      });
      // 窓のテクスチャ代わり (細いボックスで枠)
      if (Math.random() > 0.4) {
        const b2 = new THREE_L.Mesh(
          new THREE_L.BoxGeometry(sizeX*0.3, bh*0.6, sizeZ*0.3),
          new THREE_L.MeshLambertMaterial({ color: col*0.85|0 })
        );
        b2.position.set(cx + (Math.random()-0.5)*sizeX*0.4, bh*0.3, cz + (Math.random()-0.5)*sizeZ*0.4);
        sc.add(b2);
      }
      // 歩道
      const sw = new THREE_L.Mesh(
        new THREE_L.PlaneGeometry(BL - RW - 0.2, BL - RW - 0.2),
        sideMat
      );
      sw.rotation.x = -Math.PI/2;
      sw.position.set(cx, 0.025, cz);
      sc.add(sw);
    }
  }

  // 信号機 (各交差点ノードに設置)
  nodes.forEach(n => {
    // 縁の極端な交差点 (境界) はスキップ
    if (Math.abs(n.x) === half || Math.abs(n.z) === half) return;
    const grp = new THREE_L.Group();
    const pole = new THREE_L.Mesh(
      new THREE_L.CylinderGeometry(0.15, 0.15, 4, 8),
      new THREE_L.MeshLambertMaterial({ color: 0x222 })
    );
    pole.position.y = 2;
    grp.add(pole);
    const head = new THREE_L.Mesh(
      new THREE_L.BoxGeometry(0.6, 1.8, 0.4),
      new THREE_L.MeshLambertMaterial({ color: 0x111 })
    );
    head.position.y = 4.2;
    grp.add(head);
    const r = new THREE_L.Mesh(new THREE_L.SphereGeometry(0.18, 8, 8), new THREE_L.MeshBasicMaterial({ color: 0x550000 }));
    r.position.set(0.21, 4.7, 0); grp.add(r);
    const y = new THREE_L.Mesh(new THREE_L.SphereGeometry(0.18, 8, 8), new THREE_L.MeshBasicMaterial({ color: 0x553300 }));
    y.position.set(0.21, 4.2, 0); grp.add(y);
    const g = new THREE_L.Mesh(new THREE_L.SphereGeometry(0.18, 8, 8), new THREE_L.MeshBasicMaterial({ color: 0x005500 }));
    g.position.set(0.21, 3.7, 0); grp.add(g);

    // 位置: 交差点角
    grp.position.set(n.x + Live.ROAD_W/2 + 0.3, 0, n.z + Live.ROAD_W/2 + 0.3);
    sc.add(grp);

    const tl = { x:n.x, z:n.z, state:'green', t:Math.random()*8, group:grp,
                 bulbs:{ r, y, g }, axisV: Math.random()<0.5 };
    Live.trafficLights.push(tl);
  });
}

/* ============ プレイヤー ============ */
function _spawnPlayer(sc) {
  const grp = _makeStickman(0xffe0b5, 0x4d6cff);
  grp.position.set(0, 0, 0);
  sc.add(grp);
  Live.player = {
    pos: new THREE_L.Vector3(0, 0, 0),
    vel: new THREE_L.Vector3(),
    yaw: 0,
    hp: 100,
    inCar: null,
    group: grp,
    attackCD: 0,
    flashT: 0,
  };
  Live.hp = 100;
  _updateLiveHUD();
}

function _makeStickman(skin, cloth, isCop) {
  const g = new THREE_L.Group();
  // 体
  const body = new THREE_L.Mesh(
    new THREE_L.BoxGeometry(0.7, 1.0, 0.4),
    new THREE_L.MeshLambertMaterial({ color: isCop ? 0x223388 : cloth })
  );
  body.position.y = 0.9;
  g.add(body);
  // 頭
  const head = new THREE_L.Mesh(
    new THREE_L.SphereGeometry(0.32, 12, 10),
    new THREE_L.MeshLambertMaterial({ color: skin })
  );
  head.position.y = 1.7;
  g.add(head);
  if (isCop) {
    // 帽子
    const hat = new THREE_L.Mesh(
      new THREE_L.CylinderGeometry(0.32, 0.34, 0.18, 12),
      new THREE_L.MeshLambertMaterial({ color: 0x0b1f4e })
    );
    hat.position.y = 1.95;
    g.add(hat);
  }
  // 腕
  const armMat = new THREE_L.MeshLambertMaterial({ color: skin });
  const armL = new THREE_L.Mesh(new THREE_L.BoxGeometry(0.18, 0.8, 0.18), armMat);
  armL.position.set(-0.46, 0.95, 0); g.add(armL);
  const armR = new THREE_L.Mesh(new THREE_L.BoxGeometry(0.18, 0.8, 0.18), armMat);
  armR.position.set(0.46, 0.95, 0); g.add(armR);
  // 脚
  const legMat = new THREE_L.MeshLambertMaterial({ color: 0x222 });
  const legL = new THREE_L.Mesh(new THREE_L.BoxGeometry(0.22, 0.9, 0.22), legMat);
  legL.position.set(-0.18, 0.0, 0); g.add(legL);
  const legR = new THREE_L.Mesh(new THREE_L.BoxGeometry(0.22, 0.9, 0.22), legMat);
  legR.position.set(0.18, 0.0, 0); g.add(legR);
  legL.position.y = 0.0; legR.position.y = 0.0;
  // 中心調整: 足元を地面に
  g.children.forEach(c => { c.position.y += 0.45; });
  g._parts = { armL, armR, legL, legR, head };
  return g;
}

/* ============ 信号機 + 車 ============ */
function _spawnTraffic(sc) {
  // 車を 8 台 道路ノード周辺で生成
  for (let i=0; i<10; i++) {
    _spawnCar(sc, null, false);
  }
}

function _spawnCar(sc, atPos, isPolice) {
  const colors = [0xd64545, 0x4f7be8, 0x3aaa6a, 0xe5b22d, 0xb0b0b0, 0xffffff, 0x3a3a3a];
  const col = isPolice ? 0xffffff : colors[Math.floor(Math.random()*colors.length)];
  const grp = new THREE_L.Group();
  // ボディ
  const body = new THREE_L.Mesh(
    new THREE_L.BoxGeometry(1.6, 0.6, 3.2),
    new THREE_L.MeshLambertMaterial({ color: col })
  );
  body.position.y = 0.5;
  grp.add(body);
  // 屋根
  const roofCol = isPolice ? 0x1a3a8e : col;
  const roof = new THREE_L.Mesh(
    new THREE_L.BoxGeometry(1.4, 0.5, 1.6),
    new THREE_L.MeshLambertMaterial({ color: roofCol })
  );
  roof.position.set(0, 0.95, -0.1);
  grp.add(roof);
  // 窓 (黒)
  const win = new THREE_L.Mesh(
    new THREE_L.BoxGeometry(1.42, 0.4, 1.4),
    new THREE_L.MeshLambertMaterial({ color: 0x111 })
  );
  win.position.set(0, 1.0, -0.1);
  grp.add(win);
  // タイヤ
  const tireMat = new THREE_L.MeshLambertMaterial({ color: 0x111 });
  [[-0.8,-1.0],[0.8,-1.0],[-0.8,1.0],[0.8,1.0]].forEach(([x,z]) => {
    const t = new THREE_L.Mesh(new THREE_L.CylinderGeometry(0.3,0.3,0.25,10), tireMat);
    t.rotation.z = Math.PI/2;
    t.position.set(x, 0.3, z);
    grp.add(t);
  });
  if (isPolice) {
    const lr = new THREE_L.Mesh(new THREE_L.BoxGeometry(0.25,0.12,0.25), new THREE_L.MeshBasicMaterial({ color:0xff2020 }));
    lr.position.set(-0.25, 1.25, 0); grp.add(lr);
    const lb = new THREE_L.Mesh(new THREE_L.BoxGeometry(0.25,0.12,0.25), new THREE_L.MeshBasicMaterial({ color:0x2030ff }));
    lb.position.set(0.25, 1.25, 0); grp.add(lb);
    grp._sirens = { lr, lb };
  }

  // 道路ノード上に配置
  let node;
  if (atPos) {
    grp.position.copy(atPos);
    node = _nearestRoadNode(atPos);
  } else {
    node = Live.roadNodes[Math.floor(Math.random()*Live.roadNodes.length)];
    grp.position.set(node.x, 0, node.z);
  }
  sc.add(grp);

  // 次の目的地ノード
  const nextIdx = node.neighbors[Math.floor(Math.random()*node.neighbors.length)];
  const next = Live.roadNodes[nextIdx];
  const dx = next.x - node.x, dz = next.z - node.z;
  grp.rotation.y = Math.atan2(dx, dz);

  const car = {
    group: grp,
    pos: new THREE_L.Vector3(node.x, 0, node.z),
    yaw: grp.rotation.y,
    speed: 0,
    maxSpeed: isPolice ? 14 : 9 + Math.random()*4,
    accel: 6,
    driver: null, // プレイヤー乗車中なら 'player', NPC なら NPCオブジェクト
    targetNode: nextIdx,
    currentNode: Live.roadNodes.indexOf(node),
    isPolice: isPolice,
    sirenT: 0,
    hp: 100,
  };
  Live.cars.push(car);
  return car;
}

function _nearestRoadNode(pos) {
  let best=null, bd=Infinity;
  Live.roadNodes.forEach((n,i)=>{
    const d = (n.x-pos.x)*(n.x-pos.x) + (n.z-pos.z)*(n.z-pos.z);
    if (d<bd) { bd=d; best=n; }
  });
  return best;
}

/* ============ NPC ============ */
function _spawnPedestrians(sc) {
  const PERSONALITIES = ['normal','normal','normal','timid','aggressive'];
  for (let i=0; i<14; i++) {
    const skin = [0xffe0b5, 0xd9a373, 0x8b5a2b, 0xf2c89e][Math.floor(Math.random()*4)];
    const cloth = [0xff7777, 0x77aaff, 0x88cc88, 0xddbb55, 0xcc77cc, 0x444444][Math.floor(Math.random()*6)];
    const g = _makeStickman(skin, cloth, false);
    // 歩道内に配置 (ブロック中心付近)
    const node = Live.roadNodes[Math.floor(Math.random()*Live.roadNodes.length)];
    const ox = (Math.random()<0.5?-1:1) * (Live.ROAD_W/2 + 1.2);
    const oz = (Math.random()<0.5?-1:1) * (Live.ROAD_W/2 + 1.2);
    g.position.set(node.x + ox + (Math.random()-0.5)*4, 0, node.z + oz + (Math.random()-0.5)*4);
    sc.add(g);
    const pers = PERSONALITIES[Math.floor(Math.random()*PERSONALITIES.length)];
    Live.npcs.push({
      group: g,
      pos: new THREE_L.Vector3().copy(g.position),
      yaw: Math.random()*Math.PI*2,
      hp: 50,
      pers,
      state: 'wander', // wander, waitLight, flee, attack, dead
      t: 0,
      target: null,
      stepT: Math.random()*Math.PI*2,
      speed: 2 + Math.random()*1.5,
    });
  }
}

function _spawnPolice(sc) {
  for (let i=0; i<3; i++) {
    const g = _makeStickman(0xffe0b5, 0x223388, true);
    const node = Live.roadNodes[Math.floor(Math.random()*Live.roadNodes.length)];
    g.position.set(node.x + (Math.random()-0.5)*6, 0, node.z + (Math.random()-0.5)*6);
    sc.add(g);
    Live.police.push({
      group: g,
      pos: new THREE_L.Vector3().copy(g.position),
      yaw: 0,
      hp: 120,
      state: 'patrol', // patrol, chase, attack, dead
      t: 0,
      stepT: 0,
      speed: 3.5,
      attackCD: 0,
    });
  }
  // 警察車両 1台
  _spawnCar(sc, null, true);
}

/* ============ 入力 ============ */
function _wireLiveInput() {
  const stickZone = document.getElementById('liveStickZone');
  const knob = document.getElementById('liveStickKnob');

  function setKnob(dx, dy) {
    knob.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
  }
  function getOrigin() {
    const r = stickZone.getBoundingClientRect();
    return { cx: r.left + r.width/2, cy: r.top + r.height/2, max: r.width*0.35 };
  }
  stickZone.addEventListener('pointerdown', e => {
    e.preventDefault();
    Live.joy.active = true; Live.joy.id = e.pointerId;
    const o = getOrigin();
    Live.joy.sx = o.cx; Live.joy.sy = o.cy;
    try { stickZone.setPointerCapture(e.pointerId); } catch(_){}
  });
  stickZone.addEventListener('pointermove', e => {
    if (!Live.joy.active || e.pointerId !== Live.joy.id) return;
    const o = getOrigin();
    let dx = e.clientX - o.cx, dy = e.clientY - o.cy;
    const r = Math.hypot(dx,dy);
    if (r > o.max) { dx = dx*o.max/r; dy = dy*o.max/r; }
    Live.joy.dx = dx/o.max; Live.joy.dy = dy/o.max;
    setKnob(dx, dy);
  });
  function endJoy(e) {
    if (e.pointerId !== Live.joy.id) return;
    Live.joy.active=false; Live.joy.dx=0; Live.joy.dy=0; Live.joy.id=null;
    setKnob(0,0);
  }
  stickZone.addEventListener('pointerup', endJoy);
  stickZone.addEventListener('pointercancel', endJoy);
  stickZone.addEventListener('pointerleave', endJoy);

  // ===== マウス/キーボード対応 =====
  if (!Live._kbBound) {
    Live._kbBound = true;
    Live._keys = {};
    window.addEventListener('keydown', e => {
      if (!Live.running) return;
      Live._keys[e.key.toLowerCase()] = true;
      if (e.key === 'f' || e.key === 'F') _liveTriggerCar();
      if (e.key === ' ') _liveTriggerAttack();
      if (e.key === 'Shift') _liveTriggerDash();
    });
    window.addEventListener('keyup', e => {
      Live._keys[e.key.toLowerCase()] = false;
    });
  }

  // ボタン
  const bind = (id, on, off) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('pointerdown', e=>{ e.preventDefault(); on&&on(); });
    el.addEventListener('pointerup', e=>{ e.preventDefault(); off&&off(); });
  };
  bind('lvBtnAttack', _liveTriggerAttack, null);
  bind('lvBtnCar', _liveTriggerCar, null);
  bind('lvBtnDash', _liveTriggerDash, null);
  bind('lvBtnHorn', _liveTriggerHorn, null);
}

function _liveTriggerAttack() {
  if (!Live.player || Live.player.attackCD > 0) return;
  if (Live.playerRagdoll) return;
  if (Live.player.inCar) {
    // 車から殴る不可。代わりに加速ぶつけは pass
    return;
  }
  if (Live.player.group._ragdolled || !Live.player.group._parts) return;
  Live.player.attackCD = 0.45;
  // 腕アニメ
  const arm = Live.player.group._parts.armR;
  arm.rotation.x = -1.6;
  setTimeout(()=>{ if (arm) arm.rotation.x = 0; }, 220);
  // 当たり判定: 半径 1.6 前方
  const fx = Math.sin(Live.player.yaw), fz = Math.cos(Live.player.yaw);
  const tx = Live.player.pos.x + fx*1.4;
  const tz = Live.player.pos.z + fz*1.4;
  let hit = false;
  // NPC
  Live.npcs.forEach(n => {
    if (n.state === 'dead') return;
    const d = Math.hypot(n.pos.x-tx, n.pos.z-tz);
    if (d < 1.4) {
      n.hp -= 30; hit = true;
      n.state = (n.pers === 'aggressive') ? 'attack' : 'flee';
      n.target = Live.player;
      n.t = 0;
      _addWanted(1);
      if (n.hp <= 0) { _killNPC(n, { x: fx*4, y: 4, z: fz*4 }); }
    }
  });
  // 警察
  Live.police.forEach(p => {
    if (p.state === 'dead') return;
    const d = Math.hypot(p.pos.x-tx, p.pos.z-tz);
    if (d < 1.4) {
      p.hp -= 30; hit = true;
      p.state = 'chase'; p.t = 0;
      _addWanted(2);
      if (p.hp <= 0) { _killCop(p, { x: fx*4, y: 4, z: fz*4 }); }
    }
  });
  // リモートプレイヤー (PVP)
  Live.remotes.forEach((r, pid) => {
    if (!r.group) return;
    const d = Math.hypot(r.group.position.x-tx, r.group.position.z-tz);
    if (d < 1.4) {
      // ヒット通知
      try { P2P.broadcast({ type:'live', sub:'hit', target: pid, dmg: 20, from: user.id }); } catch(e){}
      hit = true;
    }
  });
  if (hit) {
    _liveLog('💥 ヒット！');
  }
}

function _liveTriggerCar() {
  if (!Live.player) return;
  if (Live.playerRagdoll) return;
  if (Live.player.inCar) {
    // 降りる
    const car = Live.player.inCar;
    car.driver = null;
    Live.player.inCar = null;
    Live.player.group.visible = true;
    // 横に降ろす
    const sx = Math.cos(car.yaw), sz = -Math.sin(car.yaw);
    Live.player.pos.set(car.pos.x + sx*1.8, 0, car.pos.z + sz*1.8);
    _liveLog('🚪 車を降りた');
  } else {
    // 近くの車に乗る
    let best=null, bd=Infinity;
    Live.cars.forEach(c => {
      if (c.driver) return;
      const d = Math.hypot(c.pos.x-Live.player.pos.x, c.pos.z-Live.player.pos.z);
      if (d<bd && d<3.5) { bd=d; best=c; }
    });
    if (best) {
      // 運転中NPCがいたら追い出して奪取 → 手配アップ
      best.driver = 'player';
      Live.player.inCar = best;
      Live.player.group.visible = false;
      _liveLog('🚗 車に乗った');
      if (best.isPolice) _addWanted(2);
    } else {
      _liveLog('近くに車なし');
    }
  }
}

function _liveTriggerDash() {
  if (!Live.player || Live.player.inCar) return;
  if (Live.playerRagdoll) return;
  if (Live.dashCD > 0) return;
  Live.dashCD = 1.2;
  const fx = Math.sin(Live.player.yaw), fz = Math.cos(Live.player.yaw);
  Live.player.vel.x += fx * 8;
  Live.player.vel.z += fz * 8;
}

function _liveTriggerHorn() {
  if (!Live.player) return;
  _liveLog('🔊 ファーン！');
  // 近くのNPCを驚かせる
  Live.npcs.forEach(n => {
    if (n.state==='dead') return;
    const d = Math.hypot(n.pos.x-Live.player.pos.x, n.pos.z-Live.player.pos.z);
    if (d < 12 && n.pers === 'timid') { n.state='flee'; n.target = Live.player; n.t=0; }
  });
}

function _addWanted(n) {
  Live.wanted = Math.min(5, Live.wanted + n*0.2);
  _updateLiveHUD();
}

function _killNPC(n, impulse) {
  if (n.state === 'dead') return;
  n.state = 'dead';
  _makeRagdoll(n.group, impulse);
  Live.kills++;
  Live.cash += 50;
  _addWanted(3);
  _liveLog('☠️ 市民を倒した (+$50)');
  _updateLiveHUD();
}
function _killCop(p, impulse) {
  if (p.state === 'dead') return;
  p.state = 'dead';
  _makeRagdoll(p.group, impulse);
  Live.kills++;
  Live.cash += 200;
  _addWanted(5);
  _liveLog('🚨 警官を倒した (+$200)');
  _updateLiveHUD();
}

function _updateLiveHUD() {
  const el = id => document.getElementById(id);
  if (el('liveHp')) el('liveHp').textContent = Math.max(0, Math.round(Live.hp));
  if (el('liveCash')) el('liveCash').textContent = Live.cash;
  if (el('liveKills')) el('liveKills').textContent = Live.kills;
  if (el('liveWanted')) {
    const w = Math.round(Live.wanted);
    el('liveWanted').textContent = '★'.repeat(w) + '☆'.repeat(5-w);
  }
  if (el('liveInfo')) {
    const np = P2P.conns ? P2P.conns.size : 0;
    el('liveInfo').textContent = np>0 ? ('PVPVE ' + (np+1)+ '人') : 'PVE (ソロ)';
  }
}

/* ============ メインループ ============ */
function _liveLoop() {
  if (!Live.running) return;
  Live.rafId = requestAnimationFrame(_liveLoop);
  const dt = Math.min(0.05, Live.clock.getDelta());

  _liveUpdateInputDir();
  _liveUpdatePlayer(dt);
  _liveUpdateTrafficLights(dt);
  _liveUpdateCars(dt);
  _liveUpdateNPCs(dt);
  _liveUpdatePolice(dt);
  _updateRagdolls(dt);
  _liveUpdateCamera(dt);
  _liveUpdateNetwork(dt);
  // ミニマップは3フレームに1回だけ更新 (描画負荷削減)
  Live._minimapSkip = ((Live._minimapSkip || 0) + 1) % 3;
  if (Live._minimapSkip === 0) _liveDrawMinimap();

  Live.renderer.render(Live.scene, Live.camera);
}

function _liveUpdateInputDir() {
  // KB
  const k = Live._keys || {};
  let dx=Live.joy.dx, dy=Live.joy.dy;
  if (k['w'] || k['arrowup']) dy = -1;
  if (k['s'] || k['arrowdown']) dy = 1;
  if (k['a'] || k['arrowleft']) dx = -1;
  if (k['d'] || k['arrowright']) dx = 1;
  Live._inDx = dx; Live._inDy = dy;
}

function _liveUpdatePlayer(dt) {
  if (!Live.player) return;
  Live.player.attackCD = Math.max(0, Live.player.attackCD - dt);
  Live.dashCD = Math.max(0, Live.dashCD - dt);

  const dx = Live._inDx || 0, dy = Live._inDy || 0;
  const mag = Math.hypot(dx, dy);

  if (Live.player.inCar) {
    // 車両操作: dy=前後、dx=ステア
    const car = Live.player.inCar;
    const steer = dx * 1.8;
    car.yaw -= steer * dt * (Math.abs(car.speed)/4 + 0.4);
    let accel = 0;
    if (mag > 0.1) {
      accel = -dy * car.accel * 2.5; // 上が前進
    } else {
      // 自然減速
      car.speed *= 0.96;
    }
    car.speed += accel * dt;
    car.speed = Math.max(-car.maxSpeed*0.6, Math.min(car.maxSpeed*1.4, car.speed));
    // 移動
    const fx = Math.sin(car.yaw), fz = Math.cos(car.yaw);
    car.pos.x += fx * car.speed * dt;
    car.pos.z += fz * car.speed * dt;
    _clampCity(car.pos);
    car.group.position.copy(car.pos);
    car.group.rotation.y = car.yaw;
    // プレイヤー位置を車に追随
    Live.player.pos.copy(car.pos);
    Live.player.yaw = car.yaw;
    // 車で人を轢く
    if (Math.abs(car.speed) > 5) {
      Live.npcs.forEach(n => {
        if (n.state==='dead') return;
        const d = Math.hypot(n.pos.x-car.pos.x, n.pos.z-car.pos.z);
        if (d < 1.6) {
          n.hp -= 80;
          if (n.hp<=0) {
            const cfx = Math.sin(car.yaw), cfz = Math.cos(car.yaw);
            const sp = Math.abs(car.speed);
            _killNPC(n, { x: cfx*(3+sp*0.5), y: 4+sp*0.2, z: cfz*(3+sp*0.5) });
          }
          else { n.state='flee'; n.target=Live.player; }
        }
      });
      Live.police.forEach(p => {
        if (p.state==='dead') return;
        const d = Math.hypot(p.pos.x-car.pos.x, p.pos.z-car.pos.z);
        if (d < 1.6) {
          p.hp -= 60;
          if (p.hp<=0) {
            const cfx = Math.sin(car.yaw), cfz = Math.cos(car.yaw);
            const sp = Math.abs(car.speed);
            _killCop(p, { x: cfx*(3+sp*0.5), y: 4+sp*0.2, z: cfz*(3+sp*0.5) });
          }
          else { p.state='chase'; p.t=0; }
        }
      });
    }
    // 車自身も建物にコリジョン
    const carHit = _resolveCollision(car.pos, 1.4, { ignoreCar: car });
    if (carHit && carHit.type === 'building') {
      if (Math.abs(car.speed) > 6) _liveLog('💥 車が建物に激突');
      car.speed *= -0.25;
      car.group.position.copy(car.pos);
    }
  } else if (Live.playerRagdoll) {
    // ラグドール中は入力無視 / 一定時間で死亡処理
    Live.playerRagdoll.t = (Live.playerRagdoll.t || 0) + dt;
    if (Live.playerRagdoll.t > 2.5) {
      _liveDeath();
    }
  } else {
    // 徒歩 (車と同じシステム: dx=ステア / dy=前後)
    const maxSpeed = 5.0;
    if (mag > 0.12) {
      const steer = dx; // -1 ~ 1
      const turnRate = 2.8; // rad/s
      Live.player.yaw -= steer * turnRate * dt * (Math.abs(dy)*0.6 + 0.6);
      const targetSpd = -dy * maxSpeed; // dy<0 で前進
      const fx = Math.sin(Live.player.yaw), fz = Math.cos(Live.player.yaw);
      const tx = fx * targetSpd;
      const tz = fz * targetSpd;
      Live.player.vel.x += (tx - Live.player.vel.x) * Math.min(1, dt*9);
      Live.player.vel.z += (tz - Live.player.vel.z) * Math.min(1, dt*9);
    } else {
      Live.player.vel.x *= 0.80;
      Live.player.vel.z *= 0.80;
    }
    Live.player.pos.x += Live.player.vel.x * dt;
    Live.player.pos.z += Live.player.vel.z * dt;
    _clampCity(Live.player.pos);
    // コリジョン解決
    const hit = _resolveCollision(Live.player.pos, 0.45, {});
    if (hit) {
      if (hit.type === 'car' && hit.speed > 4.5 && !Live.playerRagdoll) {
        const impulse = {
          x: -hit.nx * (3 + hit.speed*0.5),
          y: 4 + hit.speed*0.25,
          z: -hit.nz * (3 + hit.speed*0.5),
        };
        _makeRagdoll(Live.player.group, impulse);
        Live.playerRagdoll = { t: 0 };
        Live.hp = 0;
        _liveLog('💥 車に轢かれた！');
      } else {
        const dot = Live.player.vel.x*hit.nx + Live.player.vel.z*hit.nz;
        if (dot < 0) {
          Live.player.vel.x -= dot*hit.nx;
          Live.player.vel.z -= dot*hit.nz;
        }
      }
    }
    if (!Live.player.group._ragdolled) {
      Live.player.group.position.copy(Live.player.pos);
      Live.player.group.rotation.y = Live.player.yaw;
      // 歩行アニメ
      const moving = (Math.abs(Live.player.vel.x) + Math.abs(Live.player.vel.z)) > 0.5;
      if (moving) {
        const t = performance.now()/180;
        const pp = Live.player.group._parts;
        pp.legL.rotation.x = Math.sin(t)*0.6;
        pp.legR.rotation.x = -Math.sin(t)*0.6;
        pp.armL.rotation.x = -Math.sin(t)*0.4;
        pp.armR.rotation.x = Math.sin(t)*0.4;
      } else {
        const pp = Live.player.group._parts;
        pp.legL.rotation.x*=0.7; pp.legR.rotation.x*=0.7;
        pp.armL.rotation.x*=0.7; pp.armR.rotation.x*=0.7;
      }
    }
  }
  _updateLiveHUD();
}

function _clampCity(v) {
  const half = Live.CITY_SIZE/2 - 2;
  if (v.x < -half) v.x = -half;
  if (v.x >  half) v.x =  half;
  if (v.z < -half) v.z = -half;
  if (v.z >  half) v.z =  half;
}

function _liveUpdateTrafficLights(dt) {
  Live.trafficLights.forEach(tl => {
    tl.t -= dt;
    if (tl.t <= 0) {
      if (tl.state==='green') { tl.state='yellow'; tl.t = 1.4; }
      else if (tl.state==='yellow') { tl.state='red'; tl.t = 5; }
      else { tl.state='green'; tl.t = 5; }
      const dim = 0x222222;
      tl.bulbs.r.material.color.setHex(tl.state==='red' ? 0xff2020 : 0x550000);
      tl.bulbs.y.material.color.setHex(tl.state==='yellow' ? 0xffdd20 : 0x553300);
      tl.bulbs.g.material.color.setHex(tl.state==='green' ? 0x20ff20 : 0x005500);
    }
  });
}

/* 信号機の状態を取得: 車両が交差点に近づいた時 */
function _trafficStateAt(x, z, dirZ) {
  // dirZ: 走行方向の主軸が +z/-z (true) か +x/-x (false)
  // 信号は交差点に1つで、軸により赤/青を切替
  let best=null, bd=Infinity;
  Live.trafficLights.forEach(tl=>{
    const d = (tl.x-x)*(tl.x-x) + (tl.z-z)*(tl.z-z);
    if (d<bd) { bd=d; best=tl; }
  });
  if (!best || bd > 30) return 'green';
  // axisV: trueなら縦方向が緑時赤、横方向が赤 (簡易: 同じstateを使うが、軸違いは逆)
  if (best.axisV === dirZ) return best.state;
  // 逆軸
  if (best.state==='green') return 'red';
  if (best.state==='red') return 'green';
  return 'yellow';
}

function _liveUpdateCars(dt) {
  Live.cars.forEach(car => {
    if (car.driver === 'player') return; // プレイヤー操縦中
    // AI: 現在ノード→目標ノードへ進む
    const target = Live.roadNodes[car.targetNode];
    const dx = target.x - car.pos.x;
    const dz = target.z - car.pos.z;
    const dist = Math.hypot(dx, dz);
    if (dist < 1.2) {
      // 次ノード選択
      car.currentNode = car.targetNode;
      const cur = Live.roadNodes[car.currentNode];
      // 元の方向を避け、ランダムに選ぶ
      const cand = cur.neighbors.slice();
      if (cand.length>1) {
        // 直前のノードを除外
        for (let i=cand.length-1; i>=0; i--) {
          if (cand[i] === car._prevNode) cand.splice(i,1);
        }
      }
      car._prevNode = car.currentNode;
      car.targetNode = cand[Math.floor(Math.random()*cand.length)];
    }
    // 向き
    const desiredYaw = Math.atan2(dx, dz);
    let dyaw = desiredYaw - car.yaw;
    while (dyaw > Math.PI) dyaw -= Math.PI*2;
    while (dyaw < -Math.PI) dyaw += Math.PI*2;
    car.yaw += dyaw * Math.min(1, dt*4);

    // 信号機チェック: 交差点に近付いたら止まる
    const curNode = Live.roadNodes[car.currentNode];
    const distFromCur = Math.hypot(car.pos.x - curNode.x, car.pos.z - curNode.z);
    // 走行軸方向 (前進方向の z 成分が大きいか x か)
    const fz_dir = Math.abs(Math.cos(car.yaw)) > Math.abs(Math.sin(car.yaw));
    // 交差点直前 (target に対し残り 4-7) で信号判定
    let stopForLight = false;
    if (dist < 6 && dist > 2) {
      const st = _trafficStateAt(target.x, target.z, fz_dir);
      if (st === 'red') stopForLight = true;
    }

    // 警察車両: プレイヤー追跡
    if (car.isPolice && Live.wanted >= 2) {
      // プレイヤー方向に切替
      const pdx = Live.player.pos.x - car.pos.x;
      const pdz = Live.player.pos.z - car.pos.z;
      const pdist = Math.hypot(pdx, pdz);
      if (pdist < 60) {
        const py = Math.atan2(pdx, pdz);
        let dy = py - car.yaw;
        while (dy>Math.PI) dy-=Math.PI*2;
        while (dy<-Math.PI) dy+=Math.PI*2;
        car.yaw += dy * Math.min(1, dt*3);
        stopForLight = false; // 警察は信号無視
        car.maxSpeed = 18;
      }
      // サイレン点滅
      car.sirenT += dt;
      if (car._sirens) {
        const blink = Math.sin(car.sirenT*10) > 0;
        car._sirens.lr.visible = blink;
        car._sirens.lb.visible = !blink;
      }
    }

    // 前方車両確認
    const ahead = _carAhead(car, 4);
    if (ahead) stopForLight = true;

    // 加減速
    if (stopForLight) {
      car.speed -= car.accel * 1.5 * dt;
    } else {
      car.speed += car.accel * dt;
    }
    car.speed = Math.max(0, Math.min(car.maxSpeed, car.speed));
    const fx = Math.sin(car.yaw), fz = Math.cos(car.yaw);
    car.pos.x += fx * car.speed * dt;
    car.pos.z += fz * car.speed * dt;
    _clampCity(car.pos);
    car.group.position.copy(car.pos);
    car.group.rotation.y = car.yaw;
  });
}

function _carAhead(car, range) {
  const fx = Math.sin(car.yaw), fz = Math.cos(car.yaw);
  for (const o of Live.cars) {
    if (o===car) continue;
    const dx = o.pos.x - car.pos.x;
    const dz = o.pos.z - car.pos.z;
    const d = Math.hypot(dx,dz);
    if (d > range) continue;
    // 前方
    const dot = (dx*fx + dz*fz)/d;
    if (dot > 0.7) return o;
  }
  return null;
}

function _liveUpdateNPCs(dt) {
  const pl = Live.player;
  Live.npcs.forEach(n => {
    if (n.state === 'dead') return;
    n.t += dt;
    n.stepT += dt*5;
    const p = n.group._parts;

    if (n.state === 'wander') {
      // ランダム歩き + プレイヤーが近く + 性格で反応
      const pd = Math.hypot(pl.pos.x-n.pos.x, pl.pos.z-n.pos.z);
      if (n.pers === 'aggressive' && pd < 8 && Math.random() < 0.02) {
        n.state = 'attack'; n.target = pl; n.t = 0;
      } else if (n.pers === 'timid' && pd < 5) {
        n.state = 'flee'; n.target = pl; n.t = 0;
      }
      // 進行方向を時々変える
      if (n.t > 3 + Math.random()*2) {
        n.yaw = Math.random()*Math.PI*2;
        n.t = 0;
      }
      const speed = n.speed;
      n.pos.x += Math.sin(n.yaw)*speed*dt;
      n.pos.z += Math.cos(n.yaw)*speed*dt;
      // 街内クランプ + コリジョン
      _clampCity(n.pos);
      const nh = _resolveCollision(n.pos, 0.4, {});
      if (nh) { n.yaw = Math.random()*Math.PI*2; }
    } else if (n.state === 'flee') {
      const dx = n.pos.x - pl.pos.x, dz = n.pos.z - pl.pos.z;
      const d = Math.hypot(dx,dz)||1;
      n.yaw = Math.atan2(dx/d, dz/d);
      n.pos.x += dx/d * (n.speed*1.6) * dt;
      n.pos.z += dz/d * (n.speed*1.6) * dt;
      if (n.t > 4 || d > 22) { n.state='wander'; n.t=0; }
      _clampCity(n.pos);
      _resolveCollision(n.pos, 0.4, {});
    } else if (n.state === 'attack') {
      const dx = pl.pos.x - n.pos.x, dz = pl.pos.z - n.pos.z;
      const d = Math.hypot(dx,dz);
      n.yaw = Math.atan2(dx, dz);
      if (d > 1.4) {
        n.pos.x += dx/d * n.speed * 1.2 * dt;
        n.pos.z += dz/d * n.speed * 1.2 * dt;
      } else {
        // 攻撃
        if (n.t > 0.8) {
          n.t = 0;
          Live.hp -= 6;
          _liveLog('🥊 ' + (n.pers==='aggressive'?'攻撃的市民':'市民') + 'に殴られた');
          if (Live.hp <= 0) _liveDeath();
        }
      }
      _clampCity(n.pos);
    }
    // 表示 (ラグドール中はスキップ)
    if (!n.group._ragdolled) {
      n.group.position.copy(n.pos);
      n.group.rotation.y = n.yaw;
      p.legL.rotation.x = Math.sin(n.stepT)*0.5;
      p.legR.rotation.x = -Math.sin(n.stepT)*0.5;
    }
  });
}

function _liveUpdatePolice(dt) {
  const pl = Live.player;
  Live.police.forEach(p => {
    if (p.state === 'dead') return;
    p.t += dt;
    p.stepT += dt*5;
    p.attackCD = Math.max(0, p.attackCD - dt);
    const parts = p.group._parts;
    const pd = Math.hypot(pl.pos.x-p.pos.x, pl.pos.z-p.pos.z);

    // 手配中ならプレイヤーを追う
    if (Live.wanted >= 1 && pd < 50) {
      p.state = 'chase';
    }

    if (p.state === 'patrol') {
      if (p.t > 3) {
        p.yaw = Math.random()*Math.PI*2;
        p.t = 0;
      }
      p.pos.x += Math.sin(p.yaw)*p.speed*0.6*dt;
      p.pos.z += Math.cos(p.yaw)*p.speed*0.6*dt;
      _resolveCollision(p.pos, 0.4, {});
    } else if (p.state === 'chase') {
      if (Live.wanted < 1) { p.state='patrol'; p.t=0; }
      else {
        const dx = pl.pos.x - p.pos.x, dz = pl.pos.z - p.pos.z;
        const d = Math.hypot(dx,dz)||1;
        p.yaw = Math.atan2(dx/d, dz/d);
        if (d > 1.5) {
          p.pos.x += dx/d * p.speed * dt;
          p.pos.z += dz/d * p.speed * dt;
        } else if (p.attackCD<=0) {
          p.attackCD = 0.8;
          Live.hp -= 10;
          _liveLog('🚓 警官に殴られた');
          // 警棒アニメ
          parts.armR.rotation.x = -1.4;
          setTimeout(()=>{ if (parts.armR) parts.armR.rotation.x = 0; }, 220);
          if (Live.hp <= 0) _liveDeath();
        }
      }
    }
    _clampCity(p.pos);
    _resolveCollision(p.pos, 0.4, {});
    if (!p.group._ragdolled) {
      p.group.position.copy(p.pos);
      p.group.rotation.y = p.yaw;
      parts.legL.rotation.x = Math.sin(p.stepT)*0.6;
      parts.legR.rotation.x = -Math.sin(p.stepT)*0.6;
    }
  });

  // 手配徐々に減衰
  if (Live.wanted > 0) {
    Live.wanted = Math.max(0, Live.wanted - dt*0.02);
  }
}

function _liveRespawn() {
  // 完全なリスポーン処理 (原 _liveDeath)
  Live.hp = 100;
  Live.wanted = 0;
  Live.cash = Math.max(0, Live.cash - 100);
  Live.downed = null;
  Live.__instantDeathReason = '';
  // ラグドール状態だったら新しい体を作り直す
  if (Live.player.group && Live.player.group._ragdolled) {
    try { Live.scene.remove(Live.player.group); } catch(e){}
    const newG = _makeStickman(0xffe0b5, 0x4d6cff);
    Live.scene.add(newG);
    Live.player.group = newG;
  }
  if (Live.player.group) {
    Live.player.group.visible = true;
    Live.player.group._ragdolled = false;
    // 這いずりのオフセットを完全リセット
    if (Live.player.group._parts) {
      const p = Live.player.group._parts;
      if (p.head) { p.head.position.set(0, 1.7, 0); p.head.rotation.set(0,0,0); }
      if (p.armL) { p.armL.position.set(-0.46, 1.4, 0); p.armL.rotation.set(0,0,0); }
      if (p.armR) { p.armR.position.set(0.46, 1.4, 0); p.armR.rotation.set(0,0,0); }
      if (p.legL) { p.legL.position.set(-0.18, 0.45, 0); p.legL.rotation.set(0,0,0); }
      if (p.legR) { p.legR.position.set(0.18, 0.45, 0); p.legR.rotation.set(0,0,0); }
    }
  }
  Live.player.vel.set(0,0,0);
  Live.playerRagdoll = null;
  Live.player.pos.set(0, 0, 0);
  if (Live.player.inCar) {
    Live.player.inCar.driver = null;
    Live.player.inCar = null;
  }
  const bar = document.getElementById('liveReviveStatus');
  if (bar) bar.style.display = 'none';
  _liveCenterMsg('☠️ やられた...病院でリスポーン', 1800);
  _updateLiveHUD();
}

function _liveDeath() {
  // 即死フラグが立っている場合 (車に轢かれた等): 即リスポーン
  if (Live.__instantDeathReason || (Live.playerRagdoll && Live.playerRagdoll.fatal)) {
    Live.__instantDeathReason = '';
    return _liveRespawn();
  }
  // 既に瀕死状態なら何もしない (連続呼び出し対策)
  if (Live.downed) return;
  // HP0 になった瞬間: 瀕死 (這いずり) モードへ移行
  Live.hp = 0;
  if (Live.player && Live.player.inCar) {
    Live.player.inCar.driver = null;
    Live.player.inCar = null;
    if (Live.player.group) Live.player.group.visible = true;
  }
  if (Live.player) Live.player.vel.set(0, 0, 0);
  Live.downed = { remain: 20.0, total: 20.0 };
  if (typeof _liveCenterMsg === 'function') {
    _liveCenterMsg('💔 瀕死… 20秒だけ這いずれます', 1800);
  }
  if (typeof _liveLog === 'function') _liveLog('🩸 HP0! 20秒の瀕死状態に移行');
  if (typeof _updateLiveHUD === 'function') _updateLiveHUD();
}

function _liveUpdateCamera(dt) {
  const p = Live.player;
  if (!p) return;
  const yaw = p.yaw;
  const dist = p.inCar ? 12 : Live.CAM_DIST;
  const h = p.inCar ? 7 : Live.CAM_HEIGHT;
  const tx = p.pos.x - Math.sin(yaw)*dist;
  const tz = p.pos.z - Math.cos(yaw)*dist;
  const ty = h;
  Live.camera.position.x += (tx - Live.camera.position.x) * Math.min(1, dt*5);
  Live.camera.position.y += (ty - Live.camera.position.y) * Math.min(1, dt*5);
  Live.camera.position.z += (tz - Live.camera.position.z) * Math.min(1, dt*5);
  Live.camera.lookAt(p.pos.x, 1, p.pos.z);
}

/* ============ ネットワーク ============ */
function _liveUpdateNetwork(dt) {
  Live._netT += dt;
  if (Live._netT < 0.1) return;
  Live._netT = 0;
  if (!P2P || P2P.conns.size === 0) return;
  const p = Live.player;
  try {
    P2P.broadcast({
      type:'live', sub:'pos',
      uid: user.id,
      name: user.name,
      icon: user.icon,
      x: p.pos.x, z: p.pos.z, yaw: p.yaw,
      inCar: !!p.inCar,
      hp: Live.hp,
    });
  } catch(e){}
}

// P2P からの受信を処理
Live.onNet = function(peerId, d) {
  if (!Live.running) return;
  if (d.sub === 'pos') {
    let r = Live.remotes.get(peerId);
    if (!r) {
      const g = _makeStickman(0xffe0b5, 0x8a3aff, false);
      Live.scene.add(g);
      r = { group: g, hp: d.hp||100, name: d.name||'P2P', lastT: performance.now() };
      Live.remotes.set(peerId, r);
      _liveLog('👤 ' + (d.name||'プレイヤー') + ' 入場');
    }
    r.group.position.set(d.x, 0, d.z);
    r.group.rotation.y = d.yaw || 0;
    r.group.visible = !d.inCar;
    r.hp = d.hp;
    r.lastT = performance.now();
  } else if (d.sub === 'hit') {
    if (d.target === user.id) {
      Live.hp -= d.dmg||10;
      _liveLog('💥 ' + (d.fromName||'プレイヤー') + 'に殴られた');
      if (Live.hp <= 0) _liveDeath();
    }
  }
};

// 切断検出: 5秒以上 pos が来ないリモートは削除
setInterval(()=>{
  if (!Live.running) return;
  const now = performance.now();
  Live.remotes.forEach((r, pid) => {
    if (now - r.lastT > 6000 || !P2P.conns.has(pid)) {
      if (r.group && r.group.parent) r.group.parent.remove(r.group);
      Live.remotes.delete(pid);
    }
  });
}, 1500);

/* ============ ミニマップ ============ */
function _liveDrawMinimap() {
  const cv = document.getElementById('liveMinimapCanvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#1a1f28';
  ctx.fillRect(0,0,W,H);
  const half = Live.CITY_SIZE/2;
  const scale = W / Live.CITY_SIZE;
  const px = Live.player.pos.x, pz = Live.player.pos.z;
  const toMap = (x,z) => [(x+half)*scale, (z+half)*scale];

  // 道路グリッド (簡易)
  ctx.strokeStyle = '#3a4250';
  ctx.lineWidth = 1.6;
  const BL = Live.BLOCK;
  for (let v=-half; v<=half; v+=BL) {
    let [_, y1] = toMap(0, v);
    ctx.beginPath(); ctx.moveTo(0, y1); ctx.lineTo(W, y1); ctx.stroke();
    let [x1, __] = toMap(v, 0);
    ctx.beginPath(); ctx.moveTo(x1, 0); ctx.lineTo(x1, H); ctx.stroke();
  }
  // 車
  ctx.fillStyle = '#9ec5ff';
  Live.cars.forEach(c => {
    if (c.isPolice) return;
    const [mx, my] = toMap(c.pos.x, c.pos.z);
    ctx.fillRect(mx-1.5, my-1.5, 3, 3);
  });
  // 警察車
  ctx.fillStyle = '#ff4040';
  Live.cars.forEach(c => {
    if (!c.isPolice) return;
    const [mx, my] = toMap(c.pos.x, c.pos.z);
    ctx.fillRect(mx-2, my-2, 4, 4);
  });
  // 警察(歩)
  Live.police.forEach(p => {
    if (p.state==='dead') return;
    const [mx, my] = toMap(p.pos.x, p.pos.z);
    ctx.beginPath(); ctx.arc(mx, my, 2.2, 0, Math.PI*2); ctx.fill();
  });
  // NPC
  ctx.fillStyle = '#ffd76b';
  Live.npcs.forEach(n => {
    if (n.state==='dead') return;
    const [mx, my] = toMap(n.pos.x, n.pos.z);
    ctx.fillRect(mx-1, my-1, 2, 2);
  });
  // リモートプレイヤー
  ctx.fillStyle = '#aa66ff';
  Live.remotes.forEach(r => {
    const [mx, my] = toMap(r.group.position.x, r.group.position.z);
    ctx.beginPath(); ctx.arc(mx, my, 3, 0, Math.PI*2); ctx.fill();
  });
  // プレイヤー (緑三角)
  const [px2, pz2] = toMap(px, pz);
  ctx.save();
  ctx.translate(px2, pz2);
  ctx.rotate(Live.player.yaw);
  ctx.fillStyle = '#8cffb0';
  ctx.beginPath();
  ctx.moveTo(0, -5);
  ctx.lineTo(-4, 4);
  ctx.lineTo(4, 4);
  ctx.closePath();
  ctx.fill();
  ctx.restore();
}
/* ===== 初期化完了 ===== */
window.addEventListener('load', ()=>{
  showToast('ガリガリ柔道へようこそ!');
});
</script>
<script>
(function(){
  if (window.__liveConnectedRagdollPatchV2) return;
  window.__liveConnectedRagdollPatchV2 = true;

  const CFG = {
    gravity: 22,
    knockdownRecover: 1.15,
    npcRecover: 1.55,
    copRecover: 1.7,
    fatalCarSpeed: 4.9,
    stumbleCarSpeed: 2.6,
    stumbleWallImpact: 4.8,
  };

  function _ensureBodyPart(group) {
    if (!group) return group;
    group._parts = group._parts || {};
    if (group._parts.body) return group;
    let body = null;
    for (const c of (group.children || [])) {
      if (!c || !c.geometry) continue;
      const gt = c.geometry.type || '';
      if (gt === 'BoxGeometry' && c.position && c.position.y > 1.0 && c.position.y < 1.6) {
        body = c;
        break;
      }
    }
    if (!body && group.children && group.children.length) body = group.children[0];
    if (body) group._parts.body = body;
    return group;
  }

  function _safeForwardYawFromQuat(q, fallbackYaw) {
    try {
      const f = new THREE_L.Vector3(0, 0, 1).applyQuaternion(q);
      f.y = 0;
      if (f.lengthSq() > 1e-5) {
        f.normalize();
        return Math.atan2(f.x, f.z);
      }
    } catch (e) {}
    return fallbackYaw || 0;
  }

  function _removeRagdollPartsFromScene(r) {
    if (!r || !r.parts) return;
    r.parts.forEach(part => {
      try {
        if (part.mesh && part.mesh.parent) part.mesh.parent.remove(part.mesh);
      } catch (e) {}
    });
  }

  function _restoreRagdoll(r) {
    if (!r || !r.sourceGroup) return;
    const group = r.sourceGroup;
    const root = r.root || r.parts[0];
    const rootPos = root && root.mesh ? root.mesh.position.clone() : new THREE_L.Vector3();
    const yawBase = (r.entity && typeof r.entity.yaw === 'number') ? r.entity.yaw : (group.rotation ? group.rotation.y : 0);
    const yaw = root && root.mesh ? _safeForwardYawFromQuat(root.mesh.quaternion, yawBase) : yawBase;

    group.position.set(rootPos.x, 0, rootPos.z);
    group.rotation.y = yaw;

    r.parts.forEach(part => {
      try { group.add(part.mesh); } catch (e) {}
      part.mesh.position.copy(part.localPos);
      part.mesh.quaternion.copy(part.localQuat);
      part.mesh.scale.copy(part.localScale);
      part.mesh.rotation.x = part.localEuler.x;
      part.mesh.rotation.y = part.localEuler.y;
      part.mesh.rotation.z = part.localEuler.z;
    });

    group.visible = true;
    group._ragdolled = false;
    group._activeRagdoll = null;

    if (r.entityType === 'player' && Live.player) {
      Live.player.pos.set(group.position.x, 0, group.position.z);
      Live.player.vel.set(0, 0, 0);
      Live.player.yaw = yaw;
      Live.player.group = group;
      Live.playerRagdoll = null;
    } else if (r.entity) {
      r.entity.pos.set(group.position.x, 0, group.position.z);
      r.entity.yaw = yaw;
      r.entity.knockedDown = false;
      r.entity.ragdoll = null;
      r.entity.t = 0;
      if (typeof r.recoverState === 'function') r.entity.state = r.recoverState(r.entity);
      else if (r.recoverState) r.entity.state = r.recoverState;
      else if (r.entityType === 'cop') r.entity.state = Live.wanted >= 1 ? 'chase' : 'patrol';
      else r.entity.state = 'flee';
    }

    _removeRagdollPartsFromScene({ parts: [] });
  }

  function _cleanupExpiredRagdoll(r) {
    if (!r) return;
    if (r.sourceGroup) {
      r.sourceGroup._activeRagdoll = null;
      if (r.mode !== 'knockdown') r.sourceGroup._ragdolled = true;
    }
    if (r.entity) {
      r.entity.knockedDown = false;
      r.entity.ragdoll = null;
    }
    _removeRagdollPartsFromScene(r);
  }

  function _applyRagdollWorldCollision(part) {
    if (part.mesh.position.y < part.restY) {
      part.mesh.position.y = part.restY;
      if (part.vel.y < 0) part.vel.y = -part.vel.y * 0.22;
      part.vel.x *= 0.72;
      part.vel.z *= 0.72;
      part.angVel.multiplyScalar(0.68);
    }
    for (const b of Live.buildings) {
      const dx = part.mesh.position.x - b.x;
      const dz = part.mesh.position.z - b.z;
      const hx = b.hx + 0.15;
      const hz = b.hz + 0.15;
      if (Math.abs(dx) < hx && Math.abs(dz) < hz) {
        const ox = hx - Math.abs(dx);
        const oz = hz - Math.abs(dz);
        if (ox < oz) {
          part.mesh.position.x = b.x + (dx >= 0 ? 1 : -1) * hx;
          part.vel.x = -part.vel.x * 0.24;
        } else {
          part.mesh.position.z = b.z + (dz >= 0 ? 1 : -1) * hz;
          part.vel.z = -part.vel.z * 0.24;
        }
      }
    }
  }

  const __origMakeStickman = window._makeStickman;
  window._makeStickman = function(skin, cloth, isCop) {
    const g = __origMakeStickman.call(this, skin, cloth, isCop);
    _ensureBodyPart(g);
    return g;
  };

  window._makeRagdoll = function(group, impulse, opts) {
    opts = opts || {};
    if (!group || !group._parts || group._ragdolled) return group ? group._activeRagdoll || null : null;
    _ensureBodyPart(group);
    group._ragdolled = true;

    const parts = group._parts;
    const ragdoll = {
      parts: [],
      constraints: [],
      life: 0,
      mode: opts.mode || 'dead',
      recoverAt: opts.recoverAt || 0,
      sourceGroup: group,
      entity: opts.entity || null,
      entityType: opts.entityType || null,
      recoverState: opts.recoverState || null,
      root: null,
    };

    const ix = impulse ? impulse.x : (Math.random() - 0.5) * 1.8;
    const iy = impulse ? impulse.y : 2.4 + Math.random() * 1.2;
    const iz = impulse ? impulse.z : (Math.random() - 0.5) * 1.8;

    const order = ['body', 'head', 'armL', 'armR', 'legL', 'legR'];
    group.updateMatrixWorld(true);

    order.forEach((name) => {
      const mesh = parts[name];
      if (!mesh) return;
      const wp = new THREE_L.Vector3();
      const wq = new THREE_L.Quaternion();
      mesh.getWorldPosition(wp);
      mesh.getWorldQuaternion(wq);
      const localPos = mesh.position.clone();
      const localQuat = mesh.quaternion.clone();
      const localScale = mesh.scale.clone();
      const localEuler = mesh.rotation.clone();
      Live.scene.attach(mesh);
      mesh.position.copy(wp);
      mesh.quaternion.copy(wq);
      const kick = name === 'body' ? 0.6 : (name === 'head' ? 0.85 : 1.0);
      ragdoll.parts.push({
        name,
        mesh,
        vel: new THREE_L.Vector3(
          ix * kick + (Math.random() - 0.5) * (name === 'body' ? 0.8 : 1.5),
          iy * (name === 'body' ? 0.85 : 1.0) + Math.random() * (name === 'body' ? 0.4 : 0.8),
          iz * kick + (Math.random() - 0.5) * (name === 'body' ? 0.8 : 1.5)
        ),
        angVel: new THREE_L.Vector3(
          (Math.random() - 0.5) * (name === 'body' ? 3.8 : 7.2),
          (Math.random() - 0.5) * (name === 'body' ? 3.8 : 7.2),
          (Math.random() - 0.5) * (name === 'body' ? 3.8 : 7.2)
        ),
        restY: name === 'head' ? 0.34 : (name === 'body' ? 0.54 : 0.16),
        localPos,
        localQuat,
        localScale,
        localEuler,
      });
    });

    ragdoll.root = ragdoll.parts.find(p => p.name === 'body') || ragdoll.parts[0] || null;
    const root = ragdoll.root;
    if (root) {
      const rootQuatInv = root.localQuat.clone().invert();
      ragdoll.parts.forEach(part => {
        if (part === root) return;
        ragdoll.constraints.push({
          part,
          anchor: part.localPos.clone().sub(root.localPos),
          relQuat: rootQuatInv.clone().multiply(part.localQuat.clone()),
          // 遅延 0 設定: 高い stiffness/rotFollow + 低 maxStretch でトルソに即追従させる
          stiffness: 600,
          damping: 28,
          rotFollow: 60,
          maxStretch: 0.04,
        });
      });
    }

    group.visible = false;
    group._activeRagdoll = ragdoll;
    Live.ragdolls.push(ragdoll);
    return ragdoll;
  };

  function _knockdownEntity(entity, entityType, impulse, duration, recoverState) {
    if (!entity || !entity.group || entity.group._ragdolled) return null;
    const rd = window._makeRagdoll(entity.group, impulse, {
      mode: 'knockdown',
      recoverAt: duration,
      entity,
      entityType,
      recoverState,
    });
    entity.knockedDown = true;
    entity.ragdoll = rd;
    entity.state = 'ragdoll';
    entity.t = 0;
    return rd;
  }

  window._updateRagdolls = function(dt) {
    const substeps = Math.max(1, Math.ceil(dt / 0.018));
    const stepDt = dt / substeps;

    for (let i = Live.ragdolls.length - 1; i >= 0; i--) {
      const r = Live.ragdolls[i];
      r.life += dt;

      for (let s = 0; s < substeps; s++) {
        r.parts.forEach(part => {
          part.vel.y -= CFG.gravity * stepDt;
          part.mesh.position.x += part.vel.x * stepDt;
          part.mesh.position.y += part.vel.y * stepDt;
          part.mesh.position.z += part.vel.z * stepDt;
          part.mesh.rotation.x += part.angVel.x * stepDt;
          part.mesh.rotation.y += part.angVel.y * stepDt;
          part.mesh.rotation.z += part.angVel.z * stepDt;
        });

        for (let iter = 0; iter < 2; iter++) {
          const root = r.root;
          if (root) _applyRagdollWorldCollision(root);
          r.constraints.forEach(link => {
            const target = link.anchor.clone().applyQuaternion(root.mesh.quaternion).add(root.mesh.position);
            const delta = target.sub(link.part.mesh.position);
            link.part.vel.addScaledVector(delta, link.stiffness * stepDt);
            link.part.vel.multiplyScalar(Math.max(0.2, 1 - link.damping * stepDt));
            const dist = delta.length();
            if (dist > link.maxStretch) {
              link.part.mesh.position.add(delta.normalize().multiplyScalar((dist - link.maxStretch) * 0.72));
            }
            const targetQuat = root.mesh.quaternion.clone().multiply(link.relQuat);
            link.part.mesh.quaternion.slerp(targetQuat, Math.min(1, link.rotFollow * stepDt));
          });
        }

        r.parts.forEach(part => {
          _applyRagdollWorldCollision(part);
          part.vel.x *= Math.max(0, 1 - stepDt * 0.55);
          part.vel.z *= Math.max(0, 1 - stepDt * 0.55);
          part.angVel.multiplyScalar(Math.max(0.15, 1 - stepDt * 1.3));
        });
      }

      if (r.mode === 'knockdown' && r.life >= r.recoverAt) {
        _restoreRagdoll(r);
        Live.ragdolls.splice(i, 1);
        continue;
      }

      if (r.mode !== 'knockdown' && r.life > 30) {
        _cleanupExpiredRagdoll(r);
        Live.ragdolls.splice(i, 1);
      }
    }
  };

  window._liveUpdatePlayer = function(dt) {
    if (!Live.player) return;
    Live.player.attackCD = Math.max(0, Live.player.attackCD - dt);
    Live.dashCD = Math.max(0, Live.dashCD - dt);

    const dx = Live._inDx || 0;
    const dy = Live._inDy || 0;
    const mag = Math.hypot(dx, dy);

    if (Live.player.inCar) {
      const car = Live.player.inCar;
      const steer = dx * 1.8;
      car.yaw -= steer * dt * (Math.abs(car.speed) / 4 + 0.4);
      let accel = 0;
      if (mag > 0.1) {
        accel = -dy * car.accel * 2.5;
      } else {
        car.speed *= 0.96;
      }
      car.speed += accel * dt;
      car.speed = Math.max(-car.maxSpeed * 0.6, Math.min(car.maxSpeed * 1.4, car.speed));
      const fx = Math.sin(car.yaw), fz = Math.cos(car.yaw);
      car.pos.x += fx * car.speed * dt;
      car.pos.z += fz * car.speed * dt;
      _clampCity(car.pos);
      car.group.position.copy(car.pos);
      car.group.rotation.y = car.yaw;
      Live.player.pos.copy(car.pos);
      Live.player.yaw = car.yaw;

      if (Math.abs(car.speed) > 4.2) {
        Live.npcs.forEach(n => {
          if (n.state === 'dead' || n.state === 'ragdoll') return;
          const d = Math.hypot(n.pos.x - car.pos.x, n.pos.z - car.pos.z);
          if (d < 1.6) {
            n.hp -= 80;
            const cfx = Math.sin(car.yaw), cfz = Math.cos(car.yaw);
            const sp = Math.abs(car.speed);
            const impulse = { x: cfx * (2.2 + sp * 0.4), y: 3.0 + sp * 0.18, z: cfz * (2.2 + sp * 0.4) };
            if (n.hp <= 0) {
              _killNPC(n, { x: cfx * (3 + sp * 0.5), y: 4 + sp * 0.2, z: cfz * (3 + sp * 0.5) });
            } else {
              _knockdownEntity(n, 'npc', impulse, CFG.npcRecover, 'flee');
            }
          }
        });
        Live.police.forEach(p => {
          if (p.state === 'dead' || p.state === 'ragdoll') return;
          const d = Math.hypot(p.pos.x - car.pos.x, p.pos.z - car.pos.z);
          if (d < 1.6) {
            p.hp -= 60;
            const cfx = Math.sin(car.yaw), cfz = Math.cos(car.yaw);
            const sp = Math.abs(car.speed);
            const impulse = { x: cfx * (2.4 + sp * 0.42), y: 3.2 + sp * 0.18, z: cfz * (2.4 + sp * 0.42) };
            if (p.hp <= 0) {
              _killCop(p, { x: cfx * (3 + sp * 0.5), y: 4 + sp * 0.2, z: cfz * (3 + sp * 0.5) });
            } else {
              _knockdownEntity(p, 'cop', impulse, CFG.copRecover, function(){ return Live.wanted >= 1 ? 'chase' : 'patrol'; });
            }
          }
        });
      }

      const carHit = _resolveCollision(car.pos, 1.4, { ignoreCar: car });
      if (carHit && carHit.type === 'building') {
        if (Math.abs(car.speed) > 6) _liveLog('💥 車が建物に激突');
        car.speed *= -0.25;
        car.group.position.copy(car.pos);
      }
    } else if (Live.playerRagdoll) {
      Live.playerRagdoll.t = (Live.playerRagdoll.t || 0) + dt;
      if (Live.playerRagdoll.fatal) {
        if (Live.playerRagdoll.t > (Live.playerRagdoll.deathAfter || 2.5)) _liveDeath();
      } else if (Live.playerRagdoll.t > (Live.playerRagdoll.recoverAfter || CFG.knockdownRecover)) {
        Live.playerRagdoll = null;
      }
    } else {
      const maxSpeed = 5.0;
      if (mag > 0.12) {
        const steer = dx;
        const turnRate = 2.8;
        Live.player.yaw -= steer * turnRate * dt * (Math.abs(dy) * 0.6 + 0.6);
        const targetSpd = -dy * maxSpeed;
        const fx = Math.sin(Live.player.yaw), fz = Math.cos(Live.player.yaw);
        const tx = fx * targetSpd;
        const tz = fz * targetSpd;
        Live.player.vel.x += (tx - Live.player.vel.x) * Math.min(1, dt * 9);
        Live.player.vel.z += (tz - Live.player.vel.z) * Math.min(1, dt * 9);
      } else {
        Live.player.vel.x *= 0.80;
        Live.player.vel.z *= 0.80;
      }
      Live.player.pos.x += Live.player.vel.x * dt;
      Live.player.pos.z += Live.player.vel.z * dt;
      _clampCity(Live.player.pos);
      const hit = _resolveCollision(Live.player.pos, 0.45, {});
      if (hit) {
        const planarSpeed = Math.hypot(Live.player.vel.x, Live.player.vel.z);
        const impact = Math.max(planarSpeed, (hit.speed || 0));
        if (hit.type === 'car' && hit.speed > CFG.fatalCarSpeed && !Live.playerRagdoll) {
          const impulse = {
            x: -hit.nx * (3 + hit.speed * 0.5),
            y: 4 + hit.speed * 0.25,
            z: -hit.nz * (3 + hit.speed * 0.5),
          };
          const rd = window._makeRagdoll(Live.player.group, impulse, { mode: 'dead' });
          Live.playerRagdoll = { t: 0, fatal: true, deathAfter: 2.5, ragdoll: rd };
          Live.hp = 0;
          _liveLog('💥 車に轢かれた！');
        } else if (!Live.playerRagdoll && ((hit.type === 'car' && hit.speed > CFG.stumbleCarSpeed) || (hit.type === 'building' && impact > CFG.stumbleWallImpact))) {
          const impulse = {
            x: -hit.nx * (1.9 + impact * 0.42),
            y: 2.6 + impact * 0.12,
            z: -hit.nz * (1.9 + impact * 0.42),
          };
          const rd = _knockdownEntity(Live.player, 'player', impulse, CFG.knockdownRecover, null);
          Live.player.vel.set(0, 0, 0);
          Live.playerRagdoll = { t: 0, fatal: false, recoverAfter: CFG.knockdownRecover, ragdoll: rd };
          _liveLog(hit.type === 'building' ? '🌀 壁にぶつかって転倒！' : '🌀 吹っ飛んで転倒！');
        } else {
          const dot = Live.player.vel.x * hit.nx + Live.player.vel.z * hit.nz;
          if (dot < 0) {
            Live.player.vel.x -= dot * hit.nx;
            Live.player.vel.z -= dot * hit.nz;
          }
        }
      }
      if (!Live.player.group._ragdolled) {
        Live.player.group.position.copy(Live.player.pos);
        Live.player.group.rotation.y = Live.player.yaw;
        const moving = (Math.abs(Live.player.vel.x) + Math.abs(Live.player.vel.z)) > 0.5;
        if (moving) {
          const t = performance.now() / 180;
          const pp = Live.player.group._parts;
          pp.legL.rotation.x = Math.sin(t) * 0.6;
          pp.legR.rotation.x = -Math.sin(t) * 0.6;
          pp.armL.rotation.x = -Math.sin(t) * 0.4;
          pp.armR.rotation.x = Math.sin(t) * 0.4;
        } else {
          const pp = Live.player.group._parts;
          pp.legL.rotation.x *= 0.7;
          pp.legR.rotation.x *= 0.7;
          pp.armL.rotation.x *= 0.7;
          pp.armR.rotation.x *= 0.7;
        }
      }
    }
    _updateLiveHUD();
  };

  window._liveUpdateNPCs = function(dt) {
    const pl = Live.player;
    Live.npcs.forEach(n => {
      if (n.state === 'dead' || n.state === 'ragdoll') return;
      n.t += dt;
      n.stepT += dt * 5;
      const p = n.group._parts;

      if (n.state === 'wander') {
        const pd = Math.hypot(pl.pos.x - n.pos.x, pl.pos.z - n.pos.z);
        if (n.pers === 'aggressive' && pd < 8 && Math.random() < 0.02) {
          n.state = 'attack'; n.target = pl; n.t = 0;
        } else if (n.pers === 'timid' && pd < 5) {
          n.state = 'flee'; n.target = pl; n.t = 0;
        }
        if (n.t > 3 + Math.random() * 2) {
          n.yaw = Math.random() * Math.PI * 2;
          n.t = 0;
        }
        const speed = n.speed;
        n.pos.x += Math.sin(n.yaw) * speed * dt;
        n.pos.z += Math.cos(n.yaw) * speed * dt;
        _clampCity(n.pos);
        const nh = _resolveCollision(n.pos, 0.4, {});
        if (nh) n.yaw = Math.random() * Math.PI * 2;
      } else if (n.state === 'flee') {
        const dx = n.pos.x - pl.pos.x, dz = n.pos.z - pl.pos.z;
        const d = Math.hypot(dx, dz) || 1;
        n.yaw = Math.atan2(dx / d, dz / d);
        n.pos.x += dx / d * (n.speed * 1.6) * dt;
        n.pos.z += dz / d * (n.speed * 1.6) * dt;
        if (n.t > 4 || d > 22) { n.state = 'wander'; n.t = 0; }
        _clampCity(n.pos);
        _resolveCollision(n.pos, 0.4, {});
      } else if (n.state === 'attack') {
        const dx = pl.pos.x - n.pos.x, dz = pl.pos.z - n.pos.z;
        const d = Math.hypot(dx, dz);
        n.yaw = Math.atan2(dx, dz);
        if (d > 1.4) {
          n.pos.x += dx / d * n.speed * 1.2 * dt;
          n.pos.z += dz / d * n.speed * 1.2 * dt;
        } else if (n.t > 0.8) {
          n.t = 0;
          Live.hp -= 6;
          _liveLog('🥊 ' + (n.pers === 'aggressive' ? '攻撃的市民' : '市民') + 'に殴られた');
          if (Live.hp <= 0) _liveDeath();
        }
        _clampCity(n.pos);
      }

      if (!n.group._ragdolled) {
        n.group.position.copy(n.pos);
        n.group.rotation.y = n.yaw;
        p.legL.rotation.x = Math.sin(n.stepT) * 0.5;
        p.legR.rotation.x = -Math.sin(n.stepT) * 0.5;
      }
    });
  };

  window._liveUpdatePolice = function(dt) {
    const pl = Live.player;
    Live.police.forEach(p => {
      if (p.state === 'dead' || p.state === 'ragdoll') return;
      p.t += dt;
      p.stepT += dt * 5;
      p.attackCD = Math.max(0, p.attackCD - dt);
      const parts = p.group._parts;
      const pd = Math.hypot(pl.pos.x - p.pos.x, pl.pos.z - p.pos.z);

      if (Live.wanted >= 1 && pd < 50) p.state = 'chase';

      if (p.state === 'patrol') {
        if (p.t > 3) {
          p.yaw = Math.random() * Math.PI * 2;
          p.t = 0;
        }
        p.pos.x += Math.sin(p.yaw) * p.speed * 0.6 * dt;
        p.pos.z += Math.cos(p.yaw) * p.speed * 0.6 * dt;
        _resolveCollision(p.pos, 0.4, {});
      } else if (p.state === 'chase') {
        if (Live.wanted < 1) {
          p.state = 'patrol'; p.t = 0;
        } else {
          const dx = pl.pos.x - p.pos.x, dz = pl.pos.z - p.pos.z;
          const d = Math.hypot(dx, dz) || 1;
          p.yaw = Math.atan2(dx / d, dz / d);
          if (d > 1.5) {
            p.pos.x += dx / d * p.speed * dt;
            p.pos.z += dz / d * p.speed * dt;
          } else if (p.attackCD <= 0) {
            p.attackCD = 0.8;
            Live.hp -= 10;
            _liveLog('🚓 警官に殴られた');
            parts.armR.rotation.x = -1.4;
            setTimeout(() => { if (parts.armR) parts.armR.rotation.x = 0; }, 220);
            if (Live.hp <= 0) _liveDeath();
          }
        }
      }
      _clampCity(p.pos);
      _resolveCollision(p.pos, 0.4, {});
      if (!p.group._ragdolled) {
        p.group.position.copy(p.pos);
        p.group.rotation.y = p.yaw;
        parts.legL.rotation.x = Math.sin(p.stepT) * 0.6;
        parts.legR.rotation.x = -Math.sin(p.stepT) * 0.6;
      }
    });

    if (Live.wanted > 0) Live.wanted = Math.max(0, Live.wanted - dt * 0.02);
  };

  const __origLiveDeath = window._liveDeath;
  window._liveDeath = function() {
    if (Live.playerRagdoll && Live.playerRagdoll.ragdoll && Live.playerRagdoll.ragdoll.mode === 'knockdown') {
      try { _cleanupExpiredRagdoll(Live.playerRagdoll.ragdoll); } catch (e) {}
    }
    return __origLiveDeath.apply(this, arguments);
  };
})();
</script>

<script defer src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447" integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==" data-cf-beacon='{"version":"2024.11.0","token":"4edd5f8ec12a48cfa682ab8261b80a79","server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>
<script defer src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447" integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==" data-cf-beacon='{"version":"2024.11.0","token":"4edd5f8ec12a48cfa682ab8261b80a79","server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>

<!-- ====== ボクシング→柔道統合 + ラグドール物理 拡張パッチ ====== -->
<script>
/* ============================================================
   柔道本編 拡張パッチ:
   ・ボクシングモードの機能 (パンチ / キック / 回避 / シールド耐久 / 残像) を本編へ移植
   ・タックルで転倒した時、物理演算ラグドール (四肢コリジョン + 部位同士の貫通防止) を発動
   ============================================================ */
(function(){
  if (window.__judoBoxingRagdollPatch) return;
  window.__judoBoxingRagdollPatch = true;

  function $$(id) { return document.getElementById(id); }
  function clamp(v, a, b) { return v < a ? a : (v > b ? b : v); }
  function rnd(a, b) { return a + Math.random() * (b - a); }

  // ---------- 1. JUDO_ATTACKS: パンチ/キックは柔道本編からは削除 (殴り合いモード専用) ----------
  function _extendAttacks() {
    if (typeof JUDO_ATTACKS === 'undefined') return;
    // パンチ/キックは柔道本編では使用しないため追加しない。
    // もし以前のバージョンで追加済みだった場合は念のため削除しておく。
    if (JUDO_ATTACKS.punch) delete JUDO_ATTACKS.punch;
    if (JUDO_ATTACKS.kick)  delete JUDO_ATTACKS.kick;
    // 既存タックルに shieldDmg, knockback フラグを追加 (シールド連携用)
    if (JUDO_ATTACKS.tackle && JUDO_ATTACKS.tackle.shieldDmg === undefined) {
      JUDO_ATTACKS.tackle.shieldDmg = 14;
      JUDO_ATTACKS.tackle.knockback = true;
    }
  }

  // ---------- 2. Judo に シールド/残像/回避状態を追加 ----------
  function _extendJudoState() {
    if (typeof Judo === 'undefined') return;
    if (Judo._extendedState) return;
    Judo._extendedState = true;
    Judo.shieldMax       = 30;
    Judo.shield          = 30;
    Judo.shieldRegen     = 4.5;
    Judo.shieldRegenDelay= 0.9;
    Judo.shieldRegenT    = 0;
    Judo.shieldBroken    = false;
    Judo.enemyAfterimages = [];
    Judo.nextAfterimageT = 0;
    Judo.enemyDodgeT     = 0;
    Judo.enemyDodgeDir   = { x:0, z:0 };
  }

  // ---------- 3. UI: アクションパッドに パンチ/キック/回避 ボタンを注入 ----------
  function _injectJudoUI() {
    const pad = $$('actionPad');
    if (!pad || pad.dataset.boxingMerged === '1') return;

    // 既存のグリッドを置き換え (4技 + ガード = 計5ボタン)。柔道本編ではパンチ/キックは使わない。
    pad.innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
        <div class="judoBtn" id="btnTackle" style="display:flex;align-items:center;justify-content:center;background:rgba(120,190,255,0.22);border:2px solid rgba(120,190,255,0.45);min-height:54px;border-radius:14px;font-weight:bold;color:#d9eeff;font-size:16px;">タックル</div>
        <div class="judoBtn" id="btnGuard"  style="display:flex;align-items:center;justify-content:center;background:rgba(72,175,120,0.22);border:2px solid rgba(72,175,120,0.45);min-height:54px;border-radius:14px;font-weight:bold;color:#d8ffe8;font-size:16px;">ガード</div>
        <div class="judoBtn" id="btnRoll"   style="display:flex;align-items:center;justify-content:center;background:rgba(200,120,255,0.22);border:2px solid rgba(200,120,255,0.45);min-height:54px;border-radius:14px;font-weight:bold;color:#f2dbff;font-size:16px;">回避</div>
        <div class="judoBtn" id="btnThrow"  style="display:flex;align-items:center;justify-content:center;background:rgba(255,140,120,0.22);border:2px solid rgba(255,140,120,0.45);min-height:54px;border-radius:14px;font-weight:bold;color:#ffe0d8;font-size:16px;">投げ → 固め技</div>
        <div class="judoBtn" id="btnPunch" style="display:none;"></div>
        <div class="judoBtn" id="btnKick"  style="display:none;"></div>
        <div class="judoBtn" id="btnPin" style="display:none;"></div>
      </div>
    `;
    pad.dataset.boxingMerged = '1';

    // ガード耐久リング (ボクシングと同じ)
    const overlay = $$('judoOverlay');
    if (overlay && !$$('judoShieldRing')) {
      const ring = document.createElement('div');
      ring.id = 'judoShieldRing';
      ring.style.cssText = 'position:absolute;display:none;width:54px;height:54px;pointer-events:none;z-index:5;';
      ring.innerHTML = `
        <svg viewBox="0 0 54 54" width="54" height="54" style="position:absolute;left:0;top:0;">
          <circle cx="27" cy="27" r="22" fill="rgba(0,0,0,0.4)" stroke="rgba(255,255,255,0.25)" stroke-width="2"></circle>
          <circle id="judoShieldArc" cx="27" cy="27" r="22" fill="none" stroke="#6fe39a" stroke-width="4" stroke-linecap="round" stroke-dasharray="138.23 138.23" stroke-dashoffset="0" transform="rotate(-90 27 27)"></circle>
          <text id="judoShieldTxt" x="27" y="31" text-anchor="middle" fill="#d8ffe8" font-size="14" font-weight="bold" font-family="Hiragino Sans, sans-serif">30</text>
        </svg>`;
      overlay.appendChild(ring);
    }

    // HUDノートを更新
    const note = $$('judoHudNote');
    if (note) note.textContent = '左:移動 / 右:タックル・投げ・ガード・回避';
  }

  // ---------- 4. _bindJudoControls をラップ (追加ボタンを束ねる) ----------
  function _wrapBindControls() {
    if (typeof _bindJudoControls === 'undefined' || _bindJudoControls.__wrapped) return;
    const orig = window._bindJudoControls;
    window._bindJudoControls = function() {
      _injectJudoUI();  // 念のため UI を毎回確実に注入
      orig.apply(this, arguments);

      // 新規ボタン (柔道本編ではパンチ/キックは使わないのでバインドしない)
      const br = $$('btnRoll');  if (br) br.onclick = () => _judoStartRoll();
    };
    window._bindJudoControls.__wrapped = true;
  }

  // ---------- 5. プレイヤーの新規アクション ----------
  window._judoPlayerActionExt = function(kind) {
    if (!Judo.running || Judo.mode !== 'fight') return;
    if (Judo.attackCD > 0 || Judo.meRollT > 0 || Judo.meAction) return;
    if (Judo.meStunT > 0) return;
    const spec = JUDO_ATTACKS[kind];
    if (!spec) return;
    Judo.meGuard = false;
    Judo.mePose = kind;
    Judo.meAnim = 0;
    Judo.attackCD = spec.cooldown;
    Judo.meAction = { side:'me', kind, t:0, hitDone:false, ...spec };
  };

  // ---------- 6. 回避 (ロール) ----------
  window._judoStartRoll = function() {
    if (!Judo.running || Judo.mode !== 'fight') return;
    if (Judo.attackCD > 0 || Judo.meAction || Judo.meRollT > 0) return;
    if (Judo.meStunT > 0) return;
    // ボクシングと同じ計算
    const ix = Math.abs(Judo.input.x) > 0.08 ? Judo.input.x : Judo.input.lastX;
    const iy = Math.abs(Judo.input.y) > 0.08 ? Judo.input.y : Judo.input.lastY;
    const v = (typeof _getMoveVector === 'function')
      ? _getMoveVector(ix, iy)
      : { x: ix, z: -iy, mag: Math.hypot(ix, iy) };
    let x = v.x, z = v.z;
    if (Math.hypot(x, z) < 0.01) {
      const ang = Judo.me ? Judo.me.rotation.y : 0;
      x = Math.sin(ang); z = Math.cos(ang);
    }
    const len = Math.hypot(x, z) || 1;
    Judo.meRollDir = { x:x/len, z:z/len };
    Judo.meRollT = 0.42;
    Judo.meInvuln = 0.34;
    Judo.meGuard = false;
    Judo.mePose = 'roll';
    Judo.meAnim = 0;
    Judo.attackCD = 22;
    Judo.meAction = null;
  };

  // ---------- 7. _playerAction をラップ (punch/kick もスペックを許可) ----------
  // 既存実装は JUDO_ATTACKS の項を spread するため、punch/kick も既に通る。
  // ただ、tackle の strong 確率が punch/kick にも誤って付かないように特殊処理ガード。
  function _wrapPlayerAction() {
    if (typeof _playerAction === 'undefined' || _playerAction.__wrapped) return;
    const orig = window._playerAction;
    window._playerAction = function(kind) {
      // tackle/throw 以外はラップ後の Ext 実装へ委譲
      if (kind === 'punch' || kind === 'kick') return _judoPlayerActionExt(kind);
      return orig.apply(this, arguments);
    };
    window._playerAction.__wrapped = true;
  }

  // ---------- 8. ガード ON/OFF をラップ: シールド破損中は不可 ----------
  function _wrapSetGuard() {
    if (typeof _setGuard === 'undefined' || _setGuard.__wrapped) return;
    const orig = window._setGuard;
    window._setGuard = function(on) {
      if (on && Judo.shieldBroken) on = false;
      orig.call(this, on);
      // ガードを離した時、回復遅延をかける
      if (!Judo.meGuard) Judo.shieldRegenT = Math.max(Judo.shieldRegenT, Judo.shieldRegenDelay);
    };
    window._setGuard.__wrapped = true;
  }

  // ---------- 9. _applyHit をラップ ----------
  // 敵から punch/kick を受けた場合のシールド処理 / 回避不可判定を追加
  function _wrapApplyHit() {
    if (typeof _applyHit === 'undefined' || _applyHit.__wrapped) return;
    const orig = window._applyHit;
    window._applyHit = function(action) {
      // 投げ/掴み/その他既存処理は元実装に任せる
      if (action.kind === 'throw' || action.kind === 'grapple') {
        return orig.apply(this, arguments);
      }

      // me 側（プレイヤーが当てる）: punch/kick を独自処理、tackle は元実装(強タックル含む)
      if (action.side === 'me' && action.kind === 'tackle') {
        const result = orig.apply(this, arguments);
        // 通常タックルヒット時、相手にも軽い「転倒」を付与しラグドールが発動するよう
        // 既存コードでは Strong タックル時のみ enStunT が 3.0 になる。
        // 通常タックルの場合: 必中ヒット時に短い転倒 (0.9s) を付与
        if (action.hitDone) {
          // 既存の applyHit は dist が範囲外だと早期 return しているので、ここに来た時点で当たっている保証はないが
          // strong フラグが付いていない通常タックル & 敵にダメージが入った印 (enHP が下がる) で判断
          // 簡易判定: strong でなく & まだスタンしていなければ短時間転倒
          if (!action.strong && Judo.enStunT <= 0 && Judo.en && Judo.enHP < (Judo.en._lastHP ?? Judo.enHP)) {
            // 何もしない (既存ノックバックのみで OK)
          }
        }
        return result;
      }
      if (action.side === 'me') {
        // パンチ・キック: 自前で処理
        _judoApplyMeHit(action);
        return;
      }

      // 敵が攻撃: punch/kick は自前処理、tackle/その他は元実装に委譲
      if (action.kind === 'punch' || action.kind === 'kick') {
        _judoApplyEnemyStrike(action);
        return;
      }

      // 敵のタックル: 元実装に任せた後、通常タックル命中時もラグドール発動のため短時間転倒付与
      const prevMeHP = Judo.meHP;
      const r = orig.apply(this, arguments);
      // 通常タックル命中 (strong ではない) で HP が減った場合、短い転倒を付与
      if (action.kind === 'tackle' && !action.strong && prevMeHP > Judo.meHP && Judo.meStunT <= 0 && !Judo.meGuard) {
        Judo.meStunT = 1.0;
        Judo.mePose = 'down';
        Judo.meAction = null;
        Judo.meAnim = 0;
        Judo.meRollT = 0;
        Judo.meGuard = false;
      }
      return r;
    };
    window._applyHit.__wrapped = true;
  }

  // パンチ/キック: プレイヤーが敵に与える
  function _judoApplyMeHit(action) {
    if (!Judo.me || !Judo.en) return;
    const dist = Math.hypot(Judo.me.position.x - Judo.en.position.x, Judo.me.position.z - Judo.en.position.z);
    if (dist > action.range) {
      _flashMsg(action.label + ' 空振り', '#cfd8dc', 320);
      return;
    }
    let dmg = rnd(action.damage[0], action.damage[1]);
    const dx = Judo.en.position.x - Judo.me.position.x;
    const dz = Judo.en.position.z - Judo.me.position.z;
    const dl = Math.hypot(dx, dz) || 1;
    const push = action.kind === 'kick' ? 0.28 : 0.18;
    // 敵ガード適用
    if (Judo.enGuard) dmg *= 0.30;
    Judo.enHP = Math.max(0, Judo.enHP - dmg);
    Judo.score += Math.round(action.score * (Judo.enGuard ? 0.4 : 1));
    if (!Judo.enGuard) {
      Judo.en.position.x += dx / dl * push;
      Judo.en.position.z += dz / dl * push;
      if (typeof _clampArena === 'function') _clampArena(Judo.en);
      if (typeof _resolveJudoCollision === 'function') _resolveJudoCollision(0.15, 0.6);
      Judo.shakeT = action.kind === 'kick' ? 8 : 5;
      _flashMsg(action.label + ' ヒット!', action.color, 380);
    } else {
      Judo.shakeT = 3;
      _flashMsg('敵にガードされた!', '#ffd76b', 320);
      Judo.enGuardT = Math.max(0.05, Judo.enGuardT - 0.4);
    }
    if (typeof updateJudoHUD === 'function') updateJudoHUD();
  }

  // パンチ/キック: 敵がプレイヤーに与える (シールド処理付き)
  function _judoApplyEnemyStrike(action) {
    if (!Judo.me || !Judo.en) return;
    const dist = Math.hypot(Judo.me.position.x - Judo.en.position.x, Judo.me.position.z - Judo.en.position.z);
    if (dist > action.range) return;
    if (Judo.meInvuln > 0) {
      Judo.score += 2;
      _flashMsg('回避成功!', '#8fd9ff', 320);
      return;
    }
    const dmg = rnd(action.damage[0], action.damage[1]);
    const dx = Judo.me.position.x - Judo.en.position.x;
    const dz = Judo.me.position.z - Judo.en.position.z;
    const dl = Math.hypot(dx, dz) || 1;
    const push = action.kind === 'kick' ? 0.28 : 0.18;

    // ガード処理 (ボクシングと同等のシールド)
    if (Judo.meGuard && !Judo.shieldBroken) {
      const sDmg = action.shieldDmg || 6;
      const absorb = Math.min(Judo.shield, sDmg);
      Judo.shield = Math.max(0, Judo.shield - sDmg);
      const guardEff = absorb / sDmg;
      const blockedRate = 0.18;
      const finalDmg = dmg * (guardEff * blockedRate + (1 - guardEff) * 1.0);
      Judo.meHP = Math.max(0, Judo.meHP - finalDmg);
      Judo.shieldRegenT = Judo.shieldRegenDelay;
      if (Judo.shield <= 0) {
        Judo.shieldBroken = true;
        Judo.meGuard = false;
        _flashMsg('シールドブレイク!', '#ff8c8c', 520);
        Judo.shakeT = 12;
      } else {
        _flashMsg('ガード!', '#8cffb0', 240);
        Judo.shakeT = 4;
      }
    } else {
      Judo.meHP = Math.max(0, Judo.meHP - dmg);
      Judo.me.position.x -= dx / dl * push * 0.9;
      Judo.me.position.z -= dz / dl * push * 0.9;
      if (typeof _clampArena === 'function') _clampArena(Judo.me);
      if (typeof _resolveJudoCollision === 'function') _resolveJudoCollision(0.6, 0.12);
      Judo.shakeT = action.kind === 'kick' ? 9 : 6;
      _flashMsg(action.label + ' 被弾!', '#ff9595', 380);
    }
    if (typeof updateJudoHUD === 'function') updateJudoHUD();
  }

  // ---------- 10. _startEnemyAction をラップ (punch/kick 拡張) ----------
  function _wrapStartEnemyAction() {
    if (typeof _startEnemyAction === 'undefined' || _startEnemyAction.__wrapped) return;
    const orig = window._startEnemyAction;
    window._startEnemyAction = function(kind) {
      if (kind !== 'punch' && kind !== 'kick') return orig.apply(this, arguments);
      const spec = JUDO_ATTACKS[kind];
      if (!spec || Judo.enAction || Judo.mode !== 'fight') return;
      Judo.enGuard = false; Judo.enGuardT = 0;
      Judo.enPose = kind;
      Judo.enAnim = 0;
      Judo.enAction = {
        side:'en', kind,
        label:'敵' + spec.label,
        range: spec.range + 0.04,
        damage: [Math.max(3, spec.damage[0] - 1), Math.max(3, spec.damage[1] - 1)],
        hitAt: spec.hitAt + 0.07,
        total: spec.total + 0.12,
        cooldown: spec.cooldown + 12,
        color: '#ffb08f',
        score: 0,
        shieldDmg: spec.shieldDmg || 6,
        t: 0, hitDone: false,
      };
      Judo.enemyAtkCD = spec.cooldown + 24 + Math.random() * 22;
    };
    window._startEnemyAction.__wrapped = true;
  }

  // ---------- 11. 敵 AI をラップ: 中距離で punch/kick を使う + 先読み回避 ----------
  function _wrapEnemyThink() {
    if (typeof _enemyThink === 'undefined' || _enemyThink.__wrapped) return;
    const orig = window._enemyThink;
    window._enemyThink = function(dt, time) {
      // プレイヤー攻撃中、敵が一定確率で先読み回避 (ボクシングと同様)
      try {
        if (Judo.enAction == null && Judo.enStunT <= 0 && Judo.enemyDodgeT <= 0 && Judo.meAction) {
          const a = Judo.meAction;
          const ttl = a.hitAt - a.t;
          if (ttl <= 0.18 && ttl > -0.04) {
            const dist = Math.hypot(Judo.me.position.x - Judo.en.position.x, Judo.me.position.z - Judo.en.position.z);
            const inRange = dist < (a.range + 0.35);
            const prob = a.kind === 'tackle' ? 0.45 : (a.kind === 'kick' ? 0.32 : 0.28);
            if (inRange && Math.random() < prob) {
              _startEnemyDodge(a.kind);
              return; // 通常思考スキップ
            }
          }
        }
      } catch (e) {}

      // 既存 enemyThink を実行
      orig.apply(this, arguments);

      // 柔道本編では敵ボットもパンチ/キックを使わない (殴り合いモードのみ)
    };
    window._enemyThink.__wrapped = true;
  }

  function _startEnemyDodge(reason) {
    if (!Judo.en || !Judo.me) return;
    const ang = Math.atan2(Judo.me.position.x - Judo.en.position.x, Judo.me.position.z - Judo.en.position.z);
    const side = Math.random() < 0.5 ? -1 : 1;
    const backMul = reason === 'tackle' ? -0.85 : -0.45;
    const sideMul = reason === 'tackle' ? 1.4 : 1.15;
    const dx = Math.cos(ang) * side * sideMul + Math.sin(ang) * backMul;
    const dz = -Math.sin(ang) * side * sideMul + Math.cos(ang) * backMul;
    const len = Math.hypot(dx, dz) || 1;
    Judo.enemyDodgeDir = { x: dx/len, z: dz/len };
    Judo.enemyDodgeT   = reason === 'tackle' ? 0.34 : 0.26;
    Judo.nextAfterimageT = 0;
    Judo.enPose = 'roll';
    Judo.enAnim = 0;
    Judo.enAction = null;
    _spawnEnemyAfterimageJudo();
    _flashMsg('CPUが先読み回避!', '#9fe7ff', 320);
  }

  function _spawnEnemyAfterimageJudo() {
    if (!Judo.en) return;
    Judo.enemyAfterimages.push({
      x: Judo.en.position.x, z: Judo.en.position.z,
      rotY: Judo.en.rotation.y,
      pose: Judo.enPose || 'move',
      anim: Judo.enAnim || 0,
      life: 0.34, maxLife: 0.34,
    });
    if (Judo.enemyAfterimages.length > 6) Judo.enemyAfterimages.shift(); // 8→6に削減
  }

  function _disposeAfterimageEntryJudo(g) {
    if (!g.mesh) return;
    if (g.mesh.parent) g.mesh.parent.remove(g.mesh);
    g.mesh.traverse(obj => {
      if (obj.geometry) try { obj.geometry.dispose(); } catch(e) {}
      if (obj.material) {
        const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
        mats.forEach(m => { try { m.dispose(); } catch(e) {} });
      }
    });
    g.mesh = null;
  }

  function _updateAfterimagesJudo(dt, time) {
    if (!Judo.enemyAfterimages || !Judo.enemyAfterimages.length) return;
    if (!Judo.scene || !Judo.THREE) return;
    const next = [];
    for (let i = 0; i < Judo.enemyAfterimages.length; i++) {
      const g = Judo.enemyAfterimages[i];
      g.life -= dt;
      _disposeAfterimageEntryJudo(g);
      if (g.life <= 0) continue;
      const mesh = _buildJudoka(Judo.THREE, 0xaef6ff, true);
      mesh.position.set(g.x, 0, g.z);
      mesh.rotation.y = g.rotY;
      mesh.scale.setScalar(0.985);
      const alpha = Math.max(0.08, Math.min(0.45, g.life / g.maxLife * 0.42));
      mesh.traverse(obj => {
        if (obj.isMesh && obj.material) {
          const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
          obj.material = mats.map(m => {
            const mm = m.clone();
            mm.transparent = true; mm.opacity = alpha;
            if (mm.color) mm.color.offsetHSL(0.02, -0.08, 0.16);
            return mm;
          });
        }
      });
      _animateJudoka(mesh, g.pose, g.anim, time);
      Judo.scene.add(mesh);
      g.mesh = mesh;
      next.push(g);
    }
    Judo.enemyAfterimages = next;
  }

  function _cleanupAfterimagesJudo() {
    if (!Judo.enemyAfterimages) return;
    Judo.enemyAfterimages.forEach(g => _disposeAfterimageEntryJudo(g));
    Judo.enemyAfterimages = [];
  }

  // ---------- 12. シールドリング UI 更新 (ボクシングと同等) ----------
  function _updateJudoShieldUI() {
    const ring = $$('judoShieldRing');
    const arc = $$('judoShieldArc');
    const txt = $$('judoShieldTxt');
    if (!ring || !arc || !txt) return;
    const shouldShow = Judo.running && Judo.mode === 'fight' &&
      (Judo.meGuard || Judo.shield < Judo.shieldMax - 0.01 || Judo.shieldBroken);
    if (!shouldShow || !Judo.me || !Judo.camera || !Judo.renderer) {
      ring.style.display = 'none'; return;
    }
    if (!Judo._shieldVec) Judo._shieldVec = new Judo.THREE.Vector3();
    const vec = Judo._shieldVec;
    vec.set(Judo.me.position.x, 1.6, Judo.me.position.z);
    vec.project(Judo.camera);
    const rect = Judo.renderer.domElement.getBoundingClientRect();
    const stageRect = $$('judoStage').getBoundingClientRect();
    const sx = rect.left - stageRect.left + (vec.x * 0.5 + 0.5) * rect.width;
    const sy = rect.top  - stageRect.top  + (-vec.y * 0.5 + 0.5) * rect.height;
    ring.style.display = 'block';
    ring.style.left = (sx + 36) + 'px';
    ring.style.top  = (sy - 30) + 'px';
    const ratio = clamp(Judo.shield / Judo.shieldMax, 0, 1);
    const circ = 2 * Math.PI * 22;
    arc.setAttribute('stroke-dasharray', circ.toFixed(2) + ' ' + circ.toFixed(2));
    arc.setAttribute('stroke-dashoffset', (circ * (1 - ratio)).toFixed(2));
    let col = '#6fe39a';
    if (Judo.shieldBroken) col = '#888';
    else if (ratio < 0.33) col = '#ff7a7a';
    else if (ratio < 0.66) col = '#ffd76b';
    arc.setAttribute('stroke', col);
    txt.textContent = Math.max(0, Math.ceil(Judo.shield));
  }

  // ============================================================
  //   ラグドール物理エンジン (柔道専用 / 四肢コリジョン付き)
  // ============================================================
  const RAG = {
    gravity: 22,
    iterations: 16,       // 制約解決の反復回数 (遅延 0 のため増やす)
    damping: 0.985,
    angDamping: 0.94,
    friction: 0.62,
    restitution: 0.18,
  };

  // group から ragdoll を生成
  function _buildRagdoll(group, impulseDir, strength) {
    if (!group || !group.userData) return null;
    if (group._ragdoll) return group._ragdoll;
    const THREE = Judo.THREE;
    const u = group.userData;
    group.updateMatrixWorld(true);

    // ラグドール対象に含めない子 (hair / belt / eyes) は一時的に非表示にする
    const hiddenChildren = [];
    const ragdollMeshSet = new Set([u.torso, u.head, u.armL, u.armR, u.legL, u.legR].filter(Boolean));
    (group.children || []).slice().forEach(c => {
      if (!c || !c.isObject3D) return;
      if (ragdollMeshSet.has(c)) return;
      if (c.visible !== false) {
        hiddenChildren.push({ mesh: c, vis: c.visible !== false });
        c.visible = false;
      }
    });

    // 各部位の半径定義 (おおよそ実形状に合わせる)
    const partDefs = [
      { name:'torso', mesh:u.torso, radius:0.55, mass:2.4 },
      { name:'head',  mesh:u.head,  radius:0.42, mass:0.8 },
      { name:'armL',  mesh:u.armL,  radius:0.30, mass:0.6 },
      { name:'armR',  mesh:u.armR,  radius:0.30, mass:0.6 },
      { name:'legL',  mesh:u.legL,  radius:0.34, mass:1.0 },
      { name:'legR',  mesh:u.legR,  radius:0.34, mass:1.0 },
    ];
    const parts = [];
    const partsByName = {};
    for (const d of partDefs) {
      if (!d.mesh) continue;
      // 保存: 元の親 / ローカル変換
      const origParent = d.mesh.parent;
      const origPos = d.mesh.position.clone();
      const origQuat = d.mesh.quaternion.clone();
      const origScale = d.mesh.scale.clone();
      // ワールドへ
      const wp = new THREE.Vector3();
      const wq = new THREE.Quaternion();
      d.mesh.getWorldPosition(wp);
      d.mesh.getWorldQuaternion(wq);
      Judo.scene.attach(d.mesh);
      d.mesh.position.copy(wp);
      d.mesh.quaternion.copy(wq);
      const part = {
        name: d.name,
        mesh: d.mesh,
        radius: d.radius,
        mass: d.mass,
        invMass: 1 / d.mass,
        pos: wp.clone(),
        prevPos: wp.clone(),
        vel: new THREE.Vector3(),
        angVel: new THREE.Vector3(
          (Math.random()-0.5) * 8,
          (Math.random()-0.5) * 4,
          (Math.random()-0.5) * 8
        ),
        origParent, origPos, origQuat, origScale,
      };
      parts.push(part);
      partsByName[d.name] = part;
    }

    // 初期インパルス: タックル方向 + 上向きの跳ね上げ
    const dirX = impulseDir ? impulseDir.x : 0;
    const dirZ = impulseDir ? impulseDir.z : 1;
    const s = strength || 6;
    parts.forEach(p => {
      p.vel.set(
        dirX * s * (0.8 + Math.random() * 0.5) + (Math.random()-0.5) * 1.5,
        3 + Math.random() * 2.5,
        dirZ * s * (0.8 + Math.random() * 0.5) + (Math.random()-0.5) * 1.5
      );
    });

    // 制約: torso-head, torso-armL, torso-armR, torso-legL, torso-legR
    const cons = [];
    const link = (aName, bName, slack) => {
      const a = partsByName[aName], b = partsByName[bName];
      if (!a || !b) return;
      const d = a.pos.distanceTo(b.pos);
      cons.push({ a, b, dist: d, minDist: d * 0.6, maxDist: d * (1 + (slack || 0.05)) });
    };
    // slack を極小にして四肢を胴体にリジッド接続 (遅延 0)
    link('torso', 'head',  0.002);
    link('torso', 'armL',  0.002);
    link('torso', 'armR',  0.002);
    link('torso', 'legL',  0.002);
    link('torso', 'legR',  0.002);
    // 二次的: 腕同士・脚同士は離れすぎないように
    link('armL', 'armR', 0.40);
    link('legL', 'legR', 0.30);

    // 元グループの位置を保存 (復元時に使用)
    const ragdoll = {
      group, parts, partsByName, cons,
      life: 0,
      origPos: group.position.clone(),
      origRotY: group.rotation.y,
      hiddenChildren,
    };
    group._ragdoll = ragdoll;
    if (!Judo._ragdolls) Judo._ragdolls = [];
    Judo._ragdolls.push(ragdoll);
    return ragdoll;
  }

  // ラグドールを解除し元キャラに戻す
  function _restoreFromRagdoll(group) {
    const r = group && group._ragdoll;
    if (!r) return;
    const THREE = Judo.THREE;
    // 胴体の現在位置を新しいキャラ位置に
    const torso = r.partsByName.torso;
    const newX = torso ? torso.pos.x : r.origPos.x;
    const newZ = torso ? torso.pos.z : r.origPos.z;
    group.position.set(newX, 0, newZ);

    // 元の親に戻し、ローカル変換を復元
    r.parts.forEach(p => {
      try {
        if (p.origParent) p.origParent.attach(p.mesh);
        p.mesh.position.copy(p.origPos);
        p.mesh.quaternion.copy(p.origQuat);
        p.mesh.scale.copy(p.origScale);
        p.mesh.rotation.x = 0;
        p.mesh.rotation.y = 0;
        p.mesh.rotation.z = 0;
      } catch (e) {}
    });

    // 一時非表示にしていた子供たちを復元
    if (r.hiddenChildren) {
      r.hiddenChildren.forEach(h => { try { h.mesh.visible = h.vis; } catch (e) {} });
    }

    // リストから除去
    if (Judo._ragdolls) {
      const idx = Judo._ragdolls.indexOf(r);
      if (idx >= 0) Judo._ragdolls.splice(idx, 1);
    }
    group._ragdoll = null;
  }

  // 自分以外の (立っているまたはラグドール化中の) もう一方のキャラと衝突解決
  function _collideWithStanding(part, otherGroup) {
    if (!otherGroup) return;
    // 相手キャラを高さ 0〜2.6 / 半径 0.66 のカプセルとして近似
    const ox = otherGroup.position.x;
    const oz = otherGroup.position.z;
    const dx = part.pos.x - ox;
    const dz = part.pos.z - oz;
    const planar = Math.hypot(dx, dz);
    const otherR = (otherGroup.userData && otherGroup.userData.collisionRadius) ? otherGroup.userData.collisionRadius * 0.7 : 0.6;
    const minDist = otherR + part.radius;
    if (planar < minDist && part.pos.y < 2.6 && part.pos.y > 0.05) {
      const overlap = minDist - planar;
      const nx = planar > 1e-4 ? dx / planar : 1;
      const nz = planar > 1e-4 ? dz / planar : 0;
      // パーツを押し出し
      part.pos.x += nx * overlap;
      part.pos.z += nz * overlap;
      // 立っているキャラには反作用で軽く押し戻し
      if (!otherGroup._ragdoll && !otherGroup._isStunFrozen) {
        const pushBack = 0.45;
        otherGroup.position.x -= nx * overlap * pushBack;
        otherGroup.position.z -= nz * overlap * pushBack;
        if (typeof _clampArena === 'function') _clampArena(otherGroup);
      }
      // 速度の法線成分を反射
      const dot = part.vel.x * nx + part.vel.z * nz;
      if (dot < 0) {
        part.vel.x -= (1 + RAG.restitution) * dot * nx;
        part.vel.z -= (1 + RAG.restitution) * dot * nz;
      }
      part.vel.x *= 0.78;
      part.vel.z *= 0.78;
    }
  }

  // ラグドール同士の部位vs部位コリジョン (球vs球)
  function _collidePartVsPart(a, b) {
    const dx = b.pos.x - a.pos.x;
    const dy = b.pos.y - a.pos.y;
    const dz = b.pos.z - a.pos.z;
    const d2 = dx*dx + dy*dy + dz*dz;
    const rsum = a.radius + b.radius;
    if (d2 >= rsum * rsum) return;
    const d = Math.sqrt(d2) || 1e-4;
    const overlap = rsum - d;
    const nx = dx / d, ny = dy / d, nz = dz / d;
    const totalInvMass = a.invMass + b.invMass;
    const aShare = a.invMass / totalInvMass;
    const bShare = b.invMass / totalInvMass;
    a.pos.x -= nx * overlap * aShare;
    a.pos.y -= ny * overlap * aShare;
    a.pos.z -= nz * overlap * aShare;
    b.pos.x += nx * overlap * bShare;
    b.pos.y += ny * overlap * bShare;
    b.pos.z += nz * overlap * bShare;
    // 速度反射
    const relVx = b.vel.x - a.vel.x;
    const relVy = b.vel.y - a.vel.y;
    const relVz = b.vel.z - a.vel.z;
    const velAlong = relVx * nx + relVy * ny + relVz * nz;
    if (velAlong < 0) {
      const j = -(1 + RAG.restitution) * velAlong / totalInvMass;
      a.vel.x -= j * nx * a.invMass;
      a.vel.y -= j * ny * a.invMass;
      a.vel.z -= j * nz * a.invMass;
      b.vel.x += j * nx * b.invMass;
      b.vel.y += j * ny * b.invMass;
      b.vel.z += j * nz * b.invMass;
    }
  }

  // 距離制約 (バネ的なリンク)
  function _resolveConstraint(c) {
    const a = c.a, b = c.b;
    const dx = b.pos.x - a.pos.x;
    const dy = b.pos.y - a.pos.y;
    const dz = b.pos.z - a.pos.z;
    const d = Math.hypot(dx, dy, dz) || 1e-4;
    let target = 0, doCorrect = false;
    if (d > c.maxDist)      { target = c.maxDist; doCorrect = true; }
    else if (d < c.minDist) { target = c.minDist; doCorrect = true; }
    if (!doCorrect) return;
    const diff = (d - target) * 0.5;
    const nx = dx / d, ny = dy / d, nz = dz / d;
    const totalInvMass = a.invMass + b.invMass;
    if (totalInvMass <= 0) return;
    const aShare = a.invMass / totalInvMass;
    const bShare = b.invMass / totalInvMass;
    a.pos.x += nx * diff * 2 * aShare;
    a.pos.y += ny * diff * 2 * aShare;
    a.pos.z += nz * diff * 2 * aShare;
    b.pos.x -= nx * diff * 2 * bShare;
    b.pos.y -= ny * diff * 2 * bShare;
    b.pos.z -= nz * diff * 2 * bShare;
  }

  // 一つのラグドールを 1ステップ更新
  function _stepRagdoll(r, dt) {
    const parts = r.parts;
    const arenaR = (typeof Judo !== 'undefined' && Judo.arenaRadius) ? Judo.arenaRadius : 4.2;
    r.life += dt;

    // ① 重力 + 速度積分
    parts.forEach(p => {
      p.vel.y -= RAG.gravity * dt;
      p.pos.x += p.vel.x * dt;
      p.pos.y += p.vel.y * dt;
      p.pos.z += p.vel.z * dt;

      // 床
      if (p.pos.y < p.radius) {
        p.pos.y = p.radius;
        if (p.vel.y < 0) p.vel.y = -p.vel.y * RAG.restitution;
        p.vel.x *= RAG.friction;
        p.vel.z *= RAG.friction;
        p.angVel.multiplyScalar(0.7);
      }
      // アリーナ境界 (円)
      const planar = Math.hypot(p.pos.x, p.pos.z);
      const limit = arenaR - p.radius * 0.4;
      if (planar > limit) {
        const nx = p.pos.x / planar, nz = p.pos.z / planar;
        p.pos.x = nx * limit;
        p.pos.z = nz * limit;
        const dot = p.vel.x * nx + p.vel.z * nz;
        if (dot > 0) {
          p.vel.x -= (1 + RAG.restitution) * dot * nx;
          p.vel.z -= (1 + RAG.restitution) * dot * nz;
        }
      }
    });

    // ② 制約 (距離リンク) を複数回反復
    for (let it = 0; it < RAG.iterations; it++) {
      r.cons.forEach(_resolveConstraint);
      // 自分の部位同士の貫通防止
      for (let i = 0; i < parts.length; i++) {
        for (let j = i + 1; j < parts.length; j++) {
          // 制約で繋がっているペアはすり抜け OK (制約に任せる)
          _collidePartVsPart(parts[i], parts[j]);
        }
      }
    }

    // ③ もう一方のキャラとの衝突 (立ち姿 or ラグドール)
    const other = (r.group === Judo.me) ? Judo.en : Judo.me;
    if (other) {
      if (other._ragdoll) {
        // ラグドール同士: 全パーツペアで衝突
        const op = other._ragdoll.parts;
        for (let i = 0; i < parts.length; i++) {
          for (let j = 0; j < op.length; j++) {
            _collidePartVsPart(parts[i], op[j]);
          }
        }
      } else {
        parts.forEach(p => _collideWithStanding(p, other));
      }
    }

    // ④ 摩擦/減衰
    parts.forEach(p => {
      p.vel.x *= RAG.damping;
      p.vel.z *= RAG.damping;
      p.angVel.multiplyScalar(RAG.angDamping);
      // メッシュへ位置/回転を反映
      p.mesh.position.copy(p.pos);
      p.mesh.rotation.x += p.angVel.x * dt;
      p.mesh.rotation.y += p.angVel.y * dt;
      p.mesh.rotation.z += p.angVel.z * dt;
    });

    // ⑤ グループ位置を胴体に同期 (敵 AI / カメラ / 立ち姿コリジョン用)
    const torsoP = r.partsByName.torso;
    if (torsoP && r.group) {
      r.group.position.x = torsoP.pos.x;
      r.group.position.z = torsoP.pos.z;
      // ラグドール中の中心点は地面に固定 (敵AI の距離計算が安定)
    }
  }

  function _updateRagdollsJudo(dt) {
    if (!Judo._ragdolls || !Judo._ragdolls.length) return;
    // 物理は小さい dt で複数ステップ実行 (安定性)
    const sub = 2;
    const sdt = dt / sub;
    for (let s = 0; s < sub; s++) {
      for (let i = Judo._ragdolls.length - 1; i >= 0; i--) {
        const r = Judo._ragdolls[i];
        _stepRagdoll(r, sdt);
      }
    }
  }

  // ---------- 13. _animateJudoka をラップ ----------
  // ラグドール化中はアニメーションを上書きしない (ラグドールが座標を支配)
  function _wrapAnimateJudoka() {
    if (typeof _animateJudoka === 'undefined' || _animateJudoka.__wrapped) return;
    const orig = window._animateJudoka;
    window._animateJudoka = function(g, pose, t, time) {
      if (g && g._ragdoll) {
        // ラグドール中はパーツがシーン直下にあるので何もしない
        return;
      }
      return orig.apply(this, arguments);
    };
    window._animateJudoka.__wrapped = true;
  }

  // ---------- 14. _judoLoop をラップ ----------
  function _wrapJudoLoop() {
    if (typeof _judoLoop === 'undefined' || _judoLoop.__wrapped) return;
    const orig = window._judoLoop;
    let prevTime = 0;
    window._judoLoop = function(now) {
      // 1. ラグドール開始トリガ: stun になった瞬間にラグドール化
      try {
        if (Judo.running && Judo.me && Judo.meStunT > 0 && !Judo.me._ragdoll) {
          const dir = _calcKnockDir(Judo.en, Judo.me);
          _buildRagdoll(Judo.me, dir, 7.5);
        }
        if (Judo.running && Judo.en && Judo.enStunT > 0 && !Judo.en._ragdoll) {
          const dir = _calcKnockDir(Judo.me, Judo.en);
          _buildRagdoll(Judo.en, dir, 7.5);
        }
        // 解除: スタン終了でラグドール終了
        if (Judo.me && Judo.me._ragdoll && Judo.meStunT <= 0) {
          _restoreFromRagdoll(Judo.me);
        }
        if (Judo.en && Judo.en._ragdoll && Judo.enStunT <= 0) {
          _restoreFromRagdoll(Judo.en);
        }
      } catch (e) {}

      // 2. シールド回復 (毎フレーム)
      try {
        const dt = prevTime ? Math.min(0.05, (now - prevTime) / 1000) : 0.016;
        prevTime = now;

        if (!Judo.meGuard) {
          if (Judo.shieldRegenT > 0) Judo.shieldRegenT -= dt;
          else if (Judo.shield < Judo.shieldMax) {
            Judo.shield = Math.min(Judo.shieldMax, Judo.shield + Judo.shieldRegen * dt);
            if (Judo.shieldBroken && Judo.shield > Judo.shieldMax * 0.5) Judo.shieldBroken = false;
          }
        }

        // 3. 敵の先読み回避 (移動)
        if (Judo.enemyDodgeT > 0 && Judo.en) {
          const dodgeSpeed = 8.1 * (0.45 + Judo.enemyDodgeT);
          Judo.en.position.x += Judo.enemyDodgeDir.x * dodgeSpeed * dt;
          Judo.en.position.z += Judo.enemyDodgeDir.z * dodgeSpeed * dt;
          if (typeof _clampArena === 'function') _clampArena(Judo.en);
          Judo.enemyDodgeT -= dt;
          Judo.nextAfterimageT -= dt;
          if (Judo.nextAfterimageT <= 0) {
            _spawnEnemyAfterimageJudo();
            Judo.nextAfterimageT = 0.045;
          }
          if (Judo.enemyDodgeT <= 0 && !Judo.enAction) Judo.enPose = 'idle';
        }

        // 4. ラグドール物理更新
        _updateRagdollsJudo(dt);

        // 5. 残像更新
        _updateAfterimagesJudo(dt, now * 0.001);
      } catch (e) {}

      // 元ループ呼び出し
      const r = orig.apply(this, arguments);

      // 6. シールド UI 更新
      try { _updateJudoShieldUI(); } catch (e) {}
      return r;
    };
    window._judoLoop.__wrapped = true;
  }

  // 攻撃者→被攻撃者 への単位ベクトル
  function _calcKnockDir(from, to) {
    if (!from || !to) return { x: 0, z: 1 };
    const dx = to.position.x - from.position.x;
    const dz = to.position.z - from.position.z;
    const d = Math.hypot(dx, dz) || 1;
    return { x: dx / d, z: dz / d };
  }

  // ---------- 14b. _resolveJudoCollision ラップ: ラグドール中はスキップ ----------
  function _wrapResolveCollision() {
    if (typeof _resolveJudoCollision === 'undefined' || _resolveJudoCollision.__wrapped) return;
    const orig = window._resolveJudoCollision;
    window._resolveJudoCollision = function() {
      // どちらかがラグドール中ならグループ間コリジョンはスキップ (四肢コリジョンに委ねる)
      if ((Judo.me && Judo.me._ragdoll) || (Judo.en && Judo.en._ragdoll)) return;
      return orig.apply(this, arguments);
    };
    window._resolveJudoCollision.__wrapped = true;
  }

  // ---------- 15. _disposeJudo ラップ: クリーンアップ ----------
  function _wrapDispose() {
    if (typeof _disposeJudo === 'undefined' || _disposeJudo.__wrapped) return;
    const orig = window._disposeJudo;
    window._disposeJudo = function() {
      try {
        // ラグドール強制復元
        if (Judo.me && Judo.me._ragdoll) _restoreFromRagdoll(Judo.me);
        if (Judo.en && Judo.en._ragdoll) _restoreFromRagdoll(Judo.en);
        Judo._ragdolls = [];
        _cleanupAfterimagesJudo();
        Judo.shield = Judo.shieldMax;
        Judo.shieldBroken = false;
        Judo.shieldRegenT = 0;
        const ring = $$('judoShieldRing'); if (ring) ring.style.display = 'none';
      } catch (e) {}
      return orig.apply(this, arguments);
    };
    window._disposeJudo.__wrapped = true;
  }

  // ---------- 16. startJudo ラップ: シールド/状態をリセット ----------
  function _wrapStartJudo() {
    if (typeof startJudo === 'undefined' || startJudo.__wrapped) return;
    const orig = window.startJudo;
    window.startJudo = function() {
      _extendAttacks();
      _extendJudoState();
      // リセット
      Judo.shield        = Judo.shieldMax;
      Judo.shieldBroken  = false;
      Judo.shieldRegenT  = 0;
      Judo.enemyDodgeT   = 0;
      Judo.enemyAfterimages = [];
      Judo._ragdolls     = [];
      const r = orig.apply(this, arguments);
      // 初期化後、UI を確実に注入
      setTimeout(_injectJudoUI, 30);
      return r;
    };
    window.startJudo.__wrapped = true;
  }

  // ---------- 全部のフックを設置 ----------
  function _installAll() {
    _extendAttacks();
    _extendJudoState();
    _wrapBindControls();
    _wrapPlayerAction();
    _wrapSetGuard();
    _wrapApplyHit();
    _wrapStartEnemyAction();
    _wrapEnemyThink();
    _wrapAnimateJudoka();
    _wrapResolveCollision();
    _wrapJudoLoop();
    _wrapDispose();
    _wrapStartJudo();
  }

  // 既存スクリプト読み込み完了後に確実にラップ
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', _installAll);
  } else {
    // 即実行 + 念のため遅延でも再実行
    _installAll();
    setTimeout(_installAll, 0);
    window.addEventListener('load', _installAll, { once:true });
  }
})();
</script>

<!-- ====== パーティーコード (マルチプレイヤーロビー) パッチ ====== -->
<style>
  .partyBox {
    margin: 10px 4px 4px;
    padding: 12px;
    background: linear-gradient(135deg, rgba(120,160,255,0.18), rgba(247,201,72,0.18));
    border: 1px solid rgba(247,201,72,0.45);
    border-radius: 14px;
    color: #fff;
  }
  .partyBox h3 {
    margin: 0 0 6px; font-size: 14px; color: #ffd76b; text-align: center;
  }
  .partyBox .partyDesc {
    font-size: 11px; opacity: 0.75; text-align: center; margin-bottom: 10px;
  }
  .partyBox .partyRow {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  }
  .partyBox button.partyBtn {
    padding: 10px 8px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.25);
    background: rgba(0,0,0,0.35); color: #fff; font-weight: bold; font-size: 13px;
    cursor: pointer;
  }
  .partyBox button.partyBtn:active { transform: scale(0.97); background: rgba(247,201,72,0.25); }
  .partyBox .partyState {
    margin-top: 10px; padding: 8px; border-radius: 8px;
    background: rgba(0,0,0,0.35); font-size: 12px; text-align: center;
  }
  .partyBox .partyCode {
    display: inline-block; font-family: "Courier New", monospace;
    font-size: 22px; font-weight: bold; color: #ffd76b;
    letter-spacing: 4px; padding: 2px 10px; border-radius: 6px;
    background: rgba(0,0,0,0.45); margin: 4px 4px 0;
  }
  .partyBox .partyLeaveBtn {
    margin-top: 8px; padding: 6px 12px; border-radius: 8px;
    border: 1px solid rgba(255,120,120,0.5); background: rgba(255,80,80,0.18);
    color: #ffd3d3; font-size: 12px; cursor: pointer;
  }
  .partyModalBox {
    background: rgba(20,20,30,0.96); border: 1px solid rgba(247,201,72,0.5);
    border-radius: 14px; padding: 18px; width: 86%; max-width: 320px;
    color: #fff; text-align: center;
  }
  .partyModalBox h2 { color: #f7c948; margin: 0 0 10px; font-size: 17px; }
  .partyModalBox input.codeInput {
    width: 110px; padding: 10px; text-align: center;
    font-family: "Courier New", monospace; font-size: 24px; font-weight: bold;
    letter-spacing: 6px; text-transform: uppercase;
    background: rgba(0,0,0,0.5); color: #ffd76b;
    border: 2px solid rgba(247,201,72,0.5); border-radius: 8px;
    outline: none;
  }
  .partyModalBox .row { display: flex; gap: 8px; margin-top: 14px; justify-content: center; }
  .partyModalBox .row button {
    padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.25);
    background: rgba(0,0,0,0.4); color: #fff; cursor: pointer; font-weight: bold;
  }
  .partyModalBox .row button.primary {
    background: rgba(247,201,72,0.3); border-color: rgba(247,201,72,0.7); color: #ffd76b;
  }
</style>
<script>
/* ============================================================
   パーティーコード (2桁英数字混在) でマルチプレイヤーロビーを作る/参加する機能
   - 同じコードを持つプレイヤー同士が同じ PeerJS ルームで P2P 接続される
   - 作る: ランダム 2桁コードを生成してホスト化
   - 参加: 2桁コードを入力して接続
   ============================================================ */
(function(){
  if (window.__partyCodePatch) return;
  window.__partyCodePatch = true;

  const PARTY_PREFIX = 'garigari-judo-party-';
  const CODE_CHARS   = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; // 紛らわしい文字を除く英数字
  const CODE_LEN     = 2;

  const Party = {
    code: null,       // 現在参加中のコード
    role: null,       // 'host' | 'guest'
    peer: null,       // 独自の PeerJS インスタンス
    conns: new Map(), // peer.id -> conn
    members: 1,
  };

  function $(id){ return document.getElementById(id); }
  function genCode() {
    let s = '';
    for (let i=0; i<CODE_LEN; i++) {
      s += CODE_CHARS[Math.floor(Math.random() * CODE_CHARS.length)];
    }
    return s;
  }
  function normalize(code) {
    return (code||'').toString().toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, CODE_LEN);
  }
  function showToastSafe(msg) {
    try {
      if (typeof showToast === 'function') showToast(msg);
      else console.log('[party]', msg);
    } catch(e) { console.log('[party]', msg); }
  }

  /* ---------- UI 注入 ---------- */
  function injectPartyUI() {
    const menuScreen = $('screen-menu');
    if (!menuScreen) return;
    const menuList = menuScreen.querySelector('.menu');
    if (!menuList || $('partyBox')) return;
    const box = document.createElement('div');
    box.className = 'partyBox';
    box.id = 'partyBox';
    box.innerHTML = `
      <h3>🎮 パーティーコード (マルチプレイヤー)</h3>
      <div class="partyDesc">2桁のコードで友達とロビーを共有</div>
      <div class="partyRow">
        <button class="partyBtn" id="btnPartyCreate">🆕 パーティーを作る</button>
        <button class="partyBtn" id="btnPartyJoin">🚪 パーティーに参加</button>
      </div>
      <div class="partyState" id="partyState" style="display:none;"></div>
    `;
    menuList.appendChild(box);

    $('btnPartyCreate').onclick = () => createParty();
    $('btnPartyJoin').onclick   = () => openJoinModal();

    // 参加モーダル
    const modal = document.createElement('div');
    modal.id = 'partyJoinModal';
    modal.style.cssText = 'position:fixed;inset:0;display:none;z-index:9999;align-items:center;justify-content:center;background:rgba(0,0,0,0.7);';
    modal.innerHTML = `
      <div class="partyModalBox">
        <h2>パーティーに参加</h2>
        <div style="font-size:12px;opacity:0.7;margin-bottom:8px;">2桁のコードを入力 (英数字)</div>
        <input id="partyCodeInput" class="codeInput" type="text" maxlength="2" inputmode="text" autocomplete="off">
        <div class="row">
          <button id="partyJoinCancel">キャンセル</button>
          <button id="partyJoinOk" class="primary">参加</button>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    $('partyJoinCancel').onclick = () => modal.style.display = 'none';
    $('partyJoinOk').onclick = () => {
      const code = normalize($('partyCodeInput').value);
      if (code.length !== CODE_LEN) { showToastSafe('2桁のコードを入力してください'); return; }
      modal.style.display = 'none';
      joinParty(code);
    };
    $('partyCodeInput').addEventListener('input', e => {
      e.target.value = normalize(e.target.value);
    });
  }

  function openJoinModal() {
    const m = $('partyJoinModal');
    if (!m) return;
    $('partyCodeInput').value = '';
    m.style.display = 'flex';
    setTimeout(() => { try { $('partyCodeInput').focus(); } catch(e){} }, 50);
  }

  function renderState() {
    const el = $('partyState');
    if (!el) return;
    const createBtn = $('btnPartyCreate');
    const joinBtn   = $('btnPartyJoin');
    if (!Party.code) {
      el.style.display = 'none';
      if (createBtn) createBtn.disabled = false;
      if (joinBtn)   joinBtn.disabled = false;
      return;
    }
    el.style.display = 'block';
    const roleLabel = Party.role === 'host' ? 'ホスト' : 'ゲスト';
    el.innerHTML = `
      <div>パーティー <b>${roleLabel}</b> ・ 仲間 ${Party.members} 人</div>
      <div>コード: <span class="partyCode">${Party.code}</span></div>
      <button class="partyLeaveBtn" id="btnPartyLeave">パーティーを抑ける</button>
    `;
    const lb = $('btnPartyLeave');
    if (lb) lb.onclick = () => leaveParty();
    if (createBtn) createBtn.disabled = true;
    if (joinBtn)   joinBtn.disabled = true;
  }

  /* ---------- PeerJS ローム処理 ---------- */
  function ensurePeerLibrary() {
    return new Promise((resolve, reject) => {
      if (typeof Peer !== 'undefined') return resolve();
      // PeerJS は既に読み込まれているはずだがフォールバック
      let tries = 0;
      const t = setInterval(() => {
        if (typeof Peer !== 'undefined') { clearInterval(t); resolve(); }
        else if (++tries > 30) { clearInterval(t); reject(new Error('PeerJS not loaded')); }
      }, 200);
    });
  }

  function destroyPeer() {
    if (Party.peer) {
      try { Party.peer.destroy(); } catch(e) {}
      Party.peer = null;
    }
    Party.conns.clear();
    Party.members = 1;
  }

  function attachConn(conn) {
    if (Party.conns.has(conn.peer)) return;
    Party.conns.set(conn.peer, conn);
    Party.members = Party.conns.size + 1;
    renderState();
    conn.on('data', d => {
      // 将来的にゲーム状態同期に使うためのフック
      try { window.dispatchEvent(new CustomEvent('partyMessage', { detail: { from: conn.peer, data: d } })); } catch(e) {}
    });
    conn.on('close', () => {
      Party.conns.delete(conn.peer);
      Party.members = Party.conns.size + 1;
      renderState();
    });
    try { conn.send({ type: 'hello', code: Party.code }); } catch(e) {}
  }

  function createParty() {
    if (Party.code) { showToastSafe('すでにパーティーに参加中'); return; }
    ensurePeerLibrary().then(() => {
      // 重複しないように最大5回トライ
      tryCreate(0);
    }).catch(err => showToastSafe('PeerJS 読み込み失敗'));
  }

  function tryCreate(attempt) {
    if (attempt >= 5) { showToastSafe('パーティー作成失敗 (コード重複)'); return; }
    const code = genCode();
    const roomId = PARTY_PREFIX + code;
    showToastSafe('パーティー作成中...');
    const peer = new Peer(roomId, { debug: 0 });
    let resolved = false;
    peer.on('open', () => {
      resolved = true;
      Party.peer = peer;
      Party.code = code;
      Party.role = 'host';
      Party.members = 1;
      peer.on('connection', conn => {
        conn.on('open', () => attachConn(conn));
      });
      peer.on('disconnected', () => { try { peer.reconnect(); } catch(e) {} });
      renderState();
      showToastSafe('パーティー作成! コード: ' + code);
    });
    peer.on('error', err => {
      if (!resolved) {
        try { peer.destroy(); } catch(e) {}
        // ID 重複なら別コードでリトライ
        tryCreate(attempt + 1);
      }
    });
  }

  function joinParty(code) {
    if (Party.code) { showToastSafe('すでにパーティーに参加中'); return; }
    ensurePeerLibrary().then(() => {
      const roomId = PARTY_PREFIX + code;
      const clientId = PARTY_PREFIX + 'c-' + (typeof randID === 'function' ? randID(6) : Math.random().toString(36).slice(2,8));
      showToastSafe('パーティー ' + code + ' に接続中...');
      const peer = new Peer(clientId, { debug: 0 });
      let resolved = false;
      peer.on('open', () => {
        const conn = peer.connect(roomId, { reliable: true });
        let opened = false;
        conn.on('open', () => {
          opened = true; resolved = true;
          Party.peer = peer;
          Party.code = code;
          Party.role = 'guest';
          Party.members = 2;
          peer.on('disconnected', () => { try { peer.reconnect(); } catch(e) {} });
          attachConn(conn);
          renderState();
          showToastSafe('パーティー ' + code + ' に参加!');
        });
        conn.on('error', () => {});
        setTimeout(() => {
          if (!opened) {
            try { peer.destroy(); } catch(e) {}
            if (!resolved) showToastSafe('パーティー ' + code + ' が見つかりません');
          }
        }, 4000);
      });
      peer.on('error', err => {
        if (!resolved) {
          try { peer.destroy(); } catch(e) {}
          showToastSafe('接続失敗: コードを確認してください');
        }
      });
    }).catch(err => showToastSafe('PeerJS 読み込み失敗'));
  }

  function leaveParty() {
    if (!Party.code) return;
    destroyPeer();
    Party.code = null;
    Party.role = null;
    renderState();
    showToastSafe('パーティーを抑けました');
  }

  // グローバル API として公開
  window.GariParty = {
    state: Party,
    create: createParty,
    join:   joinParty,
    leave:  leaveParty,
    broadcast(data) {
      Party.conns.forEach(c => { try { c.send(data); } catch(e) {} });
    }
  };

  // DOM 準備完了後に UI 注入
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectPartyUI);
  } else {
    injectPartyUI();
  }
})();
</script>

<!-- =====================================================================
     v15 追加パッチ:
      1) 回避(ロール)中にプレイヤーの残像をスポーン (敵と同じ仕組み)
      2) ボット専用必殺技: アッパーカット (34 ダメージ / CD 60 秒)
      3) リバイブ回数: 2 回 (revive ループの再開放を防ぐ)
      4) シールド優先吸収: ガードしてなくてもシールド体力があれば自動で吸収
      5) 被ダメで視点(カメラ)が相手方向に傾く (ロール / ピッチ揺らぎ)
     ===================================================================== -->
<script>
(function(){
  if (window.__gariV15Patch) return;
  window.__gariV15Patch = true;

  // ---------------- 共通ユーティリティ ----------------
  function _rand(a, b) { return a + Math.random() * (b - a); }
  function _flash(mode, msg, color, ms) {
    try {
      if (mode === 'boxing' && typeof _flashMsgBoxing === 'function') _flashMsgBoxing(msg, color, ms);
      else if (typeof _flashMsg === 'function') _flashMsg(msg, color, ms);
    } catch(e) {}
  }

  // ====================================================================
  // 1)  プレイヤー残像 (Boxing + Judo)  — ロール中 / 被ダメ時に発生
  // ====================================================================
  function _spawnPlayerAfterimageBoxing() {
    if (typeof Boxing === 'undefined' || !Boxing.me || !Boxing.scene || !Boxing.THREE) return;
    if (!Boxing.playerAfterimages) Boxing.playerAfterimages = [];
    Boxing.playerAfterimages.push({
      x: Boxing.me.position.x,
      z: Boxing.me.position.z,
      rotY: Boxing.me.rotation.y,
      pose: Boxing.mePose || 'roll',
      anim: Boxing.meAnim || 0,
      life: 0.55, maxLife: 0.55,
    });
    if (Boxing.playerAfterimages.length > 8) Boxing.playerAfterimages.shift();
  }
  function _spawnPlayerAfterimageJudo() {
    if (typeof Judo === 'undefined' || !Judo.me || !Judo.scene || !Judo.THREE) return;
    if (!Judo.playerAfterimages) Judo.playerAfterimages = [];
    Judo.playerAfterimages.push({
      x: Judo.me.position.x,
      z: Judo.me.position.z,
      rotY: Judo.me.rotation.y,
      pose: Judo.mePose || 'roll',
      anim: Judo.meAnim || 0,
      life: 0.55, maxLife: 0.55,
    });
    if (Judo.playerAfterimages.length > 8) Judo.playerAfterimages.shift();
  }
  function _disposePlayerAfterimage(g) {
    if (!g || !g.mesh) return;
    if (g.mesh.parent) g.mesh.parent.remove(g.mesh);
    g.mesh.traverse(o => {
      if (o.geometry) try { o.geometry.dispose(); } catch(e) {}
      if (o.material) {
        const mats = Array.isArray(o.material) ? o.material : [o.material];
        mats.forEach(m => { try { m.dispose(); } catch(e) {} });
      }
    });
    g.mesh = null;
  }
  function _updatePlayerAfterimagesBoxing(dt, time) {
    if (typeof Boxing === 'undefined') return;
    if (!Boxing.playerAfterimages || !Boxing.playerAfterimages.length) return;
    if (!Boxing.scene || !Boxing.THREE) return;
    const next = [];
    for (let i = 0; i < Boxing.playerAfterimages.length; i++) {
      const g = Boxing.playerAfterimages[i];
      g.life -= dt;
      _disposePlayerAfterimage(g);
      if (g.life <= 0) continue;
      const mesh = _buildJudoka(Boxing.THREE, 0xffd76b, true);
      mesh.position.set(g.x, 0, g.z);
      mesh.rotation.y = g.rotY;
      mesh.scale.setScalar(0.985);
      const alpha = Math.max(0.10, Math.min(0.55, g.life / g.maxLife * 0.55));
      mesh.traverse(o => {
        if (o.isMesh && o.material) {
          const mats = Array.isArray(o.material) ? o.material : [o.material];
          o.material = mats.map(m => {
            const mm = m.clone();
            mm.transparent = true; mm.opacity = alpha;
            if (mm.color) mm.color.offsetHSL(0.05, -0.05, 0.18);
            return mm;
          });
        }
      });
      _animateJudoka(mesh, g.pose, g.anim, time);
      Boxing.scene.add(mesh);
      g.mesh = mesh;
      next.push(g);
    }
    Boxing.playerAfterimages = next;
  }
  function _updatePlayerAfterimagesJudo(dt, time) {
    if (typeof Judo === 'undefined') return;
    if (!Judo.playerAfterimages || !Judo.playerAfterimages.length) return;
    if (!Judo.scene || !Judo.THREE) return;
    const next = [];
    for (let i = 0; i < Judo.playerAfterimages.length; i++) {
      const g = Judo.playerAfterimages[i];
      g.life -= dt;
      _disposePlayerAfterimage(g);
      if (g.life <= 0) continue;
      const mesh = _buildJudoka(Judo.THREE, 0xffd76b, true);
      mesh.position.set(g.x, 0, g.z);
      mesh.rotation.y = g.rotY;
      mesh.scale.setScalar(0.985);
      const alpha = Math.max(0.10, Math.min(0.55, g.life / g.maxLife * 0.55));
      mesh.traverse(o => {
        if (o.isMesh && o.material) {
          const mats = Array.isArray(o.material) ? o.material : [o.material];
          o.material = mats.map(m => {
            const mm = m.clone();
            mm.transparent = true; mm.opacity = alpha;
            if (mm.color) mm.color.offsetHSL(0.05, -0.05, 0.18);
            return mm;
          });
        }
      });
      _animateJudoka(mesh, g.pose, g.anim, time);
      Judo.scene.add(mesh);
      g.mesh = mesh;
      next.push(g);
    }
    Judo.playerAfterimages = next;
  }

  // ロール (回避) 中の毎フレームスポーン用タイマー
  let _bxPlayerAfterT = 0;
  let _jdPlayerAfterT = 0;

  // ====================================================================
  // 2)  ボット専用: アッパーカット (uppercut)
  // ====================================================================
  // BOXING_ATTACKS / JUDO_ATTACKS に登録するがプレイヤーからは触れない。
  function _registerUppercut() {
    if (typeof BOXING_ATTACKS !== 'undefined' && !BOXING_ATTACKS.uppercut) {
      BOXING_ATTACKS.uppercut = {
        label: 'アッパーカット',
        range: 1.7,
        damage: [34, 34],
        hitAt: 0.34,
        total: 0.66,
        cooldown: 60 * 60,         // ※他攻撃と単位を合わせるための値 (実 CD は別管理)
        score: 0,
        color: '#ff5577',
        shieldDmg: 28,
        knockback: true,
        botOnly: true,
      };
    }
    if (typeof JUDO_ATTACKS !== 'undefined' && !JUDO_ATTACKS.uppercut) {
      JUDO_ATTACKS.uppercut = {
        label: 'アッパーカット',
        range: 1.7,
        damage: [34, 34],
        hitAt: 0.34,
        total: 0.66,
        cooldown: 60 * 60,
        score: 0,
        color: '#ff5577',
        shieldDmg: 28,
        knockback: true,
        botOnly: true,
      };
    }
  }

  // ボット側の実 CD (秒) を独自管理
  if (typeof Boxing !== 'undefined') {
    Boxing.uppercutCD = 0;        // 0 になったら撃てる
    Boxing.uppercutCDMax = 60;
  }
  if (typeof Judo !== 'undefined') {
    Judo.uppercutCD = 0;
    Judo.uppercutCDMax = 60;
  }

  function _tryFireUppercutBoxing() {
    if (typeof Boxing === 'undefined' || !Boxing.en || !Boxing.me) return false;
    if (Boxing.mode !== 'fight') return false;
    if (Boxing.enAction || Boxing.enRagdoll || Boxing.enemyDodgeT > 0) return false;
    if ((Boxing.uppercutCD || 0) > 0) return false;
    const dist = Math.hypot(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
    if (dist > 1.85) return false;
    // 至近距離・プレイヤーが攻撃モーション中 or HP 50% 以下のとき発動率高め
    let prob = 0.014;
    if (Boxing.meAction) prob += 0.04;
    if (Boxing.meHP / Boxing.meMaxHP < 0.55) prob += 0.02;
    if (Math.random() > prob) return false;
    const spec = BOXING_ATTACKS.uppercut;
    Boxing.enPose = 'uppercut';
    Boxing.enAnim = 0;
    Boxing.enAction = {
      side:'en', kind:'uppercut',
      label: (Boxing.isPro ? 'プロ' : '敵') + spec.label,
      range: spec.range,
      damage: [spec.damage[0], spec.damage[1]],
      hitAt: spec.hitAt,
      total: spec.total,
      cooldown: 0,
      color: spec.color,
      score: 0,
      knockback: true,
      shieldDmg: spec.shieldDmg,
      t: 0, hitDone: false,
      isUppercut: true,
    };
    Boxing.uppercutCD = Boxing.uppercutCDMax;
    Boxing.enemyAtkCD = Math.max(Boxing.enemyAtkCD || 0, 70);
    _flash('boxing', '⚠ アッパーカット!!', '#ff5577', 720);
    return true;
  }
  function _tryFireUppercutJudo() {
    if (typeof Judo === 'undefined' || !Judo.en || !Judo.me) return false;
    if (Judo.mode !== 'fight') return false;
    if (Judo.enAction || Judo.enStunT > 0 || Judo.enemyDodgeT > 0) return false;
    if ((Judo.uppercutCD || 0) > 0) return false;
    const dist = Math.hypot(Judo.me.position.x - Judo.en.position.x, Judo.me.position.z - Judo.en.position.z);
    if (dist > 1.85) return false;
    let prob = 0.014;
    if (Judo.meAction) prob += 0.04;
    if (Judo.meHP / Judo.meMaxHP < 0.55) prob += 0.02;
    if (Math.random() > prob) return false;
    const spec = JUDO_ATTACKS.uppercut;
    Judo.enPose = 'uppercut';
    Judo.enAnim = 0;
    Judo.enAction = {
      side:'en', kind:'uppercut',
      label: '敵' + spec.label,
      range: spec.range,
      damage: [spec.damage[0], spec.damage[1]],
      hitAt: spec.hitAt,
      total: spec.total,
      cooldown: 0,
      color: spec.color,
      score: 0,
      knockback: true,
      shieldDmg: spec.shieldDmg,
      t: 0, hitDone: false,
      isUppercut: true,
    };
    Judo.uppercutCD = Judo.uppercutCDMax;
    Judo.enemyAtkCD = Math.max(Judo.enemyAtkCD || 0, 70);
    _flash('judo', '⚠ アッパーカット!!', '#ff5577', 720);
    return true;
  }

  // プレイヤーが uppercut を実行しようとした場合はブロック
  function _wrapPlayerActionForBotOnly() {
    if (typeof _boxingPlayerAction === 'function' && !_boxingPlayerAction.__botGuard) {
      const orig = window._boxingPlayerAction;
      window._boxingPlayerAction = function(kind) {
        if (kind === 'uppercut') return; // bot only
        return orig.apply(this, arguments);
      };
      window._boxingPlayerAction.__botGuard = true;
    }
    if (typeof _playerAction === 'function' && !_playerAction.__botGuard) {
      const orig = window._playerAction;
      window._playerAction = function(kind) {
        if (kind === 'uppercut') return;
        return orig.apply(this, arguments);
      };
      window._playerAction.__botGuard = true;
    }
  }

  // ====================================================================
  // 4)  シールド優先吸収 — 被ダメ判定の直前にフックして shield を先に使う
  //     既存 _applyHit / _boxingApplyHit を包んで、敵側ヒット時に meGuard を一時 ON
  //     にする (元実装の shield ロジックを流用)。
  // ====================================================================
  // 仕様:
  //   - プレイヤー被弾、meInvuln <= 0、shield > 0 のとき、
  //     一時的に meGuard=true 扱いで既存シールド吸収パスを通す。
  //     シールド破壊 (shield<=0) になっても、その被弾分は通常通り
  //     ガード貫通ダメージとして処理される (元実装のまま)。
  //   - 元々 meGuard=true のときは何もしない (通常パス)。
  function _withShieldPriorityBoxing(action, origFn, ctx, args) {
    if (action.side !== 'en') return origFn.apply(ctx, args);
    if (Boxing.meInvuln > 0) return origFn.apply(ctx, args);
    if (Boxing.shieldBroken || Boxing.shield <= 0.01) return origFn.apply(ctx, args);
    if (Boxing.meGuard) return origFn.apply(ctx, args); // 既に guard 中
    Boxing.meGuard = true;
    Boxing.__shieldAutoGuard = true;
    try { return origFn.apply(ctx, args); }
    finally {
      // 自動 guard は被弾処理が終わったら解除
      Boxing.meGuard = false;
      Boxing.__shieldAutoGuard = false;
    }
  }
  function _withShieldPriorityJudo(action, origFn, ctx, args) {
    if (action.side !== 'en') return origFn.apply(ctx, args);
    if (Judo.meInvuln > 0) return origFn.apply(ctx, args);
    if (Judo.shieldBroken || Judo.shield <= 0.01) return origFn.apply(ctx, args);
    if (Judo.meGuard) return origFn.apply(ctx, args);
    // 投げ / 掴み中はシールド無効 (操作不能のため)
    if (action.kind === 'throw' || action.kind === 'grapple') return origFn.apply(ctx, args);
    Judo.meGuard = true;
    Judo.__shieldAutoGuard = true;
    try { return origFn.apply(ctx, args); }
    finally {
      Judo.meGuard = false;
      Judo.__shieldAutoGuard = false;
    }
  }

  function _wrapBoxingApplyHit() {
    if (typeof _boxingApplyHit !== 'function' || _boxingApplyHit.__v15) return;
    const orig = window._boxingApplyHit;
    window._boxingApplyHit = function(action) {
      // アッパーカット は専用ダメージで処理
      if (action && action.isUppercut && action.side === 'en') {
        return _applyUppercutBoxing(action);
      }
      // 被ダメ視点傾き登録
      const meHpBefore = Boxing.meHP;
      const enHpBefore = Boxing.enHP;
      const r = _withShieldPriorityBoxing(action, orig, this, arguments);
      if (action && action.side === 'en' && Boxing.meHP < meHpBefore) {
        _registerCamHitTiltBoxing();
      }
      if (action && action.side === 'me' && Boxing.enHP < enHpBefore) {
        // 敵側にもショックを与えたいなら別途何かする (今回はプレイヤー視点のみ)
      }
      return r;
    };
    window._boxingApplyHit.__v15 = true;
  }
  function _wrapJudoApplyHit() {
    if (typeof _applyHit !== 'function' || _applyHit.__v15) return;
    const orig = window._applyHit;
    window._applyHit = function(action) {
      if (action && action.isUppercut && action.side === 'en') {
        return _applyUppercutJudo(action);
      }
      const meHpBefore = Judo.meHP;
      const r = _withShieldPriorityJudo(action, orig, this, arguments);
      if (action && action.side === 'en' && Judo.meHP < meHpBefore) {
        _registerCamHitTiltJudo();
      }
      return r;
    };
    window._applyHit.__v15 = true;
  }

  // ----- アッパーカット専用ダメージ処理 -----
  function _applyUppercutBoxing(action) {
    if (!Boxing.me || !Boxing.en) return;
    const dist = Math.hypot(Boxing.me.position.x - Boxing.en.position.x, Boxing.me.position.z - Boxing.en.position.z);
    if (dist > action.range) {
      _flash('boxing', 'アッパー空振り', '#cfd8dc', 360);
      return;
    }
    // 回避中なら無効化
    if (Boxing.meInvuln > 0) {
      Boxing.score += 5;
      _flash('boxing', 'アッパー回避!!', '#8fd9ff', 480);
      return;
    }
    let dmg = action.damage[0]; // 固定 34
    const dx = Boxing.me.position.x - Boxing.en.position.x;
    const dz = Boxing.me.position.z - Boxing.en.position.z;
    const dl = Math.hypot(dx, dz) || 1;
    // シールド優先
    let useShield = !Boxing.shieldBroken && Boxing.shield > 0.01;
    if (useShield) {
      const sDmg = action.shieldDmg || 28;
      const absorb = Math.min(Boxing.shield, sDmg);
      Boxing.shield = Math.max(0, Boxing.shield - sDmg);
      const guardEff = absorb / sDmg;
      const blockedRate = 0.35; // タックル相当 (アッパーは強)
      dmg = dmg * (guardEff * blockedRate + (1 - guardEff) * 1.0);
      Boxing.shieldRegenT = Boxing.shieldRegenDelay;
      if (Boxing.shield <= 0) {
        Boxing.shieldBroken = true;
        _flash('boxing', 'アッパーでシールド粉砕!!', '#ff5577', 720);
      } else {
        _flash('boxing', 'ガードでアッパー耐えた!', '#ffd76b', 560);
      }
    }
    Boxing.meHP = Math.max(0, Boxing.meHP - dmg);
    // ノックバック大
    Boxing.me.position.x -= dx / dl * 0.9;
    Boxing.me.position.z -= dz / dl * 0.9;
    if (typeof _boxingClampArena === 'function') _boxingClampArena(Boxing.me);
    if (typeof _resolveBoxingCollision === 'function') _resolveBoxingCollision(0.62, 0.12);
    Boxing.shakeT = 28;
    if (typeof _boxingSpawnRagdoll === 'function') {
      _boxingSpawnRagdoll('me', { x:-dx / dl * 4.0, y: 3.0, z:-dz / dl * 4.0 }, 1.4);
    }
    _flash('boxing', '💥 アッパーカット直撃!!', '#ff5577', 900);
    _registerCamHitTiltBoxing(2.4); // 強め
    if (typeof updateBoxingHUD === 'function') updateBoxingHUD();
  }
  function _applyUppercutJudo(action) {
    if (!Judo.me || !Judo.en) return;
    const dist = Math.hypot(Judo.me.position.x - Judo.en.position.x, Judo.me.position.z - Judo.en.position.z);
    if (dist > action.range) {
      _flash('judo', 'アッパー空振り', '#cfd8dc', 360);
      return;
    }
    if (Judo.meInvuln > 0) {
      Judo.score += 5;
      _flash('judo', 'アッパー回避!!', '#8fd9ff', 480);
      return;
    }
    let dmg = action.damage[0];
    const dx = Judo.me.position.x - Judo.en.position.x;
    const dz = Judo.me.position.z - Judo.en.position.z;
    const dl = Math.hypot(dx, dz) || 1;
    let useShield = !Judo.shieldBroken && Judo.shield > 0.01;
    if (useShield) {
      const sDmg = action.shieldDmg || 28;
      const absorb = Math.min(Judo.shield, sDmg);
      Judo.shield = Math.max(0, Judo.shield - sDmg);
      const guardEff = absorb / sDmg;
      const blockedRate = 0.35;
      dmg = dmg * (guardEff * blockedRate + (1 - guardEff) * 1.0);
      Judo.shieldRegenT = Judo.shieldRegenDelay;
      if (Judo.shield <= 0) {
        Judo.shieldBroken = true;
        _flash('judo', 'アッパーでシールド粉砕!!', '#ff5577', 720);
      } else {
        _flash('judo', 'ガードでアッパー耐えた!', '#ffd76b', 560);
      }
    }
    Judo.meHP = Math.max(0, Judo.meHP - dmg);
    Judo.me.position.x -= dx / dl * 0.9;
    Judo.me.position.z -= dz / dl * 0.9;
    if (typeof _clampArena === 'function') _clampArena(Judo.me);
    if (typeof _resolveJudoCollision === 'function') _resolveJudoCollision(0.62, 0.12);
    Judo.shakeT = 28;
    Judo.meStunT = Math.max(Judo.meStunT || 0, 1.4);
    Judo.mePose = 'down';
    _flash('judo', '💥 アッパーカット直撃!!', '#ff5577', 900);
    _registerCamHitTiltJudo(2.4);
    if (typeof updateJudoHUD === 'function') updateJudoHUD();
  }

  // ====================================================================
  // 5)  被ダメで視点が相手方向に傾く  (カメラの位置/lookAt を一時的にオフセット)
  // ====================================================================
  // 既存 _updateBoxingCamera / _updateCamera を包む。
  if (typeof Boxing !== 'undefined') {
    Boxing._hitTiltT = 0;        // 残り時間 (秒)
    Boxing._hitTiltAmount = 0;   // 振幅 0..1
  }
  if (typeof Judo !== 'undefined') {
    Judo._hitTiltT = 0;
    Judo._hitTiltAmount = 0;
  }
  function _registerCamHitTiltBoxing(strength) {
    const s = Math.max(1.0, Math.min(3.0, strength || 1.0));
    Boxing._hitTiltT = Math.max(Boxing._hitTiltT || 0, 0.55 * s);
    Boxing._hitTiltAmount = s;
  }
  function _registerCamHitTiltJudo(strength) {
    const s = Math.max(1.0, Math.min(3.0, strength || 1.0));
    Judo._hitTiltT = Math.max(Judo._hitTiltT || 0, 0.55 * s);
    Judo._hitTiltAmount = s;
  }

  function _wrapBoxingCamera() {
    if (typeof _updateBoxingCamera !== 'function' || _updateBoxingCamera.__v15) return;
    const orig = window._updateBoxingCamera;
    window._updateBoxingCamera = function() {
      orig.apply(this, arguments);
      try {
        if (!Boxing.camera || !Boxing.me || !Boxing.en) return;
        if ((Boxing._hitTiltT || 0) <= 0) return;
        // me から en への単位ベクトル (XZ 平面)
        const dx = Boxing.en.position.x - Boxing.me.position.x;
        const dz = Boxing.en.position.z - Boxing.me.position.z;
        const dl = Math.hypot(dx, dz) || 1;
        const nx = dx / dl, nz = dz / dl;
        // 強度: 残り時間に比例
        const k = Math.min(1, Boxing._hitTiltT / 0.55) * (Boxing._hitTiltAmount || 1);
        // カメラの注視点を相手方向に少しずらす + ロールを傾ける
        const focusX = (Boxing.me.position.x + Boxing.en.position.x) * 0.5;
        const focusZ = (Boxing.me.position.z + Boxing.en.position.z) * 0.5;
        const tiltOffset = 0.55 * k;
        Boxing.camera.lookAt(
          focusX + nx * tiltOffset,
          1.45 - 0.35 * k,
          focusZ + nz * tiltOffset
        );
        // 視点ロール (Z 回転) を相手方向にひねる
        const screenSide = (nx * Math.cos(Boxing.camera.rotation.y) - nz * Math.sin(Boxing.camera.rotation.y));
        Boxing.camera.rotation.z += 0.22 * k * (screenSide >= 0 ? 1 : -1);
      } catch(e) {}
    };
    window._updateBoxingCamera.__v15 = true;
  }
  function _wrapJudoCamera() {
    if (typeof _updateCamera !== 'function' || _updateCamera.__v15) return;
    const orig = window._updateCamera;
    window._updateCamera = function() {
      orig.apply(this, arguments);
      try {
        if (!Judo.camera || !Judo.me || !Judo.en) return;
        if ((Judo._hitTiltT || 0) <= 0) return;
        const dx = Judo.en.position.x - Judo.me.position.x;
        const dz = Judo.en.position.z - Judo.me.position.z;
        const dl = Math.hypot(dx, dz) || 1;
        const nx = dx / dl, nz = dz / dl;
        const k = Math.min(1, Judo._hitTiltT / 0.55) * (Judo._hitTiltAmount || 1);
        const focusX = (Judo.me.position.x + Judo.en.position.x) * 0.5;
        const focusZ = (Judo.me.position.z + Judo.en.position.z) * 0.5;
        const tiltOffset = 0.55 * k;
        Judo.camera.lookAt(
          focusX + nx * tiltOffset,
          1.45 - 0.35 * k,
          focusZ + nz * tiltOffset
        );
        const screenSide = (nx * Math.cos(Judo.camera.rotation.y) - nz * Math.sin(Judo.camera.rotation.y));
        Judo.camera.rotation.z += 0.22 * k * (screenSide >= 0 ? 1 : -1);
      } catch(e) {}
    };
    window._updateCamera.__v15 = true;
  }

  // ====================================================================
  // 3)  リバイブ回数 = 2  (Boxing ループ内で reviveLeft の自動再開放を上書き)
  // ====================================================================
  // 既存の _onBoxingKO / 復活成功ロジックで reviveLeft が 999 にリセットされる箇所をフック。
  function _enforceReviveLimit() {
    if (typeof Boxing === 'undefined') return;
    // Boxing.reviveLeft は startBoxing 内で 999 にされる可能性があるため、
    // 開始フックで 2 に固定。
    if (typeof startBoxing !== 'undefined' && !startBoxing.__v15Revive) {
      const orig = window.startBoxing;
      window.startBoxing = function() {
        const r = orig.apply(this, arguments);
        try { Boxing.reviveLeft = 2; } catch(e) {}
        try { Boxing.uppercutCD = 0; } catch(e) {}
        return r;
      };
      window.startBoxing.__v15Revive = true;
    }
  }

  // ====================================================================
  // メインループフック (Boxing + Judo)
  //   - プレイヤー回避中の残像スポーン / 更新
  //   - アッパーカット発動チェック
  //   - hit tilt タイマー減衰
  // ====================================================================
  function _wrapBoxingLoopV15() {
    if (typeof _boxingLoop !== 'function' || _boxingLoop.__v15) return;
    let prevT = 0;
    const orig = window._boxingLoop;
    window._boxingLoop = function(now) {
      const dt = prevT ? Math.min(0.05, (now - prevT) / 1000) : 0.016;
      prevT = now;
      try {
        // uppercut CD 減算 (秒単位)
        if (Boxing.uppercutCD > 0) Boxing.uppercutCD = Math.max(0, Boxing.uppercutCD - dt);
        // hit tilt 減衰
        if (Boxing._hitTiltT > 0) Boxing._hitTiltT = Math.max(0, Boxing._hitTiltT - dt);
        // 回避(ロール)中のプレイヤー残像
        if (Boxing.running && Boxing.meRollT > 0 && !Boxing.meRagdoll) {
          _bxPlayerAfterT -= dt;
          if (_bxPlayerAfterT <= 0) {
            _spawnPlayerAfterimageBoxing();
            _bxPlayerAfterT = 0.045;
          }
        } else {
          _bxPlayerAfterT = 0;
        }
        _updatePlayerAfterimagesBoxing(dt, (now || performance.now()) * 0.001);
        // アッパーカット トリガー判定
        if (Boxing.running) _tryFireUppercutBoxing();
      } catch(e) {}
      return orig.apply(this, arguments);
    };
    window._boxingLoop.__v15 = true;
  }
  function _wrapJudoLoopV15() {
    if (typeof _judoLoop !== 'function' || _judoLoop.__v15) return;
    let prevT = 0;
    const orig = window._judoLoop;
    window._judoLoop = function(now) {
      const dt = prevT ? Math.min(0.05, (now - prevT) / 1000) : 0.016;
      prevT = now;
      try {
        if (Judo.uppercutCD > 0) Judo.uppercutCD = Math.max(0, Judo.uppercutCD - dt);
        if (Judo._hitTiltT > 0) Judo._hitTiltT = Math.max(0, Judo._hitTiltT - dt);
        if (Judo.running && Judo.meRollT > 0 && Judo.meStunT <= 0) {
          _jdPlayerAfterT -= dt;
          if (_jdPlayerAfterT <= 0) {
            _spawnPlayerAfterimageJudo();
            _jdPlayerAfterT = 0.045;
          }
        } else {
          _jdPlayerAfterT = 0;
        }
        _updatePlayerAfterimagesJudo(dt, (now || performance.now()) * 0.001);
        if (Judo.running) _tryFireUppercutJudo();
      } catch(e) {}
      return orig.apply(this, arguments);
    };
    window._judoLoop.__v15 = true;
  }

  // ====================================================================
  // 設置
  // ====================================================================
  function _install() {
    _registerUppercut();
    _wrapPlayerActionForBotOnly();
    _wrapBoxingApplyHit();
    _wrapJudoApplyHit();
    _wrapBoxingCamera();
    _wrapJudoCamera();
    _wrapBoxingLoopV15();
    _wrapJudoLoopV15();
    _enforceReviveLimit();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', _install);
  } else {
    _install();
    setTimeout(_install, 0);
    setTimeout(_install, 250);
    window.addEventListener('load', _install, { once:true });
  }
})();
</script>
<script>
/* ====== ガリガリライブ 瀕死(這いずり) & ボクシング リバイブアニメ パッチ v2 ====== */
(function(){
  if (window.__genspark_revive_live_patch_v2) return;
  window.__genspark_revive_live_patch_v2 = true;

  /* ---- 1. ライブ瀕死モードの UI バー ---- */
  function ensureLiveReviveUi() {
    const overlay = document.getElementById('liveOverlay');
    if (!overlay || document.getElementById('liveReviveStatus')) return;
    const bar = document.createElement('div');
    bar.id = 'liveReviveStatus';
    bar.style.cssText = 'position:absolute;top:58px;left:10px;right:10px;display:none;padding:8px 12px;text-align:center;background:rgba(70,0,0,0.58);border:1px solid rgba(255,120,120,0.5);border-radius:12px;color:#ffd6d6;font-weight:bold;font-size:13px;z-index:6;pointer-events:none;backdrop-filter:blur(4px);';
    overlay.appendChild(bar);
  }

  function updateLiveReviveUi() {
    ensureLiveReviveUi();
    const bar = document.getElementById('liveReviveStatus');
    if (!bar || typeof Live === 'undefined') return;
    if (Live.downed) {
      const remain = Math.max(0, Live.downed.remain || 0);
      bar.style.display = 'block';
      bar.innerHTML = '💔 瀕死中 残り <span style="color:#ffd76b;">' + remain.toFixed(1) + '</span>秒 ・ 左スティックでゆっくり這いずれます';
    } else {
      bar.style.display = 'none';
    }
  }

  /* ---- 2. ライブモードの 這いずりアニメ ---- */
  function animateLiveCrawl(group, time, moving) {
    if (!group || !group._parts) return;
    const p = group._parts;
    const cycle = Math.sin(time * 7.5);
    // _makeStickman のパーツ構造: { armL, armR, legL, legR, head }
    // body は _parts に登録されていないので group.children[0] が body
    let body = null;
    if (group.children && group.children.length > 0) {
      // 最初の Mesh が body
      for (const c of group.children) {
        if (c.isMesh && c !== p.head && c !== p.armL && c !== p.armR && c !== p.legL && c !== p.legR) {
          body = c; break;
        }
      }
    }
    if (body) {
      body.rotation.x = 1.18 + (moving ? Math.sin(time * 4.2) * 0.06 : 0);
      body.rotation.y = moving ? Math.sin(time * 2.6) * 0.08 : 0.14;
      body.position.y = 0.62;
      body.position.z = 0.14;
    }
    if (p.head) {
      p.head.rotation.x = -0.55;
      p.head.position.y = 1.05;
      p.head.position.z = 0.46;
    }
    // 左腕: 腹を押さえる
    if (p.armL) {
      p.armL.rotation.x = -1.85 + (moving ? cycle * 0.05 : 0);
      p.armL.rotation.z = -0.95;
      p.armL.position.set(-0.18, 0.85, 0.32);
    }
    // 右腕: 地面についてもがく
    if (p.armR) {
      p.armR.rotation.x = -1.05 + (moving ? cycle * 0.25 : 0);
      p.armR.rotation.z = 0.35;
      p.armR.position.set(0.36, 0.78, 0.28);
    }
    // 脚: 折りたたみ
    if (p.legL) {
      p.legL.rotation.x = 0.92 + (moving ? -cycle * 0.30 : 0);
      p.legL.position.set(-0.18, 0.10, -0.06);
    }
    if (p.legR) {
      p.legR.rotation.x = 0.92 + (moving ? cycle * 0.30 : 0);
      p.legR.position.set(0.18, 0.10, -0.06);
    }
  }

  /* ---- 3. ライブモードの 瀕死アクション禁止 ---- */
  function blockLiveActionWhileDowned(fn) {
    return function() {
      if (typeof Live !== 'undefined' && Live.downed) return;
      return fn && fn.apply(this, arguments);
    };
  }
  function wrapLiveTrigger(name) {
    if (typeof window[name] !== 'function' || window[name].__downedBlocked) return;
    const orig = window[name];
    window[name] = blockLiveActionWhileDowned(orig);
    window[name].__downedBlocked = true;
  }
  wrapLiveTrigger('_liveTriggerAttack');
  wrapLiveTrigger('_liveTriggerCar');
  wrapLiveTrigger('_liveTriggerDash');
  wrapLiveTrigger('_liveTriggerHorn');

  /* ---- 4. _liveUpdatePlayer をラップ: 瀕死中の這いずり制御 ---- */
  if (window._liveUpdatePlayer && !window._liveUpdatePlayer.__downedV2Wrapped) {
    const origLiveUpdatePlayer = window._liveUpdatePlayer;
    window._liveUpdatePlayer = function(dt) {
      ensureLiveReviveUi();
      if (typeof Live === 'undefined' || !Live.player) {
        return origLiveUpdatePlayer.apply(this, arguments);
      }
      // 瀕死状態の専用更新
      if (Live.downed) {
        Live.player.attackCD = Math.max(0, (Live.player.attackCD || 0) - dt);
        Live.dashCD = Math.max(0, (Live.dashCD || 0) - dt);
        Live.downed.remain -= dt;
        if (Live.downed.remain <= 0) {
          // 時間切れ → リスポーン (即死フラグで _liveDeath を貫通)
          Live.__instantDeathReason = 'bleedout';
          if (typeof _liveDeath === 'function') _liveDeath();
          else if (typeof _liveRespawn === 'function') _liveRespawn();
          updateLiveReviveUi();
          return;
        }
        const dx = Live._inDx || 0;
        const dy = Live._inDy || 0;
        const mag = Math.hypot(dx, dy);
        const maxSpeed = 1.2;
        if (mag > 0.08) {
          Live.player.yaw -= dx * 1.7 * dt * (Math.abs(dy) * 0.45 + 0.45);
          const targetSpd = -dy * maxSpeed;
          const fx = Math.sin(Live.player.yaw), fz = Math.cos(Live.player.yaw);
          const tx = fx * targetSpd;
          const tz = fz * targetSpd;
          Live.player.vel.x += (tx - Live.player.vel.x) * Math.min(1, dt * 6);
          Live.player.vel.z += (tz - Live.player.vel.z) * Math.min(1, dt * 6);
        } else {
          Live.player.vel.x *= 0.74;
          Live.player.vel.z *= 0.74;
        }
        Live.player.pos.x += Live.player.vel.x * dt;
        Live.player.pos.z += Live.player.vel.z * dt;
        if (typeof _clampCity === 'function') _clampCity(Live.player.pos);
        if (typeof _resolveCollision === 'function') {
          const hit = _resolveCollision(Live.player.pos, 0.45, {});
          if (hit) {
            if (hit.type === 'car') {
              // 瀕死中に車に轢かれたら問答無用の即死
              if (typeof _liveLog === 'function') _liveLog('💥 瀕死中に車に轢かれて即死！');
              Live.__instantDeathReason = 'car';
              if (typeof _liveDeath === 'function') _liveDeath();
              else if (typeof _liveRespawn === 'function') _liveRespawn();
              updateLiveReviveUi();
              return;
            }
            const dot = Live.player.vel.x * hit.nx + Live.player.vel.z * hit.nz;
            if (dot < 0) {
              Live.player.vel.x -= dot * hit.nx;
              Live.player.vel.z -= dot * hit.nz;
            }
          }
        }
        if (Live.player.group && !Live.player.group._ragdolled) {
          Live.player.group.visible = true;
          Live.player.group.position.copy(Live.player.pos);
          Live.player.group.rotation.y = Live.player.yaw;
          animateLiveCrawl(Live.player.group, performance.now() / 1000, mag > 0.08);
        }
        if (typeof _updateLiveHUD === 'function') _updateLiveHUD();
        updateLiveReviveUi();
        return;
      }
      // 通常更新
      const ret = origLiveUpdatePlayer.apply(this, arguments);
      // 車に轢かれた瞬間 (fatal ラグドール発動) → 待たずに即死扱い
      if (Live.playerRagdoll && Live.playerRagdoll.fatal) {
        Live.__instantDeathReason = 'car';
      }
      updateLiveReviveUi();
      return ret;
    };
    window._liveUpdatePlayer.__downedV2Wrapped = true;
  }

  /* ---- 5. dispose / start hook ---- */
  if (window._disposeLive && !window._disposeLive.__downedV2Wrapped) {
    const orig = window._disposeLive;
    window._disposeLive = function() {
      if (typeof Live !== 'undefined') {
        Live.downed = null;
        Live.__instantDeathReason = '';
      }
      const bar = document.getElementById('liveReviveStatus');
      if (bar) bar.style.display = 'none';
      return orig.apply(this, arguments);
    };
    window._disposeLive.__downedV2Wrapped = true;
  }
  if (window.startLive && !window.startLive.__downedV2Wrapped) {
    const orig = window.startLive;
    window.startLive = async function() {
      const ret = await orig.apply(this, arguments);
      if (typeof Live !== 'undefined') {
        Live.downed = null;
        Live.__instantDeathReason = '';
      }
      ensureLiveReviveUi();
      updateLiveReviveUi();
      return ret;
    };
    window.startLive.__downedV2Wrapped = true;
  }

  document.addEventListener('DOMContentLoaded', function() {
    ensureLiveReviveUi();
    updateLiveReviveUi();
  });

  /* ---- 6. ボクシングのリバイブ姿勢を毎フレーム再強制 (他の関数の上書き対策) ---- */
  // _boxingLoop は requestAnimationFrame で回る。最終的に reviveCrawl を維持するラッパー。
  if (window._boxingLoop && !window._boxingLoop.__crawlForce) {
    const origBoxingLoop = window._boxingLoop;
    window._boxingLoop = function() {
      // ループ実行前に状態をチェックして、リバイブ中なら強制的に reviveCrawl にしておく
      // (このタイミングは _updateBoxingRevive 呼び出しよりは前ではないが、次フレームに反映される)
      if (typeof Boxing !== 'undefined' && (Boxing.mode === 'revive')) {
        Boxing.mePose = 'reviveCrawl';
      }
      return origBoxingLoop.apply(this, arguments);
    };
    window._boxingLoop.__crawlForce = true;
  }
})();
</script>

<script defer src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447" integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==" data-cf-beacon='{"version":"2024.11.0","token":"4edd5f8ec12a48cfa682ab8261b80a79","server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>
</body>
</html>
